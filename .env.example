# Public runtime configuration
PUBLIC_SITE_URL=https://wheylandelectric.com
PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/mnjbbrvn

# Build-time Google Places API (never exposed to browser)
# Used to fetch live review count and rating on each deploy.
# Get your Place ID: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
GOOGLE_PLACES_API_KEY=your_api_key_here
GOOGLE_PLACE_ID=your_place_id_here
