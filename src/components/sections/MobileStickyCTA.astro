---
import { site } from '../../data/site';
---

<div
  class="fixed inset-x-0 bottom-0 z-40 border-t border-brand-slate/80 bg-brand-slate px-4 pb-[max(env(safe-area-inset-bottom),0.75rem)] pt-3 shadow-lg lg:hidden"
>
  <div class="mx-auto grid max-w-7xl grid-cols-2 gap-3">
    <a
      href={`tel:${site.nap.phoneTel}`}
      class="flex min-h-[44px] items-center justify-center rounded-lg border border-white/30 px-3 py-2 text-center text-sm font-semibold text-white transition-colors hover:bg-white/10"
      aria-label={`Call ${site.nap.phone}`}
    >
      Call now
    </a>
    <a
      href="/free-estimates/"
      class="flex min-h-[44px] items-center justify-center rounded-lg bg-brand-gold px-3 py-2 text-center text-sm font-semibold text-brand-slate transition-colors hover:bg-brand-gold-hover"
    >
      Free estimate
    </a>
  </div>
</div>
