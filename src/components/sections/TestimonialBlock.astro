---
import { flags } from '../../data/site';
import { testimonials } from '../../data/testimonials';
import { site } from '../../data/site';
import Section from '../ui/Section.astro';

interface Props {
  heading?: string;
  serviceTag?: string;
  cityTag?: string;
}

const { heading = 'Customer Feedback', serviceTag, cityTag } = Astro.props;

const showExcerpts = flags.show_review_excerpts;
const filteredTestimonials = testimonials.filter((t) => {
  if (serviceTag && t.serviceTag !== serviceTag) return false;
  if (cityTag && t.cityTag && t.cityTag !== cityTag) return false;
  return true;
});

const featured = filteredTestimonials[0] ?? testimonials[0];
---
<Section bg="indigo" size="loose" class="relative overflow-hidden">
  <div class="pointer-events-none absolute left-8 top-8 select-none font-serif text-[120px] leading-none text-brand-teal/20 md:left-16 md:text-[180px]" aria-hidden="true">&ldquo;</div>
  <div class="pointer-events-none absolute bottom-8 right-8 select-none font-serif text-[120px] leading-none text-brand-teal/20 md:right-16 md:text-[180px]" aria-hidden="true">&rdquo;</div>

  <div class="relative mx-auto max-w-4xl text-center">
    <h2 class="mb-10 text-2xl font-heading font-bold text-white md:text-3xl">{heading}</h2>

    {showExcerpts && featured ? (
      <div>
        <div class="mb-8 flex justify-center gap-1">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="h-6 w-6 text-brand-gold" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>

        <blockquote class="mx-auto mb-8 max-w-3xl text-xl font-heading leading-relaxed text-white md:text-2xl">
          &ldquo;{featured.text}&rdquo;
        </blockquote>

        <div>
          <p class="text-base font-bold text-white">{featured.author}</p>
          {featured.cityTag && (
            <p class="mt-1 text-sm capitalize text-white/60">{featured.cityTag.replace(/-/g, ' ')}, CA</p>
          )}
        </div>

        <a
          href={site.gbp.url}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-brand-teal transition-colors hover:text-white"
        >
          Read more reviews on Google
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    ) : (
      <div>
        <div class="mb-6 flex justify-center gap-1">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="h-6 w-6 text-brand-gold" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="mb-6 text-lg text-white/80">
          We&rsquo;re proud of our reputation. See what our customers say on Google.
        </p>
        <a
          href={site.gbp.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-semibold text-brand-teal transition-colors hover:text-white"
        >
          Read our reviews on Google
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    )}
  </div>
</Section>
