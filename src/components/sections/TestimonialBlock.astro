---
import { flags } from '../../data/site';
import { testimonials } from '../../data/testimonials';
import { site } from '../../data/site';

interface Props {
  heading?: string;
  serviceTag?: string;
  cityTag?: string;
}

const { heading = 'Customer Feedback', serviceTag, cityTag } = Astro.props;

const showExcerpts = flags.show_review_excerpts;
const filteredTestimonials = testimonials.filter((t) => {
  if (serviceTag && t.serviceTag !== serviceTag) return false;
  if (cityTag && t.cityTag && t.cityTag !== cityTag) return false;
  return true;
});

const featured = filteredTestimonials[0] ?? testimonials[0];
---
<section class="bg-brand-slate py-16 md:py-24 relative overflow-hidden">
  {/* Decorative quote marks */}
  <div class="absolute top-8 left-8 md:left-16 text-brand-teal/10 text-[120px] md:text-[180px] font-serif leading-none select-none pointer-events-none" aria-hidden="true">&ldquo;</div>
  <div class="absolute bottom-8 right-8 md:right-16 text-brand-teal/10 text-[120px] md:text-[180px] font-serif leading-none select-none pointer-events-none" aria-hidden="true">&rdquo;</div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-10">{heading}</h2>

    {showExcerpts && featured ? (
      <div>
        {/* Gold stars */}
        <div class="flex justify-center gap-1 mb-8">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="w-6 h-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>

        <blockquote class="text-white text-xl md:text-2xl leading-relaxed font-heading mb-8 max-w-3xl mx-auto">
          &ldquo;{featured.text}&rdquo;
        </blockquote>

        <div>
          <p class="text-white font-bold text-base">{featured.author}</p>
          {featured.cityTag && (
            <p class="text-white/60 text-sm mt-1 capitalize">{featured.cityTag.replace(/-/g, ' ')}, CA</p>
          )}
        </div>

        <a
          href={site.gbp.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-brand-teal hover:text-white text-sm font-semibold mt-8 transition-colors"
        >
          Read more reviews on Google
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    ) : (
      <div>
        <div class="flex justify-center gap-1 mb-6">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="w-6 h-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="text-white/80 text-lg mb-6">
          We&rsquo;re proud of our reputation. See what our customers say on Google.
        </p>
        <a
          href={site.gbp.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-brand-teal hover:text-white font-semibold transition-colors"
        >
          Read our reviews on Google
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
