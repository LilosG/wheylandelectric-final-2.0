---
import { site } from '../../data/site';
import { getDisplayReviews } from '../../data/reviews';
import { reviewStats } from '../../data/testimonials';

interface Props {
  heading?: string;
  serviceTag?: string;
  cityTag?: string;
}

const { heading = 'Customer Feedback' } = Astro.props;
const reviews = getDisplayReviews();
---

<section class="bg-brand-navy py-16 md:py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {/* Header */}
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-3">{heading}</h2>
      <div class="flex items-center justify-center gap-2 mb-2">
        {[1,2,3,4,5].map(() => (
          <svg class="w-5 h-5 text-brand-gold" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
        <span class="text-white font-bold text-sm ml-1">{reviewStats.rating}.0</span>
        <span class="text-white/50 text-sm">·</span>
        <span class="text-white/70 text-sm">{reviewStats.count} reviews on Google</span>
      </div>
    </div>

    {/* Review cards grid — shows 3 on desktop, 1 on mobile */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      {reviews.slice(0, 3).map((review) => (
        <div class="bg-white/5 border border-white/10 rounded-xl p-6 flex flex-col">
          {/* Stars */}
          <div class="flex gap-1 mb-4" aria-label={`${review.rating} out of 5 stars`}>
            {[1,2,3,4,5].map((n) => (
              <svg class={`w-4 h-4 ${n <= review.rating ? 'text-brand-gold' : 'text-white/20'}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          {/* Quote */}
          <blockquote class="text-white/85 text-sm leading-relaxed flex-1 mb-5">
            &ldquo;{review.text.length > 220 ? review.text.slice(0, 220).trimEnd() + '\u2026' : review.text}&rdquo;
          </blockquote>
          {/* Author */}
          <div class="flex items-center gap-3 mt-auto pt-4 border-t border-white/10">
            <div class="w-8 h-8 rounded-full bg-brand-teal/20 flex items-center justify-center shrink-0">
              <span class="text-brand-teal text-xs font-bold uppercase">{review.author.charAt(0)}</span>
            </div>
            <div>
              <p class="text-white text-sm font-semibold leading-tight">{review.author}</p>
              <div class="flex items-center gap-1 mt-0.5">
                <svg class="w-3 h-3 text-white/40" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M21.35 11.1h-9.17v2.73h6.51c-.33 3.81-3.5 5.44-6.5 5.44C8.36 19.27 5 16.25 5 12c0-4.1 3.2-7.27 7.2-7.27 3.09 0 4.9 1.97 4.9 1.97L19 4.72S16.56 2 12.1 2C6.42 2 2.03 6.8 2.03 12c0 5.05 4.13 10 10.22 10 5.35 0 9.25-3.67 9.25-9.09 0-1.15-.15-1.81-.15-1.81z"/>
                </svg>
                <span class="text-white/40 text-xs">Google review</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Second row — 3 more reviews, hidden on mobile */}
    {reviews.length > 3 && (
      <div class="hidden md:grid md:grid-cols-3 gap-6 mb-10">
        {reviews.slice(3, 6).map((review) => (
          <div class="bg-white/5 border border-white/10 rounded-xl p-6 flex flex-col">
            <div class="flex gap-1 mb-4" aria-label={`${review.rating} out of 5 stars`}>
              {[1,2,3,4,5].map((n) => (
                <svg class={`w-4 h-4 ${n <= review.rating ? 'text-brand-gold' : 'text-white/20'}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="text-white/85 text-sm leading-relaxed flex-1 mb-5">
              &ldquo;{review.text.length > 220 ? review.text.slice(0, 220).trimEnd() + '\u2026' : review.text}&rdquo;
            </blockquote>
            <div class="flex items-center gap-3 mt-auto pt-4 border-t border-white/10">
              <div class="w-8 h-8 rounded-full bg-brand-teal/20 flex items-center justify-center shrink-0">
                <span class="text-brand-teal text-xs font-bold uppercase">{review.author.charAt(0)}</span>
              </div>
              <div>
                <p class="text-white text-sm font-semibold leading-tight">{review.author}</p>
                <div class="flex items-center gap-1 mt-0.5">
                  <svg class="w-3 h-3 text-white/40" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill="currentColor" d="M21.35 11.1h-9.17v2.73h6.51c-.33 3.81-3.5 5.44-6.5 5.44C8.36 19.27 5 16.25 5 12c0-4.1 3.2-7.27 7.2-7.27 3.09 0 4.9 1.97 4.9 1.97L19 4.72S16.56 2 12.1 2C6.42 2 2.03 6.8 2.03 12c0 5.05 4.13 10 10.22 10 5.35 0 9.25-3.67 9.25-9.09 0-1.15-.15-1.81-.15-1.81z"/>
                  </svg>
                  <span class="text-white/40 text-xs">Google review</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

    {/* Footer CTA */}
    <div class="text-center">
      
        href={site.gbp.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-teal hover:text-white text-sm font-semibold transition-colors"
      >
        Read all {reviewStats.count} reviews on Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

  </div>
</section>
