---
import { getPublishedProjects, getProjectsByCity, getProjectsByService } from '../../data/projects';

interface Props {
  citySlug?: string;
  serviceSlug?: string;
  heading?: string;
}

const { citySlug, serviceSlug, heading = 'Recent Projects' } = Astro.props;

let projects = getPublishedProjects();
if (citySlug) projects = getProjectsByCity(citySlug);
if (serviceSlug) projects = getProjectsByService(serviceSlug);
---
<div>
  <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-slate mb-8">{heading}</h2>

  {projects.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div class="bg-white rounded-xl shadow-md overflow-hidden">
          <div class="aspect-video bg-surface-subtle flex items-center justify-center">
            <span class="text-sm text-text-muted">Project photo</span>
          </div>
          <div class="p-4">
            <h3 class="font-semibold text-brand-slate mb-1">{project.title}</h3>
            <p class="text-sm text-text-muted">{project.description}</p>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <div class="bg-white rounded-xl shadow-md p-8 text-center">
      <div class="w-16 h-16 bg-surface-subtle rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <p class="text-text-muted">Project photos coming soon. Contact us to see examples of our work.</p>
    </div>
  )}
</div>
