---
import { site } from '../../data/site';
---
<div class="bg-surface py-5">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex flex-wrap justify-center items-center gap-6 md:gap-10">
      <span class="text-brand-slate font-semibold text-sm">Established {site.established}</span>
      <span aria-hidden="true" class="text-brand-slate/40">|</span>
      <span class="text-brand-slate font-semibold text-sm">{site.license}</span>
      <span aria-hidden="true" class="text-brand-slate/40">|</span>
      <span class="text-brand-slate font-semibold text-sm">Licensed, Bonded &amp; Insured</span>
      <span aria-hidden="true" class="text-brand-slate/40">|</span>
      <span class="text-brand-slate font-semibold text-sm">1-Year Labor Warranty</span>
    </div>
  </div>
</div>
