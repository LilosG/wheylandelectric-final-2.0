---
import { site } from '../../data/site';
import Button from '../ui/Button.astro';

interface Props {
  heading?: string;
  description?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
  background?: 'subtle' | 'white' | 'teal';
}

const {
  heading = 'Ready to get started?',
  description = 'Get a free, no-obligation estimate for your project.',
  primaryText = 'Request Free Estimate',
  primaryHref = '/free-estimates/',
  secondaryText = `Call ${site.nap.phone}`,
  secondaryHref = `tel:${site.nap.phoneTel}`,
  background = 'subtle',
} = Astro.props;

const bgClass: Record<string, string> = {
  subtle: 'bg-surface-subtle',
  white: 'bg-white border border-slate-200',
  teal: 'bg-brand-teal/10 border border-brand-teal/20',
};
---

<div class={`rounded-xl p-6 md:p-8 text-center ${bgClass[background] ?? bgClass.subtle}`}>
  {heading && (
    <p class="text-lg font-semibold text-brand-slate mb-2">{heading}</p>
  )}
  {description && (
    <p class="text-text-muted text-sm mb-5">{description}</p>
  )}
  <div class="flex flex-col sm:flex-row gap-3 justify-center">
    <Button href={primaryHref} variant="primary">{primaryText}</Button>
    {secondaryText && secondaryHref && (
      <Button href={secondaryHref} variant="secondary">{secondaryText}</Button>
    )}
  </div>
</div>
