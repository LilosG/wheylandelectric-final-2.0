---
import { site } from '../../data/site';

const trustPills = [
  site.license,
  '1-Year Warranty',
  'Fully Insured',
];
---
<section class="bg-white py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center">
      {/* Left — family portrait */}
      <div class="lg:col-span-3">
        <div class="relative rounded-2xl overflow-hidden shadow-xl aspect-[4/3]">
          <img
            src="/images/about/wheyland-electric-family-portrait.webp"
            alt="The Wheyland Electric family — locally owned electrical contractor in Carlsbad, CA"
            width="800"
            height="600"
            class="w-full h-full object-cover object-top"
            loading="lazy"
          />
        </div>
      </div>

      {/* Right — quote + bio */}
      <div class="lg:col-span-2">
        <span class="text-brand-teal text-xs uppercase tracking-wider font-semibold mb-4 block">
          Since {site.established} in North County
        </span>

        <blockquote class="text-xl md:text-2xl font-heading font-bold text-brand-slate leading-snug mb-6">
          &ldquo;Build our business with the same standards of care and ethics we strive to build our{' '}
          <span class="text-brand-gold">family.</span>&rdquo;
        </blockquote>

        <p class="text-text-muted leading-relaxed mb-6">
          {site.owner.name} is a {site.owner.generation}. He grew up in North County aware of the benefits of being local, buying local, and knowing first hand with whom you are dealing. Wheyland Electric carries that same personal accountability into every project.
        </p>

        <div class="flex flex-wrap gap-3 mb-6">
          {trustPills.map((pill) => (
            <span class="border border-brand-teal text-brand-teal text-xs font-semibold px-3 py-1.5 rounded-full">
              {pill}
            </span>
          ))}
        </div>

        <a href="/about/" class="text-brand-teal hover:text-brand-teal-light font-semibold inline-flex items-center gap-1 transition-colors text-sm">
          Learn More About Us
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>
