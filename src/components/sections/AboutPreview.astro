---
import { site } from '../../data/site';
import Section from '../ui/Section.astro';

const trustPills = [site.license, '1-Year Warranty', 'Fully Insured'];
---
<Section bg="white" size="loose">
  <div class="grid items-center gap-8 lg:grid-cols-5 lg:gap-12">
    <div class="lg:col-span-3">
      <div class="relative aspect-[4/3] overflow-hidden rounded-2xl shadow-xl">
        <img
          src="/images/about/wheyland-electric-family-portrait-carlsbad.webp"
          alt="The Wheyland Electric family — locally owned electrical contractor in Carlsbad, CA"
          width="800"
          height="600"
          class="h-full w-full object-cover object-top"
          loading="lazy"
        />
      </div>
    </div>

    <div class="lg:col-span-2">
      <span class="mb-4 block text-xs font-semibold uppercase tracking-wider text-brand-teal">
        Since {site.established} in North County
      </span>

      <blockquote class="mb-6 text-xl font-heading font-bold leading-snug text-brand-slate md:text-2xl">
        &ldquo;Build our business with the same standards of care and ethics we strive to build our{' '}
        <span class="text-brand-gold">family.</span>&rdquo;
      </blockquote>

      <p class="mb-6 leading-relaxed text-text-muted">
        {site.owner.name} is a {site.owner.generation}. He grew up in North County aware of the
        benefits of being local, buying local, and knowing first hand with whom you are dealing.
        Wheyland Electric carries that same personal accountability into every project.
      </p>

      <div class="mb-6 flex flex-wrap gap-3">
        {trustPills.map((pill) => (
          <span class="rounded-full border border-brand-teal px-3 py-1.5 text-xs font-semibold text-brand-teal">
            {pill}
          </span>
        ))}
      </div>

      <a
        href="/about/"
        class="inline-flex items-center gap-1 text-sm font-semibold text-brand-teal transition-colors hover:text-brand-teal-light"
      >
        Learn More About Us
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</Section>
