---
import { site } from '../../data/site';

interface Props {
  heading?: string;
  phone?: string;
  estimateUrl?: string;
}

const {
  heading = 'Ready to get started?',
  phone = site.nap.phone,
  estimateUrl = '/free-estimates/',
} = Astro.props;

const phoneTel = `+1${phone.replace(/\D/g, '')}`;
---

<section class="bg-brand-navy py-10 md:py-12">
  <div class="mx-auto max-w-5xl px-4 text-center">
    <p class="mb-5 text-2xl font-bold text-white md:text-4xl">{heading}</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={estimateUrl} class="rounded-lg bg-brand-gold px-6 py-3 text-base font-semibold text-white transition-colors shadow-sm hover:bg-brand-gold-hover">
        Request Free Estimate
      </a>
      <a href={`tel:${phoneTel}`} class="rounded-lg border border-white/40 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-white hover:text-brand-slate">
        Call {phone}
      </a>
    </div>
  </div>
</section>
