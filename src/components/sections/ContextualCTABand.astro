---
import { site } from '../../data/site';

interface Props {
  heading?: string;
  phone?: string;
  estimateUrl?: string;
}

const {
  heading = 'Ready to get started?',
  phone = site.nap.phone,
  estimateUrl = '/free-estimates/',
} = Astro.props;

const phoneTel = `+1${phone.replace(/\D/g, '')}`;
---

<section class="py-10 bg-brand-slate">
  <div class="max-w-3xl mx-auto px-4 text-center">
    <p class="text-lg font-semibold text-white mb-4">{heading}</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={estimateUrl} class="bg-brand-gold hover:bg-brand-gold-hover text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors shadow-md">
        Request Free Estimate
      </a>
      <a href={`tel:${phoneTel}`} class="border border-white/40 text-white hover:bg-white/10 text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors">
        Call {phone}
      </a>
    </div>
  </div>
</section>
