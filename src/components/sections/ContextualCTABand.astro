---
import { site } from '../../data/site';
import Button from '../ui/Button.astro';

interface Props {
  heading?: string;
}

const { heading = 'Ready to get started?' } = Astro.props;
---
<div class="max-w-2xl mx-auto text-center py-6 md:py-8">
  <p class="text-base font-medium text-text-muted mb-4">{heading}</p>
  <div class="flex flex-col sm:flex-row gap-3 justify-center">
    <Button href="/free-estimates/" variant="primary" size="sm">Request Free Estimate</Button>
    <Button href={`tel:${site.nap.phoneTel}`} variant="secondary" size="sm">Call {site.nap.phone}</Button>
  </div>
</div>
