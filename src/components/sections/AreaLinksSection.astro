---
/**
 * AreaLinksSection — shared component for "Service Areas Served", "Nearby Service Areas",
 * and "Also Serving" pill grids across ServicePillarTemplate, CityLandingTemplate,
 * and ServiceMoneyPageTemplate.
 */
interface Props {
  title?: string;
  subtitle?: string;
  links: { name: string; href: string }[];
}

const { title = "Service Areas", subtitle, links } = Astro.props;
---

<section class="py-12 md:py-16 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-brand-slate mb-2">{title}</h2>
    {subtitle && <p class="text-text-muted text-sm mb-6">{subtitle}</p>}
    {!subtitle && <div class="mb-6" />}
    <div class="flex flex-wrap justify-center gap-3">
      {links.map(link => (
        <a href={link.href} class="inline-flex items-center gap-2 px-4 py-2 bg-surface-subtle hover:bg-surface text-sm font-medium text-brand-slate hover:text-brand-teal rounded-full border border-brand-teal/30 transition-colors">
          <svg class="w-3.5 h-3.5 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          {link.name}
        </a>
      ))}
    </div>
  </div>
</section>
