---
import EstimateForm from '../forms/EstimateForm.astro';
import { site } from '../../data/site';

interface Props {
  heading: string;
  description?: string;
  compact?: boolean;
}

const {
  heading,
  description = 'Share a few project details and we will follow up with a free, no-pressure estimate.',
  compact = false,
} = Astro.props;
---

<div class:list={['mx-auto', compact ? 'max-w-3xl' : 'max-w-4xl']}>
  <div class="mb-6 text-center">
    <h2 class="font-heading text-2xl font-bold text-brand-slate md:text-3xl">{heading}</h2>
    <p class="mx-auto mt-3 max-w-2xl text-text-muted">{description}</p>
    <p class="mt-3 text-sm text-text-muted">
      Prefer to call?
      <a
        href={`tel:${site.nap.phoneTel}`}
        class="font-semibold text-brand-teal transition-colors hover:text-brand-slate"
      >
        {site.nap.phone}
      </a>
    </p>
  </div>

  <div class:list={['rounded-xl bg-white shadow-md', compact ? 'p-5 md:p-6' : 'p-6 md:p-8']}>
    <EstimateForm />
  </div>
</div>
