---
import { getPublishedPillars } from '../../data/services';
import { FORMSPREE_ENDPOINT, IS_FORMSPREE_ENDPOINT_MISSING, THANK_YOU_PATH } from '../../data/forms';
import { site } from '../../data/site';

const publishedServices = getPublishedPillars();
---

<section class="py-16 md:py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">

      <!-- LEFT COLUMN: Context + Trust -->
      <div class="pt-2">
        <p class="text-xs font-semibold uppercase tracking-wider text-brand-teal mb-3">Free Estimate</p>
        <h2 class="text-3xl md:text-4xl font-bold text-brand-slate mb-4 leading-tight">Get a Free Estimate From Wheyland Electric</h2>
        <p class="text-base text-text-muted leading-relaxed mb-8">Tell us about your project and we'll follow up with next steps, scheduling, and a detailed estimate — no obligation, no pressure.</p>

        <div class="space-y-4 mb-8">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-surface-DEFAULT flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-brand-slate" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-text">Licensed, bonded &amp; insured — {site.license}</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-surface-DEFAULT flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-brand-slate" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-text">1-year labor warranty on all work</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-surface-DEFAULT flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-brand-slate" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-text">Response within one business day</span>
          </div>
        </div>

        <div class="flex items-center gap-2 text-sm text-text-muted">
          <span>Prefer to call?</span>
          <a href={`tel:${site.nap.phoneTel}`} class="font-bold text-brand-slate hover:text-brand-teal transition-colors text-base">{site.nap.phone}</a>
        </div>
      </div>

      <!-- RIGHT COLUMN: Form Card -->
      <div>
        <div class="bg-white rounded-2xl shadow-xl border border-brand-teal/20 p-7 md:p-9">
          <h3 class="text-xl font-bold text-brand-slate mb-1">Request a Free Estimate</h3>
          <p class="text-sm text-text-muted mb-6">We'll respond within one business day.</p>

          <form
            id="home-estimate-form"
            method="POST"
            action={FORMSPREE_ENDPOINT}
            class="form-shell form-shell--compact"
            data-endpoint={FORMSPREE_ENDPOINT || ''}
            novalidate
          >
            <input type="hidden" name="_timestamp" id="home-estimate-timestamp" />
            <input type="hidden" name="_next" value={THANK_YOU_PATH} />
            <input type="hidden" name="form_type" value="home-estimate" />
            <input type="hidden" name="phone_digits" value="" />

            <fieldset class="space-y-4" disabled={!import.meta.env.DEV && IS_FORMSPREE_ENDPOINT_MISSING}>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-semibold uppercase tracking-wide text-brand-slate/70 mb-1.5" for="home-estimate-name">Full Name *</label>
                  <input
                    id="home-estimate-name"
                    type="text"
                    name="name"
                    required
                    placeholder="Your full name"
                    class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-teal/40 focus:border-brand-teal transition-colors"
                  />
                </div>
                <div>
                  <label class="block text-xs font-semibold uppercase tracking-wide text-brand-slate/70 mb-1.5" for="home-estimate-phone">Phone *</label>
                  <input
                    id="home-estimate-phone"
                    type="tel"
                    name="phone"
                    required
                    placeholder="(858) 555-1234"
                    class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-teal/40 focus:border-brand-teal transition-colors"
                  />
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-semibold uppercase tracking-wide text-brand-slate/70 mb-1.5" for="home-estimate-email">Email</label>
                  <input
                    id="home-estimate-email"
                    type="email"
                    name="email"
                    placeholder="you@example.com"
                    class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-teal/40 focus:border-brand-teal transition-colors"
                  />
                </div>
                <div>
                  <label class="block text-xs font-semibold uppercase tracking-wide text-brand-slate/70 mb-1.5" for="home-estimate-service">Service Needed *</label>
                  <select
                    id="home-estimate-service"
                    name="service"
                    required
                    class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-teal/40 focus:border-brand-teal transition-colors"
                  >
                    <option value="">Select a service</option>
                    {publishedServices.map((s) => (
                      <option value={s.name}>{s.name}</option>
                    ))}
                  </select>
                </div>
              </div>
              <div>
                <label class="block text-xs font-semibold uppercase tracking-wide text-brand-slate/70 mb-1.5" for="home-estimate-message">Project Details</label>
                <textarea
                  id="home-estimate-message"
                  name="message"
                  rows="3"
                  placeholder="Brief description of your project..."
                  class="w-full px-4 py-3 border border-gray-200 rounded-lg text-sm bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-teal/40 focus:border-brand-teal transition-colors resize-none"
                ></textarea>
              </div>

              <!-- Honeypot -->
              <div class="hidden" aria-hidden="true">
                <label for="home-estimate-website">Leave this field empty</label>
                <input id="home-estimate-website" type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
              </div>

              <p id="home-estimate-feedback" class="form-feedback" role="status" aria-live="polite"></p>

              <div class="space-y-2">
                {!import.meta.env.DEV && IS_FORMSPREE_ENDPOINT_MISSING && (
                  <p class="text-sm text-text-muted">Online submission is temporarily unavailable. Please call <a href="tel:8586635564" class="font-medium text-brand-teal hover:text-brand-slate">(858) 663-5564</a>.</p>
                )}

                <button
                  type="submit"
                  class="w-full bg-brand-gold hover:bg-brand-gold-hover text-white font-bold py-3.5 rounded-lg transition-colors shadow-lg text-sm tracking-wide disabled:cursor-not-allowed disabled:bg-surface-warm disabled:text-text-muted"
                  data-loading-label="Sending Request..."
                  disabled={!import.meta.env.DEV && IS_FORMSPREE_ENDPOINT_MISSING}
                >
                  Request Free Estimate
                </button>
              </div>
            </fieldset>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { initLeadForm } from '../../lib/forms/client';
  import { THANK_YOU_PATH } from '../../data/forms';

  initLeadForm({
    formId: 'home-estimate-form',
    feedbackId: 'home-estimate-feedback',
    endpoint: (document.getElementById('home-estimate-form') as HTMLFormElement | null)?.dataset.endpoint || '',
    thankYouPath: THANK_YOU_PATH,
  });
</script>
