---
import EstimateForm from '../forms/EstimateForm.astro';
import { site } from '../../data/site';

const trustPoints = [
  `Licensed, bonded & insured — ${site.license}`,
  '1-year labor warranty on all work',
  'Response within one business day',
];
---

<section class="py-16 md:py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-start">

      <!-- Left: Context (2 cols) -->
      <div class="lg:col-span-2">
        <p class="text-xs font-semibold uppercase tracking-wider text-brand-teal mb-2">Free Estimate</p>
        <h2 class="text-2xl md:text-3xl font-bold text-brand-slate mb-3">Get a Free Estimate From Wheyland Electric</h2>
        <p class="text-text-muted leading-relaxed mb-6">Tell us about your project and we'll follow up with next steps, scheduling, and a detailed estimate — no obligation, no pressure.</p>

        <div class="space-y-3 mb-6">
          {trustPoints.map(point => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-sm text-text-muted">{point}</span>
            </div>
          ))}
        </div>

        <p class="text-sm text-text-muted">
          Prefer to call? <a href={`tel:${site.nap.phoneTel}`} class="font-semibold text-brand-slate hover:text-brand-teal transition-colors">{site.nap.phone}</a>
        </p>
      </div>

      <!-- Right: Form (3 cols) -->
      <div class="lg:col-span-3">
        <div class="bg-white rounded-xl shadow-lg border border-brand-teal/20 p-6 md:p-8">
          <EstimateForm />
        </div>
      </div>

    </div>
  </div>
</section>
