---
import EstimateForm from '../forms/EstimateForm.astro';
import { site } from '../../data/site';

const trustBullets = [
  'Free, no-obligation estimate on every project.',
  'Licensed, bonded & insured — CA License #940291.',
  '1-year labor warranty on all workmanship.',
  'Clear scope and pricing before work begins.',
];
---
<section class="bg-white py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 items-center lg:grid-cols-2">
      {/* Left column — trust content */}
      <div>
        <span class="text-xs font-semibold uppercase tracking-wider text-brand-teal">Free Estimate</span>
        <h2 class="mt-2 font-heading text-2xl font-bold text-brand-slate md:text-3xl">
          Get a Free Estimate From Wheyland Electric
        </h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Tell us about your project and we&apos;ll follow up with scope options, scheduling availability, and a clear cost estimate — no pressure, no obligation.
        </p>
        <ul class="mt-6 space-y-3">
          {trustBullets.map((bullet) => (
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-text-muted">{bullet}</span>
            </li>
          ))}
        </ul>
        <p class="mt-6 text-sm text-text-muted">
          Or call us directly:
          <a href={`tel:${site.nap.phoneTel}`} class="font-semibold text-brand-teal hover:text-brand-slate transition-colors ml-1">
            {site.nap.phone}
          </a>
        </p>
      </div>

      {/* Right column — form card */}
      <div class="rounded-xl border border-brand-teal/20 bg-white p-6 shadow-lg md:p-8">
        <EstimateForm />
      </div>
    </div>
  </div>
</section>
