---
import { getPublishedPillars } from '../../data/services';
import { FORMSPREE_ENDPOINT } from '../../data/forms';
import { site } from '../../data/site';

const publishedServices = getPublishedPillars();
---

<section class="py-16 md:py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">

      <!-- LEFT COLUMN: Context + Trust -->
      <div class="pt-2">
        <p class="text-xs font-semibold uppercase tracking-wider text-brand-teal mb-2">Free Estimate</p>
        <h2 class="text-2xl md:text-3xl font-bold text-brand-slate mb-4">Get a Free Estimate From Wheyland Electric</h2>
        <p class="text-base text-text-muted leading-relaxed mb-8">Tell us about your project and we'll follow up with next steps, scheduling, and a detailed estimate — no obligation, no pressure.</p>

        <div class="space-y-4 mb-8">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm text-text-muted">Licensed, bonded &amp; insured — {site.license}</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm text-text-muted">1-year labor warranty on all work</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm text-text-muted">Response within one business day</span>
          </div>
        </div>

        <p class="text-sm text-text-muted">
          Prefer to call? <a href={`tel:${site.nap.phoneTel}`} class="font-semibold text-brand-slate hover:text-brand-teal transition-colors">{site.nap.phone}</a>
        </p>
      </div>

      <!-- RIGHT COLUMN: Form Card -->
      <div>
        <div class="bg-white rounded-xl shadow-lg border border-brand-teal/20 p-6 md:p-8">
          <h3 class="text-xl font-bold text-brand-slate mb-1">Request a Free Estimate</h3>
          <p class="text-sm text-text-muted mb-6">We'll respond within one business day.</p>

          <form method="POST" action={FORMSPREE_ENDPOINT}>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-brand-slate mb-1.5">Full Name *</label>
                <input type="text" name="name" required placeholder="Your full name"
                  class="w-full px-3.5 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/50 focus:border-brand-teal" />
              </div>
              <div>
                <label class="block text-sm font-medium text-brand-slate mb-1.5">Phone *</label>
                <input type="tel" name="phone" required placeholder="(858) 555-1234"
                  class="w-full px-3.5 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/50 focus:border-brand-teal" />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-sm font-medium text-brand-slate mb-1.5">Email</label>
                <input type="email" name="email" placeholder="you@example.com"
                  class="w-full px-3.5 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/50 focus:border-brand-teal" />
              </div>
              <div>
                <label class="block text-sm font-medium text-brand-slate mb-1.5">Service Needed *</label>
                <select name="service" required
                  class="w-full px-3.5 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/50 focus:border-brand-teal bg-white">
                  <option value="">Select a service</option>
                  {publishedServices.map(s => (
                    <option value={s.name}>{s.name}</option>
                  ))}
                </select>
              </div>
            </div>
            <div class="mb-4">
              <label class="block text-sm font-medium text-brand-slate mb-1.5">Project Details</label>
              <textarea name="message" rows="3" placeholder="Brief description of your project..."
                class="w-full px-3.5 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/50 focus:border-brand-teal resize-none"></textarea>
            </div>

            <!-- Honeypot -->
            <div class="hidden" aria-hidden="true">
              <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
            </div>

            <button type="submit"
              class="w-full bg-brand-gold hover:bg-brand-gold-hover text-white font-semibold py-3 rounded-lg transition-colors shadow-md text-sm">
              Request Free Estimate
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>
