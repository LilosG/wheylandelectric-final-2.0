---
import type { City } from '../../types';
import CityCard from './CityCard.astro';
import Section from '../ui/Section.astro';

interface Props {
  cities: City[];
  title?: string;
  subtitle?: string;
}

const {
  cities,
  title = 'Areas We Serve',
  subtitle = 'Wheyland Electric proudly serves communities across North County San Diego with licensed, bonded, and insured electrical services.',
} = Astro.props;
---
<Section bg="indigo" size="loose">
  <h2 class="mb-4 text-center text-2xl font-heading font-bold text-white md:text-3xl lg:text-4xl">
    {title}
  </h2>
  <p class="mx-auto mb-12 max-w-2xl text-center text-white/80">
    {subtitle}
  </p>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {cities.map((city) => (
      <CityCard
        name={city.name}
        slug={city.slug}
        description={`Residential, commercial, HOA, and EV charging services in ${city.name}.`}
      />
    ))}
  </div>
  <div class="mt-10 text-center">
    <a
      href="/service-areas/"
      class="inline-flex items-center gap-1 text-sm font-semibold text-brand-teal transition-colors duration-200 hover:text-white"
    >
      View All Service Areas &rarr;
    </a>
  </div>
</Section>
