---
/**
 * ServiceIntroSection — shared between ServiceMoneyPageTemplate and ServicePillarTemplate.
 * Fixed visual structure: H2 + intro paragraph + 2-col checkmark highlights grid (capped at 6).
 */
interface Props {
  title: string;
  subtitle?: string;
  highlights: string[];
}

const { title, subtitle, highlights } = Astro.props;
const displayHighlights = highlights.slice(0, 6);
---

<section class="py-16 md:py-20 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-bold text-brand-slate mb-4">{title}</h2>
    {subtitle && (
      <p class="text-base text-text-muted leading-relaxed mb-8 max-w-3xl">{subtitle}</p>
    )}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {displayHighlights.map(item => (
        <div class="flex items-start gap-3 p-4 bg-surface-subtle rounded-lg">
          <svg class="w-5 h-5 text-brand-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-sm text-text-muted">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>
