---
/**
 * RelatedServicesSection — shared between ServiceMoneyPageTemplate and ServicePillarTemplate.
 * 3-column grid (or centered 2). Cards are capped at 3. line-clamp-3 on descriptions.
 */
interface Props {
  title?: string;
  services: { name: string; description: string; href: string }[];
}

const { title = "Related Services", services } = Astro.props;
const displayServices = services.slice(0, 3);
---

<section class="py-16 md:py-20 bg-surface-subtle">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-bold text-brand-slate text-center mb-8">{title}</h2>
    <div
      class:list={[
        "gap-6",
        displayServices.length <= 2 ? "mx-auto grid max-w-3xl grid-cols-1 md:grid-cols-2" : "grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3",
      ]}
    >
      {displayServices.map(s => (
        <a href={s.href}
          class="flex h-full flex-col rounded-xl bg-white p-6 shadow-md transition-all hover:-translate-y-0.5 hover:shadow-lg">
          <h3 class="text-base font-bold text-brand-slate mb-2">{s.name}</h3>
          <p class="text-sm text-text-muted leading-relaxed flex-1 line-clamp-3">{s.description}</p>
          <span class="text-brand-teal text-sm font-semibold mt-4 inline-flex items-center gap-1">
            View {s.name} service details <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
