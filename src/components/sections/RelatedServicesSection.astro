---
/**
 * RelatedServicesSection — shared between ServiceMoneyPageTemplate and ServicePillarTemplate.
 * Enhanced cards with hover states, "Learn more" links, and centering logic for <3 items.
 * Each service item may optionally supply its own href; otherwise falls back to /services/{slug}/.
 */
interface Props {
  heading?: string;
  services: { name: string; slug: string; shortDesc?: string; href?: string }[];
}

const { heading = 'You May Also Need', services } = Astro.props;
const cappedServices = services.slice(0, 6);
const useGrid = cappedServices.length >= 3;
---
<div>
  <h2 class="mb-8 text-center font-heading text-2xl font-bold text-brand-slate md:text-3xl">{heading}</h2>
  <div class={useGrid
    ? 'grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3'
    : 'flex flex-wrap justify-center gap-6'
  }>
    {cappedServices.map((service) => (
      <a
        href={service.href ?? `/services/${service.slug}/`}
        class="group flex flex-col rounded-xl border border-transparent bg-white p-6 shadow-md transition-all hover:-translate-y-1 hover:border-brand-teal/30 hover:shadow-lg"
      >
        <h3 class="mb-2 font-semibold text-brand-slate transition-colors group-hover:text-brand-teal">
          {service.name}
        </h3>
        {service.shortDesc && (
          <p class="flex-1 text-sm leading-relaxed text-text-muted">{service.shortDesc}</p>
        )}
        <span class="mt-4 text-sm font-medium text-brand-teal">Learn more →</span>
      </a>
    ))}
  </div>
</div>
