---
interface Props {
  name: string;
  description: string;
  href: string;
  icon?: string;
}

const { name, description, href } = Astro.props;
---
<div class="group bg-white rounded-xl shadow-md hover:shadow-lg hover:-translate-y-1 transition-all duration-300 p-8 h-full flex flex-col border-l-[3px] border-transparent hover:border-brand-teal">
  <div class="w-14 h-14 rounded-full bg-surface flex items-center justify-center mb-4">
    <svg class="w-6 h-6 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
    </svg>
  </div>
  <h3 class="text-lg font-heading font-bold text-brand-slate mb-2">{name}</h3>
  <p class="text-sm text-text-muted leading-relaxed flex-1">{description}</p>
  <a href={href} class="text-brand-teal hover:text-brand-teal-light text-sm font-semibold mt-4 inline-flex items-center gap-1">
    Learn more
    <span aria-hidden="true">&rarr;</span>
  </a>
</div>
