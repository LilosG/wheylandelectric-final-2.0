---
import Card from '../ui/Card.astro';

interface Props {
  name: string;
  description: string;
  href: string;
  icon?: string;
}

const { name, description, href } = Astro.props;
---
<Card
  href={href}
  hoverable={true}
  class="group h-full flex flex-col border-l-[3px] border-transparent transition-all duration-300 hover:-translate-y-1 hover:border-brand-teal"
>
  <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-surface">
    <svg class="h-6 w-6 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
    </svg>
  </div>
  <h3 class="mb-2 text-lg font-heading font-bold text-brand-slate">{name}</h3>
  <p class="flex-1 text-sm leading-relaxed text-text-muted">{description}</p>
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-teal group-hover:text-brand-teal-light">
    Explore {name} service details
    <span aria-hidden="true">&rarr;</span>
  </span>
</Card>
