---
import { site } from '../../data/site';

interface Props {
  heading?: string;
}

const { heading = 'Find Us' } = Astro.props;
---
<div>
  {heading && (
    <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-slate mb-6">{heading}</h2>
  )}
  <div class="rounded-xl overflow-hidden shadow-md">
    <iframe
      src={site.gbp.embedSrc}
      width="100%"
      height="450"
      class="border-0"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Wheyland Electric location on Google Maps"
    ></iframe>
  </div>
</div>
