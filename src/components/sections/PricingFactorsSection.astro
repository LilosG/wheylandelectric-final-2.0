---
/**
 * PricingFactorsSection — shared between ServiceMoneyPageTemplate and ServicePillarTemplate.
 * Fixed visual structure: H2 + 2-col grid of compact factor cards (capped at 6).
 */
interface Props {
  title?: string;
  city?: string;
  factors: string[];
}

const { title, city, factors } = Astro.props;
const displayTitle = title || (city ? `What Affects the Cost in ${city}` : "Pricing Factors");
const displayFactors = factors.slice(0, 6);
---

<section class="py-16 md:py-20 bg-surface-subtle">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-bold text-brand-slate text-center mb-8">{displayTitle}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {displayFactors.map(factor => (
        <div class="flex items-start gap-3 p-4 bg-white rounded-lg shadow-sm">
          <svg class="w-5 h-5 text-brand-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          <span class="text-sm text-text-muted leading-relaxed">{factor}</span>
        </div>
      ))}
    </div>
  </div>
</section>
