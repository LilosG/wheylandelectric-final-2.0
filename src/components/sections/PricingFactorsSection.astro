---
/**
 * PricingFactorsSection — shared between ServiceMoneyPageTemplate and ServicePillarTemplate.
 * Fixed visual structure: H2 + 2-col grid of factor items (capped at 8).
 */
interface Props {
  heading: string;
  factors: string[];
}

const { heading, factors } = Astro.props;
const cappedFactors = factors.slice(0, 8);
---
<div>
  <h2 class="mb-6 font-heading text-2xl font-bold text-brand-slate md:text-3xl">{heading}</h2>
  <ul class="grid grid-cols-1 gap-4 md:grid-cols-2">
    {cappedFactors.map((factor) => (
      <li class="flex items-start gap-3 rounded-lg bg-white p-4 shadow-sm">
        <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="text-sm text-text-muted">{factor}</span>
      </li>
    ))}
  </ul>
</div>
