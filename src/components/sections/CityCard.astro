---
interface Props {
  name: string;
  slug: string;
  description: string;
}

const { name, slug, description } = Astro.props;
---
<a
  href={`/${slug}/`}
  class="block bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-6 hover:border-white/40 hover:-translate-y-1 transition-all duration-300"
>
  <svg class="w-6 h-6 text-brand-teal mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
  </svg>
  <h3 class="text-xl font-heading font-bold text-white mb-2">{name}</h3>
  <p class="text-white/75 text-sm leading-relaxed mb-4">{description}</p>
  <span class="text-brand-teal hover:text-white text-sm font-semibold inline-flex items-center gap-1">
    Explore {name} &rarr;
  </span>
</a>
