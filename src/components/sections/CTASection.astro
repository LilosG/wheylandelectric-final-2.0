---
import { site } from '../../data/site';
import Button from '../ui/Button.astro';

interface Props {
  title?: string;
  subtitle?: string;
  cityName?: string;
  tone?: 'dark' | 'subtle';
}

const {
  title = 'Need an estimate for your electrical project?',
  subtitle = 'Big enough to handle complex projects. Local enough to care about every detail.',
  cityName,
  tone = 'dark',
} = Astro.props;

const areaText = cityName ? `Serving ${cityName} and surrounding areas` : '';
---
<section class:list={[
  "relative overflow-hidden py-16 md:py-20",
  tone === "dark" ? "bg-brand-navy" : "bg-surface-subtle",
]}>
  {/* Subtle radial gradient center */}
  {tone === "dark" && (
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(58,153,148,0.08) 0%, transparent 70%)"></div>
  )}

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class:list={[
      "text-3xl md:text-4xl lg:text-5xl font-heading font-bold leading-tight",
      tone === "dark" ? "text-white" : "text-brand-slate",
    ]}>
      {title}
    </h2>
    <p class:list={[
      "text-lg mt-4 mb-10 max-w-2xl mx-auto",
      tone === "dark" ? "text-white/80" : "text-text-muted",
    ]}>
      {subtitle}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/free-estimates/" variant="primary" size="lg">
        Free Estimate
      </Button>
      <Button href={`tel:${site.nap.phoneTel}`} variant={tone === "dark" ? "outline-white" : "outline-teal"} size="lg">
        Call {site.nap.phone}
      </Button>
    </div>
    {areaText && (
      <p class:list={["text-sm mt-6", tone === "dark" ? "text-white/50" : "text-text-muted"]}>{areaText}</p>
    )}
  </div>
</section>
