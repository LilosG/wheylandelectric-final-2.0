---
import { site } from '../../data/site';
import Button from '../ui/Button.astro';
import Section from '../ui/Section.astro';

interface Props {
  title?: string;
  subtitle?: string;
  cityName?: string;
}

const {
  title = 'Need an estimate for your electrical project?',
  subtitle = 'Big enough to handle complex projects. Local enough to care about every detail.',
  cityName,
} = Astro.props;

const areaText = cityName ? `Serving ${cityName} and surrounding areas` : '';
---
<Section bg="indigo" size="loose" class="relative overflow-hidden">
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(58,153,148,0.08) 0%, transparent 70%)"></div>

  <div class="relative mx-auto max-w-4xl text-center">
    <h2 class="text-3xl font-heading font-bold leading-tight text-white md:text-4xl lg:text-5xl">
      {title}
    </h2>
    <p class="mx-auto mb-10 mt-4 max-w-2xl text-lg text-white/80">
      {subtitle}
    </p>
    <div class="flex flex-col justify-center gap-4 sm:flex-row">
      <Button href="/free-estimates/" variant="primary" size="lg">
        Free Estimate
      </Button>
      <Button href={`tel:${site.nap.phoneTel}`} variant="outline-white" size="lg">
        Call {site.nap.phone}
      </Button>
    </div>
    {areaText && <p class="mt-6 text-sm text-white/50">{areaText}</p>}
  </div>
</Section>
