---
import { site } from '../../data/site';
import { getPublishedCities } from '../../data/cities';
import Button from '../ui/Button.astro';

const cities = getPublishedCities();
const primaryCity = cities.find((c) => c.slug === 'carlsbad');
const otherCities = cities.filter((c) => c.slug !== 'carlsbad');
---
<section class="bg-surface-subtle py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-start">
      {/* Left — content */}
      <div>
        <span class="text-brand-gold text-xs uppercase tracking-wider font-semibold mb-3 block">
          Local Service
        </span>
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-heading font-bold text-brand-slate mb-4">
          Proudly Serving North County San Diego
        </h2>
        <p class="text-text-muted leading-relaxed mb-8">
          Based in Carlsbad since {site.established}, Wheyland Electric provides licensed electrical services to homes and businesses across San Diego County. Our team knows these communities — because we live here too.
        </p>

        {/* Primary service area */}
        {primaryCity && (
          <div class="mb-6">
            <span class="text-brand-teal text-xs uppercase tracking-wider font-semibold mb-2 block">
              Primary Service Area
            </span>
            <a href={`/${primaryCity.slug}/`} class="flex items-center gap-2 text-brand-slate font-semibold hover:text-brand-teal transition-colors">
              <svg class="w-4 h-4 text-brand-teal" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {primaryCity.name}, CA
            </a>
          </div>
        )}

        {/* Extended service areas */}
        <div class="mb-8">
          <span class="text-brand-teal text-xs uppercase tracking-wider font-semibold mb-3 block">
            Extended Service Areas
          </span>
          <div class="grid grid-cols-2 gap-2">
            {otherCities.map((city) => (
              <a
                href={`/${city.slug}/`}
                class="flex items-center gap-2 text-sm text-text-muted hover:text-brand-teal transition-colors py-1"
              >
                <svg class="w-3.5 h-3.5 text-brand-teal/70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {city.name}
              </a>
            ))}
          </div>
        </div>

        <div class="flex flex-wrap gap-3">
          <Button href="/service-areas/" variant="primary">View All Service Areas</Button>
          <Button href={`tel:${site.nap.phoneTel}`} variant="outline-teal">Call for Service</Button>
        </div>
      </div>

      {/* Right — map embed */}
      <div class="relative">
        <div class="rounded-2xl overflow-hidden shadow-xl">
          <iframe
            src={site.gbp.embedSrc}
            width="100%"
            height="450"
            class="border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Wheyland Electric location on Google Maps"
          ></iframe>
        </div>

        {/* Overlay card */}
        <div class="absolute bottom-4 right-4 bg-white rounded-xl shadow-lg p-4 max-w-[220px] hidden md:block">
          <p class="font-heading font-bold text-brand-slate text-sm mb-1">{site.nap.name}</p>
          <div class="flex gap-0.5 mb-1">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-3 h-3 text-brand-gold" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-xs text-text-muted mb-2">{site.nap.address.street}, {site.nap.address.city}</p>
          <a
            href={site.gbp.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-brand-teal hover:text-brand-teal-light font-semibold transition-colors"
          >
            Get Directions &rarr;
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
