---
import { site } from '../../data/site';
import { getPublishedCities } from '../../data/cities';
import Button from '../ui/Button.astro';
import Section from '../ui/Section.astro';

const cities = getPublishedCities();
const primaryCity = cities.find((c) => c.slug === 'carlsbad');
const otherCities = cities.filter((c) => c.slug !== 'carlsbad');
---
<Section bg="subtle" size="loose">
  <div class="grid items-start gap-8 lg:grid-cols-2 lg:gap-12">
    <div>
      <span class="mb-3 block text-xs font-semibold uppercase tracking-wider text-brand-gold">
        Local Service
      </span>
      <h2 class="mb-4 text-2xl font-heading font-bold text-brand-slate md:text-3xl lg:text-4xl">
        Proudly Serving North County San Diego
      </h2>
      <p class="mb-8 leading-relaxed text-text-muted">
        Based in Carlsbad since {site.established}, Wheyland Electric provides licensed electrical
        services to homes and businesses across San Diego County. Our team knows these communities
        — because we live here too.
      </p>

      {primaryCity && (
        <div class="mb-6">
          <span class="mb-2 block text-xs font-semibold uppercase tracking-wider text-brand-teal">
            Primary Service Area
          </span>
          <a
            href={`/${primaryCity.slug}/`}
            class="flex items-center gap-2 font-semibold text-brand-slate transition-colors hover:text-brand-teal"
          >
            <svg class="h-4 w-4 text-brand-teal" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            {primaryCity.name}, CA
          </a>
        </div>
      )}

      <div class="mb-8">
        <span class="mb-3 block text-xs font-semibold uppercase tracking-wider text-brand-teal">
          Extended Service Areas
        </span>
        <div class="grid grid-cols-2 gap-2">
          {otherCities.map((city) => (
            <a
              href={`/${city.slug}/`}
              class="flex items-center gap-2 py-1 text-sm text-text-muted transition-colors hover:text-brand-teal"
            >
              <svg class="h-3.5 w-3.5 shrink-0 text-brand-teal/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {city.name}
            </a>
          ))}
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <Button href="/service-areas/" variant="primary">View All Service Areas</Button>
        <Button href={`tel:${site.nap.phoneTel}`} variant="outline-teal">Call for Service</Button>
      </div>
    </div>

    <div class="relative">
      <div class="overflow-hidden rounded-2xl shadow-xl">
        <iframe
          src={site.gbp.embedSrc}
          width="100%"
          height="450"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Wheyland Electric location on Google Maps"
        ></iframe>
      </div>

      <div class="absolute bottom-4 right-4 hidden max-w-[220px] rounded-xl bg-white p-4 shadow-lg md:block">
        <p class="mb-1 text-sm font-heading font-bold text-brand-slate">{site.nap.name}</p>
        <div class="mb-1 flex gap-0.5">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="h-3 w-3 text-brand-gold" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="mb-2 text-xs text-text-muted">{site.nap.address.street}, {site.nap.address.city}</p>
        <a
          href={site.gbp.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-semibold text-brand-teal transition-colors hover:text-brand-teal-light"
        >
          Get Directions &rarr;
        </a>
      </div>
    </div>
  </div>
</Section>
