---
import { site } from '../../data/site';
import Button from '../ui/Button.astro';

/**
 * Hero usage guide
 * - `variant="landing"`: Primary homepage-style hero (full-height presentation).
 * - `variant="standard"`: Mid-emphasis page intros when you want substantial, but not full-screen, height.
 * - `variant="compact"`: Inner-page hero for utility pages and templates.
 *
 * Pair compact heroes with `<Section spacing="hero-tight">` on the next block to maintain
 * consistent vertical rhythm without page-level one-off `pt-*` utilities.
 */

interface Props {
  eyebrow?: string;
  title?: string;
  titleAccent?: string;
  subtitle?: string;
  showCTAs?: boolean;
  showTrustCard?: boolean;
  showStatChips?: boolean;
  variant?: 'landing' | 'standard' | 'compact';
  backgroundImage?: string;
  imagePosition?: 'center' | 'top' | 'bottom';
  backgroundImageAlt?: string;
}

const {
  eyebrow = 'Satisfaction Guaranteed',
  title = 'An Innovative Electrician',
  titleAccent = '',
  subtitle = 'We offer electrical installation, repair, and maintenance to residential, commercial, and industrial customers across San Diego County.',
  showCTAs = true,
  showTrustCard = true,
  showStatChips = true,
  variant = 'landing',
  backgroundImage,
  imagePosition = 'center',
  backgroundImageAlt,
} = Astro.props;

const resolvedVariant = variant ?? 'landing';

const sectionSpacingMap: Record<typeof resolvedVariant, string> = {
  landing: 'min-h-[85vh] flex items-center',
  standard: 'py-14 sm:py-16 md:py-20',
  compact: 'py-10 sm:py-14 md:py-16',
};

const contentSpacingMap: Record<typeof resolvedVariant, string> = {
  landing: 'py-16 md:py-24',
  standard: 'py-12 md:py-16',
  compact: 'py-8 sm:py-10 md:py-12',
};

const headingSizeMap: Record<typeof resolvedVariant, string> = {
  landing: 'text-4xl sm:text-5xl lg:text-6xl',
  standard: 'text-4xl sm:text-5xl md:text-6xl',
  compact: 'text-3xl sm:text-4xl md:text-5xl',
};

const subtitleSizeMap: Record<typeof resolvedVariant, string> = {
  landing: 'text-lg mt-6',
  standard: 'text-lg mt-5',
  compact: 'text-base sm:text-lg mt-4',
};

const ctaSpacingMap: Record<typeof resolvedVariant, string> = {
  landing: 'mt-8',
  standard: 'mt-7',
  compact: 'mt-6',
};

const finalBackgroundImage = backgroundImage ?? '/images/hero/wheyland-electric-edison-bulb-lighting-carlsbad.webp';
const finalBackgroundImageAlt = backgroundImageAlt ?? 'Professional electrician services background image';

const trustItems = [
  `CA License #940291`,
  'Licensed, Bonded & Insured',
  `Established ${site.established}`,
  '1-Year Labor Warranty',
];
---
<section class:list={[
  'relative overflow-hidden bg-brand-slate',
  sectionSpacingMap[resolvedVariant],
]}>
  {/* Background with photo + gradient overlay */}
  <div class="absolute inset-0">
    <img
      src={finalBackgroundImage}
      alt={finalBackgroundImageAlt}
      width="1920"
      height="1080"
      class:list={[
        'absolute inset-0 w-full h-full object-cover',
        imagePosition === 'top' ? 'object-top' : imagePosition === 'bottom' ? 'object-bottom' : 'object-center'
      ]}
      loading="eager"
      fetchpriority="high"
    />
    {/* Primary dark overlay for contrast */}
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(31,78,99,0.70) 0%, rgba(31,78,99,0.60) 50%, rgba(47,127,122,0.08) 100%)"></div>
  </div>

  {/* Decorative light effects */}
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-teal/[0.06] rounded-full blur-3xl -translate-y-1/4 translate-x-1/4"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-brand-teal-light/[0.04] rounded-full blur-3xl translate-y-1/4 -translate-x-1/4"></div>

  <div class:list={[
    'relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full',
    contentSpacingMap[resolvedVariant],
  ]}>
    <div class:list={[
      showTrustCard && resolvedVariant !== 'compact' ? 'grid lg:grid-cols-5 gap-8 lg:gap-12 items-center' : '',
    ]}>
      {/* Left content */}
      <div class:list={[
        showTrustCard && resolvedVariant !== 'compact' ? 'lg:col-span-3' : 'w-full max-w-3xl mx-auto text-center',
      ]}>
        {eyebrow && (
          <span class="inline-flex items-center bg-brand-teal text-white text-xs font-semibold px-4 py-2 rounded-full mb-6 tracking-wide uppercase">
            <svg class="w-3.5 h-3.5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            {eyebrow}
          </span>
        )}

        <h1 class:list={[
          'font-heading font-bold text-white leading-tight',
          headingSizeMap[resolvedVariant],
        ]}>
          {title}
          {titleAccent && (
            <>
              <br />
              <span class="text-brand-gold">{titleAccent}</span>
            </>
          )}
        </h1>

        {subtitle && (
          <p class:list={[
            'text-white leading-relaxed',
            showTrustCard && resolvedVariant !== 'compact' ? 'max-w-2xl text-left' : 'max-w-xl mx-auto text-center',
            subtitleSizeMap[resolvedVariant],
          ]}>
            {subtitle}
          </p>
        )}

        {showStatChips && (
          <div class:list={[
            'flex flex-wrap gap-3 mt-6',
            showTrustCard && resolvedVariant !== 'compact' ? 'justify-start' : 'justify-center',
          ]}>
            {[
              { icon: 'calendar', label: '17+ Years' },
              { icon: 'shield', label: 'Licensed & Insured' },
              { icon: 'check', label: '1-Year Warranty' },
            ].map((chip) => (
              <span class="inline-flex items-center gap-2 border border-white/30 text-white text-sm px-4 py-2 rounded-full bg-white/[0.08] backdrop-blur-sm">
                <svg class="w-4 h-4 text-brand-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  {chip.icon === 'calendar' && <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />}
                  {chip.icon === 'shield' && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />}
                  {chip.icon === 'check' && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />}
                </svg>
                {chip.label}
              </span>
            ))}
          </div>
        )}

        {showCTAs && (
          <div class:list={[
            'flex flex-wrap gap-4',
            showTrustCard && resolvedVariant !== 'compact' ? 'justify-start' : 'justify-center',
            ctaSpacingMap[resolvedVariant],
          ]}>
            <Button href="/free-estimates/" variant="primary" size="lg">
              Get Free Estimate
            </Button>
            <Button href={`tel:${site.nap.phoneTel}`} variant="outline-white" size="lg">
              Call {site.nap.phone}
            </Button>
          </div>
        )}
      </div>

      {/* Right trust card — desktop only */}
      {showTrustCard && resolvedVariant !== 'compact' && (
        <div class="hidden lg:block lg:col-span-2">
          <div class="bg-white/[0.08] backdrop-blur-sm border border-white/[0.12] rounded-2xl p-8 shadow-2xl">
            <h2 class="text-lg font-heading font-bold text-white mb-6">Why Choose Wheyland Electric?</h2>
            <ul class="space-y-4">
              {trustItems.map((item) => (
                <li class="flex items-center gap-3">
                  <span class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-teal/20 flex items-center justify-center">
                    <svg class="w-4 h-4 text-brand-teal" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-white text-sm font-medium">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </div>
  </div>
</section>
