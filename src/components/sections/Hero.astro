---
import { site } from '../../data/site';
import Button from '../ui/Button.astro';

interface Props {
  eyebrow?: string;
  title?: string;
  titleAccent?: string;
  subtitle?: string;
  showCTAs?: boolean;
  showTrustCard?: boolean;
  showStatChips?: boolean;
  compact?: boolean;
}

const {
  eyebrow = 'Satisfaction Guaranteed',
  title = 'An Innovative Electrician',
  titleAccent = 'You Can Trust.',
  subtitle = 'We offer electrical installation, repair, and maintenance to residential, commercial, and industrial customers across San Diego County.',
  showCTAs = true,
  showTrustCard = true,
  showStatChips = true,
  compact = false,
} = Astro.props;

const trustItems = [
  `CA License #940291`,
  'Licensed, Bonded & Insured',
  `Established ${site.established}`,
  '1-Year Labor Warranty',
];
---
<section class:list={[
  'relative overflow-hidden bg-brand-indigo',
  compact ? 'py-16 md:py-20' : 'min-h-[85vh] flex items-center',
]}>
  {/* Background with gradient overlay */}
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-indigo via-brand-indigo/95 to-brand-indigo/80"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(27,73,101,0.97) 0%, rgba(27,73,101,0.85) 40%, rgba(95,168,211,0.15) 100%)"></div>
  </div>

  {/* Decorative light effects */}
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-moonstone/[0.07] rounded-full blur-3xl -translate-y-1/4 translate-x-1/4"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-brand-picton/[0.05] rounded-full blur-3xl translate-y-1/4 -translate-x-1/4"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-radial from-white/[0.03] to-transparent rounded-full"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20 w-full">
    <div class:list={[
      showTrustCard && !compact ? 'grid lg:grid-cols-5 gap-8 lg:gap-12 items-center' : '',
    ]}>
      {/* Left content */}
      <div class:list={[
        showTrustCard && !compact ? 'lg:col-span-3' : 'max-w-3xl mx-auto text-center',
      ]}>
        {eyebrow && (
          <span class="inline-flex items-center bg-brand-moonstone/90 text-white text-xs font-semibold px-4 py-1.5 rounded-full mb-6 tracking-wide uppercase">
            <svg class="w-3.5 h-3.5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            {eyebrow}
          </span>
        )}

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white leading-tight">
          {title}
          {titleAccent && (
            <>
              <br />
              <span class="text-brand-cta">{titleAccent}</span>
            </>
          )}
        </h1>

        {subtitle && (
          <p class="text-white/85 text-lg max-w-xl mt-5 leading-relaxed">
            {subtitle}
          </p>
        )}

        {showStatChips && (
          <div class="flex flex-wrap gap-3 mt-7">
            {[
              { icon: 'calendar', label: '17+ Years' },
              { icon: 'shield', label: 'Licensed & Insured' },
              { icon: 'check', label: '1-Year Warranty' },
            ].map((chip) => (
              <span class="inline-flex items-center gap-2 border border-white/25 text-white/90 text-sm px-4 py-2 rounded-full bg-white/[0.05]">
                <svg class="w-4 h-4 text-brand-moonstone" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  {chip.icon === 'calendar' && <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />}
                  {chip.icon === 'shield' && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />}
                  {chip.icon === 'check' && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />}
                </svg>
                {chip.label}
              </span>
            ))}
          </div>
        )}

        {showCTAs && (
          <div class="flex flex-wrap gap-4 mt-8">
            <Button href="/free-estimates/" variant="primary" size="lg">
              Get Free Estimate
            </Button>
            <Button href={`tel:${site.nap.phoneTel}`} variant="outline-white" size="lg">
              Call {site.nap.phone}
            </Button>
          </div>
        )}
      </div>

      {/* Right trust card — desktop only */}
      {showTrustCard && !compact && (
        <div class="hidden lg:block lg:col-span-2">
          <div class="bg-white/[0.08] backdrop-blur-sm border border-white/[0.12] rounded-2xl p-8 shadow-2xl">
            <h2 class="text-lg font-heading font-bold text-white mb-6">Why Choose Wheyland Electric?</h2>
            <ul class="space-y-4">
              {trustItems.map((item) => (
                <li class="flex items-center gap-3">
                  <span class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-moonstone/20 flex items-center justify-center">
                    <svg class="w-4 h-4 text-brand-moonstone" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-white/90 text-sm font-medium">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </div>
  </div>
</section>
