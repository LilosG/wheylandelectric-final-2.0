---
import { buildNavigation, ctaNav } from '../../data/navigation';
import { site } from '../../data/site';
import Button from '../ui/Button.astro';

const nav = buildNavigation();
---
<header class="bg-white sticky top-0 z-50 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <img
          src="/images/logo/wheyland-electric-logo.webp"
          alt="Wheyland Electric - Licensed Electrician Carlsbad CA"
          width="200"
          height="57"
          class="h-12 w-auto"
          loading="eager"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-0.5">
        {nav.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-brand-slate hover:text-brand-teal transition-colors inline-flex items-center gap-1"
            >
              {item.label}
              {(item.children || item.residentialChildren) && (
                <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>

            {/* Standard single-column dropdown */}
            {item.children && !item.residentialChildren && (
              <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="bg-white rounded-xl shadow-xl border border-surface-warm/50 py-2 min-w-[240px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2.5 text-sm text-text hover:bg-surface-subtle hover:text-brand-teal transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}

            {/* Two-column Services dropdown: Residential | Commercial */}
            {item.residentialChildren && item.commercialChildren && (
              <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="bg-white rounded-xl shadow-xl border border-surface-warm/50 py-3 flex" style="min-width:600px">
                  <div class="flex-1 border-r border-surface-subtle px-3 pb-2">
                    <div class="px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-teal mb-1">Residential</div>
                    {item.residentialChildren.map((child) => (
                      <a
                        href={child.href}
                        class="block px-3 py-1.5 text-sm text-text hover:bg-surface-subtle hover:text-brand-teal transition-colors rounded-md"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                  <div class="w-60 px-3 pb-2">
                    <div class="px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-gold mb-1">Commercial</div>
                    {item.commercialChildren.map((child) => (
                      <a
                        href={child.href}
                        class="block px-3 py-1.5 text-sm text-text hover:bg-surface-subtle hover:text-brand-teal transition-colors rounded-md"
                      >
                        {child.label}
                      </a>
                    ))}
                    <div class="mt-4 mx-3 pt-3 border-t border-surface-subtle">
                      <a href="/services/" class="block text-xs font-semibold text-brand-teal hover:text-brand-teal-light transition-colors">
                        All Services →
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- CTA area (desktop) -->
      <div class="hidden lg:flex items-center gap-4">
        <a href={`tel:${site.nap.phoneTel}`} class="text-sm font-semibold text-brand-slate hover:text-brand-teal transition-colors">
          {site.nap.phone}
        </a>
        <Button href={ctaNav.estimate.href} variant="primary" size="sm">
          {ctaNav.estimate.label}
        </Button>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class="lg:hidden p-2 text-brand-slate hover:text-brand-teal transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav overlay -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-50 lg:hidden">
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" id="mobile-menu-backdrop"></div>
    <div class="fixed right-0 top-0 bottom-0 w-80 max-w-[85vw] bg-white shadow-2xl overflow-y-auto">
      <div class="p-5">
        <div class="flex items-center justify-between mb-8">
          <span class="font-heading font-bold text-brand-slate text-lg">Menu</span>
          <button id="mobile-menu-close" class="p-2 text-text-muted hover:text-brand-slate transition-colors" aria-label="Close menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="space-y-1" aria-label="Mobile navigation">
          {nav.map((item) => (
            <div>
              <a href={item.href} class="block px-3 py-3 text-base font-medium text-brand-slate hover:bg-surface-subtle rounded-lg transition-colors">
                {item.label}
              </a>
              {item.children && (
                <div class="ml-4 space-y-0.5 mb-2">
                  {item.children.map((child) => (
                    <a href={child.href} class="block px-3 py-2 text-sm text-text-muted hover:text-brand-teal transition-colors">
                      {child.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </nav>
        <div class="mt-8 space-y-3 px-3">
          <a href={`tel:${site.nap.phoneTel}`} class="block text-center font-semibold text-brand-slate py-3 border-2 border-brand-slate rounded-lg hover:bg-brand-slate hover:text-white transition-colors">
            Call {site.nap.phone}
          </a>
          <a href={ctaNav.estimate.href} class="block text-center font-semibold text-white bg-brand-gold hover:bg-brand-gold-hover py-3 rounded-lg transition-colors shadow-md">
            Free Estimate
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const close = document.getElementById('mobile-menu-close');
  const backdrop = document.getElementById('mobile-menu-backdrop');

  function openMenu() {
    menu?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
</script>
