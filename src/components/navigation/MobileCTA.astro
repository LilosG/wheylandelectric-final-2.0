---
import { site } from '../../data/site';
---
<!-- Sticky mobile CTA bar -->
<div class="fixed bottom-0 left-0 right-0 bg-white border-t border-surface-warm shadow-lg z-40 lg:hidden">
  <div class="flex items-center gap-2 px-4 py-3">
    <a
      href={`tel:${site.nap.phoneTel}`}
      class="flex-1 flex items-center justify-center gap-2 py-3 border-2 border-brand-slate text-brand-slate font-semibold rounded-lg hover:bg-brand-slate hover:text-white transition-colors"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      Call
    </a>
    <a
      href="/free-estimates/"
      class="flex-1 flex items-center justify-center gap-2 py-3 bg-brand-gold hover:bg-brand-gold-hover text-white font-semibold rounded-lg transition-colors"
    >
      Free Estimate
    </a>
  </div>
</div>
