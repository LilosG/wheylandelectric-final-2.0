---

---

<form
  id="contact-form"
  action={import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || '#'}
  method="POST"
  class="form-shell"
  novalidate
>
  <!-- Honeypot -->
  <div class="hidden" aria-hidden="true">
    <label for="contact-website">Website</label>
    <input type="text" id="contact-website" name="_gotcha" tabindex="-1" autocomplete="off" />
  </div>

  <input type="hidden" name="_timestamp" id="contact-timestamp" />
  <input type="hidden" name="_next" value="/thank-you/" />

  <p class="form-helper">Fields marked with * are required.</p>

  <div class="form-grid">
    <div class="form-field">
      <label for="contact-name" class="form-label">Name *</label>
      <input
        type="text"
        id="contact-name"
        name="name"
        required
        class="form-control"
        autocomplete="name"
      />
    </div>
    <div class="form-field">
      <label for="contact-email" class="form-label">Email *</label>
      <input
        type="email"
        id="contact-email"
        name="email"
        required
        class="form-control"
        autocomplete="email"
      />
    </div>
    <div class="form-field">
      <label for="contact-phone" class="form-label">Phone</label>
      <input
        type="tel"
        id="contact-phone"
        name="phone"
        class="form-control"
        autocomplete="tel"
        aria-describedby="contact-phone-help"
      />
      <p id="contact-phone-help" class="form-helper">Optional, but helpful for urgent requests.</p>
    </div>
  </div>
  <div class="form-field">
    <label for="contact-message" class="form-label">Message *</label>
    <textarea
      id="contact-message"
      name="message"
      rows="4"
      required
      class="form-control form-textarea"></textarea>
  </div>
  <p id="contact-feedback" class="form-feedback" role="status" aria-live="polite"></p>
  <div class="form-submit-group">
    <button type="submit" class="form-submit"> Send Message </button>
  </div>
</form>

<script>
  const timestampField = document.getElementById('contact-timestamp') as HTMLInputElement;
  if (timestampField) timestampField.value = String(Date.now());

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('contact-feedback') as HTMLParagraphElement;

  const showFeedback = (state: 'error' | 'success', message: string) => {
    if (!feedback) return;
    feedback.dataset.state = state;
    feedback.textContent = message;
    feedback.role = state === 'error' ? 'alert' : 'status';
  };

  let hasStarted = false;

  form?.addEventListener('focusin', () => {
    if (hasStarted) return;
    hasStarted = true;
    window.WheylandTracking?.track('form_start', { form_id: 'contact-form' });
  });

  form?.addEventListener('submit', (e) => {
    if (!form.checkValidity()) {
      e.preventDefault();
      form.reportValidity();
      window.WheylandTracking?.track('form_submit_fail', {
        form_id: 'contact-form',
        fail_reason: 'validation',
      });
      showFeedback('error', 'Please complete all required fields before submitting.');
      return;
    }

    const timestamp = parseInt(timestampField?.value || '0', 10);
    if (Date.now() - timestamp < 3000) {
      e.preventDefault();
      window.WheylandTracking?.track('form_submit_fail', {
        form_id: 'contact-form',
        fail_reason: 'submission_too_fast',
      });
      showFeedback('error', 'Please wait a moment, then submit again.');
      return;
    }
    const honeypot = (form.querySelector('[name="_gotcha"]') as HTMLInputElement)?.value;
    if (honeypot) {
      e.preventDefault();
      window.WheylandTracking?.track('form_submit_fail', {
        form_id: 'contact-form',
        fail_reason: 'honeypot',
      });
      showFeedback('error', 'We could not submit your message. Please refresh and try again.');
      return;
    }

    window.WheylandTracking?.track('form_submit_success', { form_id: 'contact-form' });
    showFeedback('success', 'Looks good — sending your message...');
  });
</script>
