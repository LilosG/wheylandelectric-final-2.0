---
import FormField from './FormField.astro';
import FormShell from './FormShell.astro';

import { STATICFORMS_ENDPOINT, STATICFORMS_ACCESS_KEY, THANK_YOU_PATH, THANK_YOU_URL } from '../../data/forms';
---
<FormShell
  heading="Send Us a Message"
  subheading="Questions about a repair or upcoming project? We're here to help."
>
  <form
    id="contact-form"
    action={STATICFORMS_ENDPOINT}
    method="POST"
    class="form-shell"
    data-endpoint={STATICFORMS_ENDPOINT}
    novalidate
  >
    <input type="hidden" name="accessKey" value={STATICFORMS_ACCESS_KEY} />
    <input type="hidden" name="redirectTo" value={THANK_YOU_URL} />
    <input type="hidden" name="_timestamp" id="contact-timestamp" />
    <input type="hidden" name="form_type" value="contact" />
    <input type="hidden" name="phone_digits" value="" />
    <input type="text" name="honeypot" style="display:none" />

    <fieldset class="space-y-5">
      <p class="text-sm text-text-muted">Full name and message are required. Please provide a phone number, email, or both.</p>

      <div class="form-grid gap-5">
        <FormField
          id="contact-name"
          name="name"
          label="Full Name"
          required
          placeholder="Your full name"
          autocomplete="name"
        />

        <FormField
          id="contact-phone"
          name="phone"
          label="Phone"
          type="tel"
          placeholder="(858) 555-1234"
          autocomplete="tel"
        />

        <FormField
          id="contact-email"
          name="email"
          label="Email"
          type="email"
          placeholder="you@example.com"
          autocomplete="email"
          fieldClass="md:col-span-2"
        />
      </div>

      <FormField
        id="contact-message"
        name="message"
        label="Message"
        as="textarea"
        required
        rows={5}
        placeholder="Tell us about your electrical question or project."
      />

      <p id="contact-feedback" class="form-feedback" role="status" aria-live="polite"></p>

      <div class="form-submit-group space-y-2">
        <button
          type="submit"
          class="w-full rounded-lg bg-brand-gold px-8 py-3 font-semibold text-white transition-colors hover:bg-brand-gold-hover focus:outline-none focus:ring-2 focus:ring-brand-teal focus:ring-offset-2 disabled:cursor-not-allowed disabled:bg-surface-warm disabled:text-text-muted sm:w-auto"
          data-loading-label="Sending Message..."
        >
          Send Message
        </button>
      </div>
    </fieldset>
  </form>
</FormShell>

<script>
  import { initLeadForm } from '../../lib/forms/client';
  import { THANK_YOU_PATH } from '../../data/forms';

  initLeadForm({
    formId: 'contact-form',
    feedbackId: 'contact-feedback',
    endpoint: (document.getElementById('contact-form') as HTMLFormElement | null)?.dataset.endpoint || '',
    thankYouPath: THANK_YOU_PATH,
    requireOneOf: ['email', 'phone'],
  });
</script>
