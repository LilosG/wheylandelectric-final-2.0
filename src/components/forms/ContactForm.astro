---
import FormField from './FormField.astro';
import FormShell from './FormShell.astro';

const endpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT;
const isEndpointMissing = !endpoint;
---
<FormShell
  heading="Send Us a Message"
  subheading="Questions about a repair or upcoming project? We’re here to help."
>
  {import.meta.env.DEV && isEndpointMissing && (
    <p slot="metaNote" class="text-sm text-text-muted">
      Dev note: set <code>PUBLIC_FORMSPREE_ENDPOINT</code> to enable submissions.
    </p>
  )}

  <form
    id="contact-form"
    action={endpoint || '#'}
    method="POST"
    class="form-shell"
    data-endpoint={endpoint || ''}
    novalidate
  >
    <div class="absolute -left-[10000px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
      <label for="contact-website">Leave this field empty</label>
      <input type="text" id="contact-website" name="_gotcha" tabindex="-1" autocomplete="off" />
    </div>

    <input type="hidden" name="_timestamp" id="contact-timestamp" />
    <input type="hidden" name="_next" value="/thank-you/" />
    <input type="hidden" name="form_type" value="contact" />
    <input type="hidden" name="phone_digits" value="" />

    <fieldset class="space-y-5" disabled={!import.meta.env.DEV && isEndpointMissing}>
      <p class="text-sm text-text-muted">Full name and message are required. Please provide a phone number, email, or both.</p>

      <div class="form-grid gap-5">
        <FormField
          id="contact-name"
          name="name"
          label="Full Name"
          required
          placeholder="Your full name"
          autocomplete="name"
        />

        <FormField
          id="contact-phone"
          name="phone"
          label="Phone"
          type="tel"
          placeholder="(858) 555-1234"
          autocomplete="tel"
        />

        <FormField
          id="contact-email"
          name="email"
          label="Email"
          type="email"
          placeholder="you@example.com"
          autocomplete="email"
          fieldClass="md:col-span-2"
        />
      </div>

      <FormField
        id="contact-message"
        name="message"
        label="Message"
        as="textarea"
        required
        rows={5}
        placeholder="Tell us about your electrical question or project."
      />

      <p id="contact-feedback" class="form-feedback" role="status" aria-live="polite"></p>

      <div class="form-submit-group space-y-2">
        {!import.meta.env.DEV && isEndpointMissing && (
          <p class="text-sm text-text-muted">Online submission is temporarily unavailable. Please call <a href="tel:8586635564" class="font-medium text-brand-teal hover:text-brand-slate">(858) 663-5564</a>.</p>
        )}
        <button
          type="submit"
          class="w-full rounded-lg bg-brand-gold px-8 py-3 font-semibold text-white transition-colors hover:bg-brand-gold-hover focus:outline-none focus:ring-2 focus:ring-brand-teal focus:ring-offset-2 disabled:cursor-not-allowed disabled:bg-surface-warm disabled:text-text-muted sm:w-auto"
          data-loading-label="Sending Message..."
          disabled={!import.meta.env.DEV && isEndpointMissing}
        >
          Send Message
        </button>
      </div>
    </fieldset>
  </form>
</FormShell>

<script>
  import { initLeadForm } from '../../lib/forms/client';

  initLeadForm({
    formId: 'contact-form',
    feedbackId: 'contact-feedback',
    endpoint: (document.getElementById('contact-form') as HTMLFormElement | null)?.dataset.endpoint || '',
    thankYouPath: '/thank-you/',
    requireOneOf: ['email', 'phone'],
  });
</script>
