---
---
<form
  id="contact-form"
  action={import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || '#'}
  method="POST"
  class="form-shell"
  novalidate
>
  <!-- Honeypot -->
  <div class="hidden" aria-hidden="true">
    <label for="contact-website">Website</label>
    <input type="text" id="contact-website" name="_gotcha" tabindex="-1" autocomplete="off" />
  </div>

  <input type="hidden" name="_timestamp" id="contact-timestamp" />
  <input type="hidden" name="_next" value="/thank-you/" />

  <p class="form-helper">Only three fields are required: name, best contact, and project summary.</p>
  <p class="form-helper">
    We reply within 1 business day whenever possible, and your contact details stay private.
  </p>

  <div class="form-grid">
    <div class="form-field">
      <label for="contact-name" class="form-label">Name *</label>
      <input
        type="text"
        id="contact-name"
        name="name"
        required
        class="form-control"
        autocomplete="name"
      />
    </div>
    <div class="form-field">
      <label for="contact-method" class="form-label">Best Contact (Email or Phone) *</label>
      <input
        type="text"
        id="contact-method"
        name="contact"
        required
        class="form-control"
        autocomplete="email"
        placeholder="you@example.com or (555) 123-4567"
        aria-describedby="contact-method-help contact-method-error"
      />
      <p id="contact-method-help" class="form-helper">Let us know the easiest way to reach you.</p>
      <p id="contact-method-error" class="form-helper" data-error-for="contact" hidden>
        Please provide an email address or phone number.
      </p>
    </div>
    <div class="form-field">
      <label for="contact-phone" class="form-label">Phone (optional)</label>
      <input
        type="tel"
        id="contact-phone"
        name="phone"
        class="form-control"
        autocomplete="tel"
        aria-describedby="contact-phone-help"
      />
      <p id="contact-phone-help" class="form-helper">Optional if already included above.</p>
    </div>
  </div>
  <div class="form-field">
    <label for="contact-message" class="form-label">Project Summary *</label>
    <textarea
      id="contact-message"
      name="message"
      rows="4"
      required
      class="form-control form-textarea"
      aria-describedby="contact-message-help contact-message-error"
    ></textarea>
    <p id="contact-message-help" class="form-helper">Briefly share what you need help with.</p>
    <p id="contact-message-error" class="form-helper" data-error-for="message" hidden>
      Please include a short project summary so we can respond accurately.
    </p>
  </div>
  <p id="contact-feedback" class="form-feedback" role="status" aria-live="polite"></p>
  <div class="form-submit-group">
    <button
      type="submit"
      class="form-submit"
    >
      Request Free Estimate
    </button>
  </div>
</form>

<script>
  const timestampField = document.getElementById('contact-timestamp') as HTMLInputElement;
  if (timestampField) timestampField.value = String(Date.now());

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('contact-feedback') as HTMLParagraphElement;

  const showFeedback = (state: 'error' | 'success', message: string) => {
    if (!feedback) return;
    feedback.dataset.state = state;
    feedback.textContent = message;
    feedback.role = state === 'error' ? 'alert' : 'status';
  };

  form?.addEventListener('submit', (e) => {
    if (!form.checkValidity()) {
      e.preventDefault();
      form.reportValidity();
      const requiredFields = form.querySelectorAll('input[required], textarea[required]');
      requiredFields.forEach((field) => {
        const input = field as HTMLInputElement | HTMLTextAreaElement;
        const errorEl = form.querySelector(`[data-error-for="${input.name}"]`) as HTMLParagraphElement | null;
        const hasValue = input.value.trim().length > 0;
        input.setAttribute('aria-invalid', hasValue ? 'false' : 'true');
        if (errorEl) errorEl.hidden = hasValue;
      });

      const firstInvalid = form.querySelector(':invalid') as HTMLInputElement | HTMLTextAreaElement | null;
      const fieldName = firstInvalid?.labels?.[0]?.textContent?.replace('*', '').trim() || 'required fields';
      showFeedback('error', `Please check ${fieldName.toLowerCase()} and try again.`);
      return;
    }

    const timestamp = parseInt(timestampField?.value || '0', 10);
    if (Date.now() - timestamp < 3000) {
      e.preventDefault();
      showFeedback('error', 'Please wait a moment, then submit again.');
      return;
    }
    const honeypot = (form.querySelector('[name="_gotcha"]') as HTMLInputElement)?.value;
    if (honeypot) {
      e.preventDefault();
      showFeedback('error', 'We could not submit your message. Please refresh and try again.');
      return;
    }

    showFeedback(
      'success',
      'Thanks! Your request is submitted. Expect a reply with next steps within 1 business day.',
    );
  });

  form?.querySelectorAll('input[required], textarea[required]').forEach((field) => {
    field.addEventListener('input', () => {
      const input = field as HTMLInputElement | HTMLTextAreaElement;
      const errorEl = form.querySelector(`[data-error-for="${input.name}"]`) as HTMLParagraphElement | null;
      const hasValue = input.value.trim().length > 0;
      input.setAttribute('aria-invalid', hasValue ? 'false' : 'true');
      if (errorEl) errorEl.hidden = hasValue;
    });
  });
</script>
