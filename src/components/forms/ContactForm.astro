---
---
<form
  id="contact-form"
  action={import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || '#'}
  method="POST"
  class="space-y-6"
>
  <!-- Honeypot -->
  <div class="hidden" aria-hidden="true">
    <label for="contact-website">Website</label>
    <input type="text" id="contact-website" name="_gotcha" tabindex="-1" autocomplete="off" />
  </div>

  <input type="hidden" name="_timestamp" id="contact-timestamp" />
  <input type="hidden" name="_next" value="/thank-you/" />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label for="contact-name" class="block text-sm font-semibold text-brand-slate mb-2">Name *</label>
      <input
        type="text"
        id="contact-name"
        name="name"
        required
        class="w-full px-4 py-3 rounded-lg border border-surface-warm focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 outline-none transition-colors text-text"
      />
    </div>
    <div>
      <label for="contact-email" class="block text-sm font-semibold text-brand-slate mb-2">Email *</label>
      <input
        type="email"
        id="contact-email"
        name="email"
        required
        class="w-full px-4 py-3 rounded-lg border border-surface-warm focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 outline-none transition-colors text-text"
      />
    </div>
    <div>
      <label for="contact-phone" class="block text-sm font-semibold text-brand-slate mb-2">Phone</label>
      <input
        type="tel"
        id="contact-phone"
        name="phone"
        class="w-full px-4 py-3 rounded-lg border border-surface-warm focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 outline-none transition-colors text-text"
      />
    </div>
  </div>
  <div>
    <label for="contact-message" class="block text-sm font-semibold text-brand-slate mb-2">Message *</label>
    <textarea
      id="contact-message"
      name="message"
      rows="4"
      required
      class="w-full px-4 py-3 rounded-lg border border-surface-warm focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 outline-none transition-colors text-text resize-y"
    ></textarea>
  </div>
  <div>
    <button
      type="submit"
      class="bg-brand-gold hover:bg-brand-gold-hover text-white font-semibold px-6 py-3 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-brand-teal focus:ring-offset-2"
    >
      Send Message
    </button>
  </div>
</form>

<script>
  const timestampField = document.getElementById('contact-timestamp') as HTMLInputElement;
  if (timestampField) timestampField.value = String(Date.now());

  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    const timestamp = parseInt(timestampField?.value || '0', 10);
    if (Date.now() - timestamp < 3000) { e.preventDefault(); return; }
    const honeypot = (form.querySelector('[name="_gotcha"]') as HTMLInputElement)?.value;
    if (honeypot) { e.preventDefault(); return; }
  });
</script>
