---
interface Props {
  heading: string;
  subheading?: string;
  showTrustPanel?: boolean;
}

const { heading, subheading = '', showTrustPanel = true } = Astro.props;
---
<div class="mx-auto max-w-4xl">
  <div class="grid grid-cols-12 gap-5 md:gap-6">

    <section
      class:list={[
        'col-span-12 rounded-2xl border border-surface-subtle border-t-4 border-t-brand-gold bg-white p-6 shadow-sm md:p-8',
        showTrustPanel ? 'lg:col-span-7' : 'lg:col-span-12',
      ]}
    >
      <header class="mb-6 space-y-1.5">
        <h2 class="text-2xl font-heading font-bold text-brand-slate md:text-3xl">{heading}</h2>
        {subheading && <p class="text-sm leading-relaxed text-text-muted md:text-base">{subheading}</p>}
        <slot name="metaNote" />
      </header>
      <slot />
    </section>

    {showTrustPanel && (
      <aside class="col-span-12 lg:col-span-5 flex flex-col gap-4">

        <!-- What Happens Next -->
        <div class="rounded-2xl border border-surface-subtle bg-white p-6 shadow-sm">
          <h3 class="mb-5 text-base font-semibold text-brand-slate">What Happens Next</h3>
          <ol class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-teal/10 text-xs font-bold text-brand-teal">1</span>
              <div>
                <p class="text-sm font-medium text-brand-slate">We review your request</p>
                <p class="text-xs text-text-muted mt-0.5">We confirm project details and match you with the right service.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-teal/10 text-xs font-bold text-brand-teal">2</span>
              <div>
                <p class="text-sm font-medium text-brand-slate">You hear back within one business day</p>
                <p class="text-xs text-text-muted mt-0.5">No waiting around — we respond promptly by phone or email.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-teal/10 text-xs font-bold text-brand-teal">3</span>
              <div>
                <p class="text-sm font-medium text-brand-slate">We schedule your estimate visit</p>
                <p class="text-xs text-text-muted mt-0.5">We find the earliest available time that works for you.</p>
              </div>
            </li>
          </ol>
        </div>

        <!-- Trust credentials -->
        <div class="rounded-2xl border border-surface-subtle bg-white p-6 shadow-sm">
          <h3 class="mb-4 text-base font-semibold text-brand-slate">Why Wheyland Electric</h3>
          <ul class="space-y-3">
            <li class="flex items-center gap-3">
              <svg class="h-5 w-5 shrink-0 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <span class="text-sm text-text-muted"><span class="font-semibold text-brand-slate">Licensed &amp; insured</span> — CA License #940291</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-5 w-5 shrink-0 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-sm text-text-muted"><span class="font-semibold text-brand-slate">1-year labor warranty</span> on all workmanship</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-5 w-5 shrink-0 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span class="text-sm text-text-muted"><span class="font-semibold text-brand-slate">Available Mon–Fri</span>, 8am–7pm</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="h-5 w-5 shrink-0 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
              </svg>
              <span class="text-sm text-text-muted"><span class="font-semibold text-brand-slate">Serving San Diego County</span> since 2008</span>
            </li>
          </ul>
        </div>

        <!-- Call CTA -->
        <div class="rounded-2xl border border-brand-teal/20 bg-brand-teal/5 p-5">
          <p class="text-sm font-semibold text-brand-slate">Prefer to call us directly?</p>
          <p class="text-xs text-text-muted mt-0.5 mb-3">We answer during business hours — no voicemail maze.</p>
          <a href="tel:8586635564" class="inline-flex items-center gap-2 rounded-lg bg-brand-teal px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-brand-teal-light">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            (858) 663-5564
          </a>
        </div>

      </aside>
    )}

  </div>
</div>
