---
import { getPublishedCities } from '../../data/cities';
import { getPublishedPillars } from '../../data/services';

const cities = getPublishedCities();
const services = getPublishedPillars();
---
<form
  id="estimate-form"
  action={import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || '#'}
  method="POST"
  class="form-shell"
  novalidate
>
  <!-- Honeypot -->
  <div class="hidden" aria-hidden="true">
    <label for="website">Website</label>
    <input type="text" id="website" name="_gotcha" tabindex="-1" autocomplete="off" />
  </div>

  <!-- Timestamp for spam guard -->
  <input type="hidden" name="_timestamp" id="form-timestamp" />

  <!-- Redirect -->
  <input type="hidden" name="_next" value="/thank-you/" />

  <p class="form-helper">Only three fields are required: name, best contact, and project summary.</p>
  <p class="form-helper">
    We typically respond within 1 business day, and we never share your information outside our team.
  </p>

  <div class="form-grid">
    <!-- Name -->
    <div class="form-field">
      <label for="name" class="form-label">Full Name *</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="form-control"
        placeholder="Your full name"
        autocomplete="name"
      />
    </div>

    <!-- Preferred contact -->
    <div class="form-field">
      <label for="contact" class="form-label">Best Contact (Email or Phone) *</label>
      <input
        type="text"
        id="contact"
        name="contact"
        required
        class="form-control"
        placeholder="you@example.com or (555) 123-4567"
        autocomplete="email"
        aria-describedby="estimate-contact-help estimate-contact-error"
      />
      <p id="estimate-contact-help" class="form-helper">Share whichever contact method you prefer us to use.</p>
      <p id="estimate-contact-error" class="form-helper" data-error-for="contact" hidden>
        Please add an email address or phone number so we can reach you.
      </p>
    </div>

    <!-- City -->
    <div class="form-field">
      <label for="city" class="form-label">City (optional)</label>
      <select
        id="city"
        name="city"
        class="form-control"
      >
        <option value="">Select your city</option>
        {cities.map((city) => (
          <option value={city.name}>{city.name}, CA</option>
        ))}
        <option value="Other">Other</option>
      </select>
    </div>

    <!-- Service -->
    <div class="form-field">
      <label for="service" class="form-label">Service Needed (optional)</label>
      <select
        id="service"
        name="service"
        class="form-control"
      >
        <option value="">Select a service</option>
        {services.map((svc) => (
          <option value={svc.name}>{svc.name}</option>
        ))}
        <option value="HOA Maintenance Quote">HOA Maintenance Quote</option>
        <option value="Other">Other</option>
      </select>
    </div>

    <!-- Preferred contact method -->
    <div class="form-field">
      <label for="contact-method" class="form-label">Preferred Contact Method (optional)</label>
      <select
        id="contact-method"
        name="contact_method"
        class="form-control"
      >
        <option value="phone">Phone</option>
        <option value="email">Email</option>
        <option value="text">Text</option>
      </select>
    </div>
  </div>

  <!-- Message -->
  <div class="form-field">
    <label for="message" class="form-label">Project Summary *</label>
    <textarea
      id="message"
      name="message"
      rows="4"
      required
      class="form-control form-textarea"
      placeholder="Describe what you need help with..."
      aria-describedby="estimate-message-help estimate-message-error"
    ></textarea>
    <p id="estimate-message-help" class="form-helper">A short summary is enough — we can gather details in follow-up.</p>
    <p id="estimate-message-error" class="form-helper" data-error-for="message" hidden>
      Please add a brief project summary so we can prepare your estimate.
    </p>
  </div>

  <p id="estimate-feedback" class="form-feedback" role="status" aria-live="polite"></p>

  <!-- Submit -->
  <div class="form-submit-group">
    <button
      type="submit"
      class="form-submit text-lg"
    >
      Request Free Estimate
    </button>
  </div>
</form>

<script>
  // Set timestamp on load for spam guard
  const timestampField = document.getElementById('form-timestamp') as HTMLInputElement;
  if (timestampField) {
    timestampField.value = String(Date.now());
  }

  // Client-side validation
  const form = document.getElementById('estimate-form') as HTMLFormElement;
  const feedback = document.getElementById('estimate-feedback') as HTMLParagraphElement;

  const showFeedback = (state: 'error' | 'success', message: string) => {
    if (!feedback) return;
    feedback.dataset.state = state;
    feedback.textContent = message;
    feedback.role = state === 'error' ? 'alert' : 'status';
  };

  form?.addEventListener('submit', (e) => {
    if (!form.checkValidity()) {
      e.preventDefault();
      form.reportValidity();
      const requiredFields = form.querySelectorAll('input[required], textarea[required]');
      requiredFields.forEach((field) => {
        const input = field as HTMLInputElement | HTMLTextAreaElement;
        const errorEl = form.querySelector(`[data-error-for="${input.name}"]`) as HTMLParagraphElement | null;
        const hasValue = input.value.trim().length > 0;
        input.setAttribute('aria-invalid', hasValue ? 'false' : 'true');
        if (errorEl) errorEl.hidden = hasValue;
      });

      const firstInvalid = form.querySelector(':invalid') as HTMLInputElement | HTMLTextAreaElement | null;
      const fieldName = firstInvalid?.labels?.[0]?.textContent?.replace('*', '').trim() || 'required fields';
      showFeedback('error', `Please check ${fieldName.toLowerCase()} and try again.`);
      return;
    }

    const timestamp = parseInt(timestampField?.value || '0', 10);
    const elapsed = Date.now() - timestamp;

    // Reject if submitted in under 3 seconds (likely bot)
    if (elapsed < 3000) {
      e.preventDefault();
      showFeedback('error', 'Please wait a moment, then submit again.');
      return;
    }

    // Check honeypot
    const honeypot = (form.querySelector('[name="_gotcha"]') as HTMLInputElement)?.value;
    if (honeypot) {
      e.preventDefault();
      showFeedback('error', 'We could not submit your request. Please refresh and try again.');
      return;
    }

    showFeedback(
      'success',
      'Thanks! Your request is on the way. We will review it and follow up with next steps within 1 business day.',
    );
  });

  form?.querySelectorAll('input[required], textarea[required]').forEach((field) => {
    field.addEventListener('input', () => {
      const input = field as HTMLInputElement | HTMLTextAreaElement;
      const errorEl = form.querySelector(`[data-error-for="${input.name}"]`) as HTMLParagraphElement | null;
      const hasValue = input.value.trim().length > 0;
      input.setAttribute('aria-invalid', hasValue ? 'false' : 'true');
      if (errorEl) errorEl.hidden = hasValue;
    });
  });
</script>
