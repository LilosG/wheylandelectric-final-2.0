---
import { getPublishedCities } from '../../data/cities';
import { getPublishedPillars } from '../../data/services';

const cities = getPublishedCities();
const services = getPublishedPillars();
---

<form
  id="estimate-form"
  action={import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || '#'}
  method="POST"
  class="form-shell"
  novalidate
>
  <!-- Honeypot -->
  <div class="hidden" aria-hidden="true">
    <label for="website">Website</label>
    <input type="text" id="website" name="_gotcha" tabindex="-1" autocomplete="off" />
  </div>

  <!-- Timestamp for spam guard -->
  <input type="hidden" name="_timestamp" id="form-timestamp" />

  <!-- Redirect -->
  <input type="hidden" name="_next" value="/thank-you/" />

  <p class="form-helper">Fields marked with * are required.</p>

  <div class="form-grid">
    <!-- Name -->
    <div class="form-field">
      <label for="name" class="form-label">Full Name *</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="form-control"
        placeholder="Your full name"
        autocomplete="name"
      />
    </div>

    <!-- Phone -->
    <div class="form-field">
      <label for="phone" class="form-label">Phone *</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        class="form-control"
        placeholder="(xxx) xxx-xxxx"
        autocomplete="tel"
        aria-describedby="estimate-phone-help"
      />
      <p id="estimate-phone-help" class="form-helper">Include area code for a faster callback.</p>
    </div>

    <!-- Email -->
    <div class="form-field">
      <label for="email" class="form-label">Email *</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="form-control"
        placeholder="you@example.com"
        autocomplete="email"
      />
    </div>

    <!-- City -->
    <div class="form-field">
      <label for="city" class="form-label">City</label>
      <select id="city" name="city" class="form-control">
        <option value="">Select your city</option>
        {cities.map((city) => <option value={city.name}>{city.name}, CA</option>)}
        <option value="Other">Other</option>
      </select>
    </div>

    <!-- Service -->
    <div class="form-field">
      <label for="service" class="form-label">Service Needed</label>
      <select id="service" name="service" class="form-control">
        <option value="">Select a service</option>
        {services.map((svc) => <option value={svc.name}>{svc.name}</option>)}
        <option value="HOA Maintenance Quote">HOA Maintenance Quote</option>
        <option value="Other">Other</option>
      </select>
    </div>

    <!-- Preferred contact method -->
    <div class="form-field">
      <label for="contact-method" class="form-label">Preferred Contact Method</label>
      <select id="contact-method" name="contact_method" class="form-control">
        <option value="phone">Phone</option>
        <option value="email">Email</option>
        <option value="text">Text</option>
      </select>
    </div>
  </div>

  <!-- Message -->
  <div class="form-field">
    <label for="message" class="form-label">Tell Us About Your Project</label>
    <textarea
      id="message"
      name="message"
      rows="4"
      class="form-control form-textarea"
      placeholder="Describe what you need help with..."></textarea>
  </div>

  <p id="estimate-feedback" class="form-feedback" role="status" aria-live="polite"></p>

  <!-- Submit -->
  <div class="form-submit-group">
    <button type="submit" class="form-submit text-lg"> Request Free Estimate </button>
  </div>
</form>

<script>
  // Set timestamp on load for spam guard
  const timestampField = document.getElementById('form-timestamp') as HTMLInputElement;
  if (timestampField) {
    timestampField.value = String(Date.now());
  }

  // Client-side validation
  const form = document.getElementById('estimate-form') as HTMLFormElement;
  const feedback = document.getElementById('estimate-feedback') as HTMLParagraphElement;

  const showFeedback = (state: 'error' | 'success', message: string) => {
    if (!feedback) return;
    feedback.dataset.state = state;
    feedback.textContent = message;
    feedback.role = state === 'error' ? 'alert' : 'status';
  };

  let hasStarted = false;

  form?.addEventListener('focusin', () => {
    if (hasStarted) return;
    hasStarted = true;
    window.WheylandTracking?.track('form_start', { form_id: 'estimate-form' });
  });

  form?.addEventListener('submit', (e) => {
    if (!form.checkValidity()) {
      e.preventDefault();
      form.reportValidity();
      window.WheylandTracking?.track('form_submit_fail', {
        form_id: 'estimate-form',
        fail_reason: 'validation',
      });
      showFeedback('error', 'Please complete all required fields before submitting.');
      return;
    }

    const timestamp = parseInt(timestampField?.value || '0', 10);
    const elapsed = Date.now() - timestamp;

    // Reject if submitted in under 3 seconds (likely bot)
    if (elapsed < 3000) {
      e.preventDefault();
      window.WheylandTracking?.track('form_submit_fail', {
        form_id: 'estimate-form',
        fail_reason: 'submission_too_fast',
      });
      showFeedback('error', 'Please wait a moment, then submit again.');
      return;
    }

    // Check honeypot
    const honeypot = (form.querySelector('[name="_gotcha"]') as HTMLInputElement)?.value;
    if (honeypot) {
      e.preventDefault();
      window.WheylandTracking?.track('form_submit_fail', {
        form_id: 'estimate-form',
        fail_reason: 'honeypot',
      });
      showFeedback('error', 'We could not submit your request. Please refresh and try again.');
      return;
    }

    window.WheylandTracking?.track('form_submit_success', { form_id: 'estimate-form' });
    showFeedback('success', 'Looks good — sending your estimate request...');
  });
</script>
