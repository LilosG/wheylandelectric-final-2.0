---
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

{GA_ID && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA_ID, { send_page_view: true });
    </script>
  <script is:inline>
    document.addEventListener('click', function(e) {
      var el = e.target.closest('a[href^="tel:"]');
      if (!el) return;
      if (typeof gtag === 'function') {
        gtag('event', 'click_to_call', {
          event_category: 'engagement',
          event_label: el.href.replace('tel:', ''),
        });
      }
    });
  </script>
  </>
)}
