---
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

{GA_ID && (
  <Fragment>
    <meta name="ga-id" content={GA_ID} />
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline>
      var _ga = document.querySelector('meta[name="ga-id"]').content;
      window.dataLayer = window.dataLayer || [];
      window.gtag = function gtag() { window.dataLayer.push(arguments); };
      window.gtag('js', new Date());
      window.gtag('config', _ga, { send_page_view: true });
      document.addEventListener('click', function(e) {
        var el = e.target.closest('a[href^="tel:"]');
        if (!el) return;
        window.gtag('event', 'click_to_call', {
          event_category: 'engagement',
          event_label: el.href.replace('tel:', '')
        });
      });
    </script>
  </Fragment>
)}
