---
interface Props {
  bg?: 'white' | 'subtle' | 'warm' | 'indigo' | 'surface';
  class?: string;
  id?: string;
}

const { bg = 'white', class: className = '', id } = Astro.props;

const bgMap: Record<string, string> = {
  white: 'bg-white',
  subtle: 'bg-surface-subtle',
  warm: 'bg-surface-warm',
  indigo: 'bg-brand-slate text-white',
  surface: 'bg-surface',
};

const bgClass = bgMap[bg] ?? 'bg-white';
---
<section class:list={['py-16 md:py-24', bgClass, className]} id={id}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <slot />
  </div>
</section>
