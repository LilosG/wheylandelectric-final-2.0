---
interface Props {
  bg?: 'white' | 'subtle' | 'warm' | 'indigo' | 'surface';
  spacing?: 'default' | 'hero-tight' | 'hero-adjacent' | 'none';
  class?: string;
  id?: string;
}

const { bg = 'white', spacing = 'default', class: className = '', id } = Astro.props;

const bgMap: Record<string, string> = {
  white: 'bg-white',
  subtle: 'bg-surface-subtle',
  warm: 'bg-surface-warm',
  indigo: 'bg-brand-slate text-white',
  surface: 'bg-surface',
};

const bgClass = bgMap[bg] ?? 'bg-white';

const spacingMap: Record<string, string> = {
  default: 'py-14 md:py-20',
  'hero-tight': 'pt-8 pb-14 md:pt-10 md:pb-20',
  'hero-adjacent': 'pt-0 pb-14 md:pb-20',
  none: 'py-0',
};

const spacingClass = spacingMap[spacing] ?? spacingMap.default;
---
<section class:list={[spacingClass, bgClass, className]} id={id}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <slot />
  </div>
</section>
