---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../sections/Hero.astro';
import TrustBar from '../sections/TrustBar.astro';
import Section from '../ui/Section.astro';
import FAQAccordion from '../sections/FAQAccordion.astro';
import CTASection from '../sections/CTASection.astro';
import TestimonialBlock from '../sections/TestimonialBlock.astro';
import ServiceIntroSection from '../sections/ServiceIntroSection.astro';
import WhatsIncludedSection from '../sections/WhatsIncludedSection.astro';
import ProcessStepsSection from '../sections/ProcessStepsSection.astro';
import PricingFactorsSection from '../sections/PricingFactorsSection.astro';
import ContextualCTABand from '../sections/ContextualCTABand.astro';
import AreaLinksSection from '../sections/AreaLinksSection.astro';
import RelatedServicesSection from '../sections/RelatedServicesSection.astro';
import type { City, FAQ, PageMeta, BreadcrumbItem, ServicePillar } from '../../types';
import type { ServiceHeroImage } from '../../data/serviceHeroImages';

/**
 * ServicePillarTemplate — fixed-structure template for all 8 pillar pages.
 *
 * FIXED SECTION ORDER (no conditional visual logic):
 * 1. Breadcrumbs (PageLayout)
 * 2. Hero
 * 3. TrustBar
 * 4. Contextual CTA Band — bg-surface-subtle (compact)
 * 5. Service Overview — bg-white
 * 6. What's Included — bg-surface-subtle
 * 7. Process Steps — bg-white (omitted only if no steps)
 * 8. Pricing Factors — bg-surface-subtle
 * 9. Service Areas Served — bg-white
 * 10. Related Services — bg-surface-subtle (omitted only if no related pillars)
 * 11. FAQs — bg-white (omitted only if no FAQs)
 * 12. Testimonial Block — dark navy (self-contained)
 * 13. CTA Section — dark navy (self-contained)
 *
 * Sections 5–8 use the EXACT SAME shared components as ServiceMoneyPageTemplate,
 * ensuring visual consistency between money pages and pillar pages.
 */

interface Props {
  meta: PageMeta;
  schemas: Record<string, unknown>[];
  breadcrumbs: BreadcrumbItem[];
  pillar: ServicePillar;
  heroImage: {
    src: string;
    alt: string;
  };
  serviceImg?: ServiceHeroImage;
  serviceAreaCities: Pick<City, 'slug' | 'name'>[];
  relatedPillars: ServicePillar[];
}

const { meta, schemas, breadcrumbs, pillar, heroImage, serviceImg, serviceAreaCities, relatedPillars } = Astro.props;

const overviewBullets =
  pillar.overviewBullets && pillar.overviewBullets.length > 0
    ? pillar.overviewBullets.slice(0, 6)
    : [
        `Upfront scope and safety review for ${pillar.name.toLowerCase()}.`,
        'Licensed installation with clean, code-compliant workmanship.',
        'Clear communication from estimate through final walkthrough.',
        'Permit coordination support when required by project scope.',
        'Final testing and handoff documentation provided.',
        '1-year labor warranty on all workmanship.',
      ];

const includedBullets =
  pillar.includedItems && pillar.includedItems.length > 0
    ? pillar.includedItems.slice(0, 8)
    : pillar.includedBullets && pillar.includedBullets.length > 0
    ? pillar.includedBullets.slice(0, 8)
    : [
        'Project walk-through and recommendation on next steps.',
        'Material and labor scope aligned to current electrical code.',
        'Final testing, cleanup, and customer handoff notes.',
      ];

const processSteps =
  pillar.processSteps.length > 0
    ? pillar.processSteps.slice(0, 6)
    : [
        { step: 1, title: 'Project Review', description: 'We review your goals, existing setup, and service requirements.' },
        { step: 2, title: 'Professional Execution', description: 'Our team completes the work safely with attention to detail.' },
        { step: 3, title: 'Final Verification', description: 'We test performance and confirm everything is ready for daily use.' },
      ];

const pricingFactors =
  pillar.pricingFactors.length > 0
    ? pillar.pricingFactors.slice(0, 8)
    : ['Project scope', 'Equipment and materials', 'Panel capacity and circuit availability', 'Permit and inspection requirements'];

const faqItems: FAQ[] =
  pillar.faqs.length > 0
    ? pillar.faqs.slice(0, 10)
    : [
        {
          question: `How do I get started with ${pillar.name.toLowerCase()}?`,
          answer: `Contact our team for a free estimate and we will outline the safest and most efficient next steps for your ${pillar.name.toLowerCase()} project.`,
        },
        {
          question: `Will I get a clear scope before work begins?`,
          answer: 'Yes. We provide a clear project scope, timeline expectations, and cost drivers before scheduling work.',
        },
      ];

const serviceAreaLinks = serviceAreaCities.map((city) => ({
  name: city.name,
  href: `/${city.slug}/${pillar.slug}/`,
}));

const relatedServiceItems = relatedPillars.map((p) => ({
  name: p.name,
  slug: p.slug,
  shortDesc: p.shortDesc,
}));
---

<PageLayout meta={meta} schemas={schemas} breadcrumbs={breadcrumbs}>
  {/* 2. Hero */}
  <Hero
    title={`${pillar.name} in San Diego County`}
    subtitle={pillar.shortDesc}
    variant="compact"
    showTrustCard={false}
    showStatChips={false}
    showCTAs={true}
    backgroundImage={heroImage.src}
    backgroundImageAlt={heroImage.alt}
  />

  {/* 3. TrustBar */}
  <TrustBar />

  {/* 4. Contextual CTA Band — bg-surface-subtle */}
  <Section bg="subtle" spacing="none">
    <ContextualCTABand
      heading={`Get a Fast Callback for ${pillar.name}`}
    />
  </Section>

  {/* 5. Service Overview — bg-white */}
  <Section bg="white">
    <ServiceIntroSection
      heading={`${pillar.name} — Service Overview`}
      introParagraph={pillar.shortDesc}
      bullets={overviewBullets}
    />
  </Section>

  {/* 6. What's Included — bg-surface-subtle */}
  <Section bg="subtle">
    <WhatsIncludedSection
      bullets={includedBullets}
      serviceImg={serviceImg}
      imgFallbackLabel={`Professional ${pillar.name.toLowerCase()} from licensed electricians.`}
    />
  </Section>

  {/* 7. Process Steps — bg-white (omitted if no steps) */}
  {processSteps.length > 0 && (
    <Section bg="white">
      <ProcessStepsSection
        heading="Our Process"
        steps={processSteps}
      />
    </Section>
  )}

  {/* 8. Pricing Factors — bg-surface-subtle */}
  <Section bg="subtle">
    <PricingFactorsSection
      heading="Pricing Factors"
      factors={pricingFactors}
    />
  </Section>

  {/* 9. Service Areas Served — bg-white */}
  <Section bg="white">
    <AreaLinksSection
      heading="Service Areas Served"
      subtitle={`We provide ${pillar.name.toLowerCase()} across San Diego County.`}
      links={serviceAreaLinks}
    />
  </Section>

  {/* 10. Related Services — bg-surface-subtle */}
  {relatedServiceItems.length > 0 && (
    <Section bg="subtle">
      <RelatedServicesSection
        heading="Related Services"
        services={relatedServiceItems}
      />
    </Section>
  )}

  {/* 11. FAQs — bg-white */}
  {faqItems.length > 0 && (
    <Section bg="white">
      <div class="mx-auto max-w-3xl">
        <FAQAccordion faqs={faqItems} heading={`${pillar.name} FAQs`} />
      </div>
    </Section>
  )}

  {/* 12. Testimonial Block — dark navy (self-contained) */}
  <TestimonialBlock serviceTag={pillar.slug} />

  {/* 13. CTA Section — dark navy (self-contained) */}
  <CTASection subtitle={`Contact Wheyland Electric today for a free estimate on ${pillar.name.toLowerCase()}.`} />
</PageLayout>
