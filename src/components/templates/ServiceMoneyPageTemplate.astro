---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../sections/Hero.astro';
import TrustBar from '../sections/TrustBar.astro';
import FAQAccordion from '../sections/FAQAccordion.astro';
import CTASection from '../sections/CTASection.astro';
import Section from '../ui/Section.astro';
import Card from '../ui/Card.astro';
import ServiceIntroSection from '../sections/ServiceIntroSection.astro';
import WhatsIncludedSection from '../sections/WhatsIncludedSection.astro';
import ProcessStepsSection from '../sections/ProcessStepsSection.astro';
import PricingFactorsSection from '../sections/PricingFactorsSection.astro';
import ContextualCTABand from '../sections/ContextualCTABand.astro';
import type { FAQ, PageMeta, BreadcrumbItem, ServicePillar, City } from '../../types';
import type { ServiceHeroImage } from '../../data/serviceHeroImages';

/**
 * ServiceMoneyPageTemplate — fixed-structure template for all 56 money pages.
 *
 * FIXED SECTION ORDER (no conditional visual logic):
 * 1. Breadcrumbs (PageLayout)
 * 2. Hero — dark overlay, H1, subtitle, two CTA buttons
 * 3. TrustBar
 * 4. Intro Section — bg-white
 * 5. What's Included — bg-surface-subtle
 * 6. Process Steps — bg-white (omitted only if no steps data)
 * 7. Pricing Factors — bg-surface-subtle
 * 8. Mid-Page CTA Band — bg-white
 * 9. Related Services — bg-surface-subtle (omitted only if no related pillars)
 * 10. FAQs — bg-white (omitted only if no FAQs)
 * 11. Bottom CTA — dark navy (CTASection)
 * 12. Also Serving — bg-surface-subtle (omitted only if no nearby cities)
 */

interface Props {
  meta: PageMeta;
  schemas: Record<string, unknown>[];
  breadcrumbs: BreadcrumbItem[];
  heroTitle: string;
  heroSubtitle: string;
  backgroundImage?: string;
  backgroundImageAlt?: string;
  cityName: string;
  pillarName: string;
  citySlug: string;
  pillarSlug: string;
  overviewBullets: string[];
  includedBullets: string[];
  serviceImg?: ServiceHeroImage;
  processSteps: { step: number | string; title: string; description: string }[];
  pricingFactors: string[];
  faqs: FAQ[];
  relatedPillars: Pick<ServicePillar, 'name' | 'slug' | 'shortDesc'>[];
  nearbyCities: Pick<City, 'slug' | 'name'>[];
}

const {
  meta,
  schemas,
  breadcrumbs,
  heroTitle,
  heroSubtitle,
  backgroundImage,
  backgroundImageAlt,
  cityName,
  pillarName,
  citySlug,
  pillarSlug,
  overviewBullets,
  includedBullets,
  serviceImg,
  processSteps,
  pricingFactors,
  faqs,
  relatedPillars,
  nearbyCities,
} = Astro.props;

const cappedFaqs = faqs.slice(0, 10);
---

<PageLayout meta={meta} schemas={schemas} breadcrumbs={breadcrumbs}>
  {/* 2. Hero */}
  <Hero
    title={heroTitle}
    subtitle={heroSubtitle}
    variant="compact"
    showTrustCard={false}
    showStatChips={false}
    showCTAs={true}
    backgroundImage={backgroundImage}
    backgroundImageAlt={backgroundImageAlt}
  />

  {/* 3. TrustBar */}
  <TrustBar />

  {/* 4. Intro Section — bg-white */}
  <Section bg="white">
    <ServiceIntroSection
      heading={`Professional ${pillarName} in ${cityName}`}
      bullets={overviewBullets}
    />
  </Section>

  {/* 5. What's Included — bg-surface-subtle */}
  <Section bg="subtle">
    <WhatsIncludedSection
      bullets={includedBullets}
      serviceImg={serviceImg}
      imgFallbackLabel={`${pillarName} in ${cityName}`}
    />
  </Section>

  {/* 6. Process Steps — bg-white (omitted if no steps) */}
  {processSteps.length > 0 && (
    <Section bg="white">
      <ProcessStepsSection
        heading={`How ${pillarName} Works in ${cityName}`}
        steps={processSteps}
      />
    </Section>
  )}

  {/* 7. Pricing Factors — bg-surface-subtle */}
  <Section bg="subtle">
    <PricingFactorsSection
      heading={`What Affects the Cost of ${pillarName} in ${cityName}`}
      factors={pricingFactors}
    />
  </Section>

  {/* 8. Mid-Page CTA Band — bg-white */}
  <Section bg="white" spacing="hero-tight">
    <ContextualCTABand
      heading={`Get a precise estimate for your ${cityName} project.`}
    />
  </Section>

  {/* 9. Related Services — bg-surface-subtle */}
  {relatedPillars.length > 0 && (
    <Section bg="subtle">
      <h2 class="mb-6 font-heading text-2xl font-bold text-brand-slate md:text-3xl">You May Also Need</h2>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {relatedPillars.map((related) => (
          <Card href={`/${citySlug}/${related.slug}/`} hoverable={true}>
            <h3 class="mb-2 font-semibold text-brand-slate">{related.name} in {cityName}</h3>
            <p class="text-sm text-text-muted">{related.shortDesc}</p>
          </Card>
        ))}
      </div>
    </Section>
  )}

  {/* 10. FAQs — bg-white */}
  {cappedFaqs.length > 0 && (
    <Section bg="white">
      <div class="mx-auto max-w-3xl">
        <FAQAccordion faqs={cappedFaqs} heading={`${pillarName} in ${cityName} — FAQs`} />
      </div>
    </Section>
  )}

  {/* 11. Bottom CTA — dark navy */}
  <CTASection
    title={`Need ${pillarName} in ${cityName}?`}
    subtitle={`Contact Wheyland Electric today for a free estimate. Licensed, bonded & insured with a 1-year labor warranty.`}
    cityName={cityName}
  />

  {/* 12. Also Serving — bg-surface-subtle */}
  {nearbyCities.length > 0 && (
    <Section bg="subtle">
      <h2 class="mb-4 text-center font-heading text-xl font-bold text-brand-slate">Also Serving</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {nearbyCities.map((nearby) => (
          <a
            href={`/${nearby.slug}/${pillarSlug}/`}
            class="rounded-lg bg-white px-4 py-2 text-sm font-medium text-brand-slate shadow-sm transition-shadow hover:text-brand-teal hover:shadow-md"
          >
            {pillarName} in {nearby.name}
          </a>
        ))}
      </div>
    </Section>
  )}

  {/* Navigation links */}
  <Section bg="white" spacing="hero-tight">
    <div class="flex flex-wrap justify-center gap-4 text-sm">
      <a href={`/${citySlug}/`} class="text-brand-teal transition-colors hover:text-brand-slate">
        ← All services in {cityName}
      </a>
      <span class="text-surface-warm">|</span>
      <a href={`/services/${pillarSlug}/`} class="text-brand-teal transition-colors hover:text-brand-slate">
        {pillarName} across all areas →
      </a>
    </div>
  </Section>
</PageLayout>
