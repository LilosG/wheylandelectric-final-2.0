---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../sections/Hero.astro';
import TrustBar from '../sections/TrustBar.astro';
import ServiceGrid from '../sections/ServiceGrid.astro';
import FAQAccordion from '../sections/FAQAccordion.astro';
import CTASection from '../sections/CTASection.astro';
import HOAOfferBlock from '../sections/HOAOfferBlock.astro';
import GBPEmbed from '../sections/GBPEmbed.astro';
import Section from '../ui/Section.astro';
import ContextualCTABand from '../sections/ContextualCTABand.astro';
import TestimonialBlock from '../sections/TestimonialBlock.astro';
import AreaLinksSection from '../sections/AreaLinksSection.astro';
import type { City, FAQ, PageMeta, BreadcrumbItem, ServicePillar } from '../../types';
import { getPublishedCities } from '../../data/cities';

/**
 * CityLandingTemplate — fixed-structure template for all 7 city pages.
 *
 * FIXED SECTION ORDER (no conditional visual logic):
 * 1. Breadcrumbs (PageLayout)
 * 2. Hero
 * 3. TrustBar
 * 4. Contextual CTA Band — bg-surface-subtle (compact)
 * 5. Why Choose / Intro Content — bg-white
 * 6. Services Grid — bg-surface-subtle
 * 7. Neighborhoods — bg-white (omitted if no neighborhood data)
 * 8. Local Electrical Context — bg-surface-subtle (omitted if no localCues)
 * 9. HOA Block — bg-warm
 * 10. FAQs — bg-white (omitted if no FAQs)
 * 11. Nearby Cities — bg-surface-subtle (omitted if no nearby cities)
 * 12. CTA Section — dark navy (self-contained)
 * 13. GBP Embed — bg-white
 */

interface Props {
  city: City;
  services: ServicePillar[];
  nearbyCities: City[];
  cityFaqs: FAQ[];
  meta: PageMeta;
  breadcrumbs: BreadcrumbItem[];
  cityHero: {
    src: string;
    alt: string;
  };
  schemas: Record<string, unknown>[];
}

const { city, services, nearbyCities, cityFaqs, meta, breadcrumbs, cityHero, schemas } = Astro.props;

const cappedFaqs = cityFaqs.slice(0, 10);
const cappedProofPoints = (city.localProofPoints || []).slice(0, 6);
const cappedLocalCues = (city.localCues || []).slice(0, 6);
const cappedNeighborhoods = (city.neighborhoodSpotlights || []).slice(0, 9);
const publishedCitySlugs = new Set(getPublishedCities().map((c) => c.slug));

const slugifyName = (name: string): string =>
  name.toLowerCase().replace(/\s+/g, '-');

const featuredServiceLinks = services.slice(0, 6).map((service) => ({
  label: `${service.name} in ${city.name}`,
  href: `/${city.slug}/${service.slug}/`,
}));
---

<PageLayout meta={meta} schemas={schemas} breadcrumbs={breadcrumbs}>
  {/* 2. Hero */}
  <Hero
    title={`Electrician in ${city.name}, CA`}
    subtitle={`Licensed, bonded & insured electrical services for homes and businesses in ${city.name}.`}
    variant="compact"
    showTrustCard={false}
    showStatChips={false}
    showCTAs={true}
    backgroundImage={cityHero.src}
    backgroundImageAlt={cityHero.alt}
    imagePosition={city.slug === 'carlsbad' ? 'top' : 'bottom'}
  />

  {/* 3. TrustBar */}
  <TrustBar />

  {/* 4. Why Choose / Intro Content — bg-white */}
  <Section bg="white">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-4 font-heading text-2xl font-bold text-brand-slate md:text-3xl">
        Why Homeowners in {city.name} Choose Wheyland Electric
      </h2>
      <p class="mb-6 text-base leading-relaxed text-text-muted md:text-lg">{city.localIntroSeed}</p>
      {cappedProofPoints.length > 0 && (
        <ul class="mt-6 grid grid-cols-1 gap-3 md:grid-cols-2">
          {cappedProofPoints.map((point) => (
            <li class="flex items-start gap-3 rounded-lg bg-surface-subtle p-4">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm text-text-muted">{point}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </Section>

  {/* 6. Services Grid — bg-surface-subtle */}
  <Section bg="subtle">
    <ServiceGrid
      services={services}
      citySlug={city.slug}
      heading={`Electrical Services in ${city.name}`}
      subtitle={`Explore service pages tailored to ${city.name}.`}
    />
  </Section>

  {/* 7. Mid-Page CTA Band */}
  <ContextualCTABand
    heading={`Need a licensed electrician in ${city.name}?`}
  />

  {/* 7. Neighborhoods — bg-white */}
  {cappedNeighborhoods.length > 0 && (
    <Section bg="white">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-5 font-heading text-2xl font-bold text-brand-slate md:text-3xl">Neighborhoods We Serve</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {cappedNeighborhoods.map((item) => {
            const neighborhoodSlug = slugifyName(item.name);
            const hasPage = publishedCitySlugs.has(neighborhoodSlug);
            return hasPage ? (
              <a
                href={`/${neighborhoodSlug}/`}
                class="block rounded-xl border border-brand-teal/30 bg-white p-4 shadow-sm transition-colors hover:border-brand-teal hover:shadow-md"
              >
                <h3 class="text-sm font-semibold text-brand-teal">{item.name}</h3>
                <p class="mt-2 text-sm text-text-muted">{item.blurb}</p>
                <span class="mt-3 inline-block text-xs font-semibold text-brand-teal">View service area &rarr;</span>
              </a>
            ) : (
              <div class="rounded-xl border border-surface-subtle bg-white p-4 shadow-sm">
                <h3 class="text-sm font-semibold text-brand-slate">{item.name}</h3>
                <p class="mt-2 text-sm text-text-muted">{item.blurb}</p>
              </div>
            );
          })}
        </div>
      </div>
    </Section>
  )}

  {/* 8. Local Signals + Internal Links — bg-surface-subtle */}
  <Section bg="subtle">
    <div class="mx-auto max-w-5xl">
      {cappedLocalCues.length > 0 && (
        <div class="text-center">
          <h2 class="font-heading text-2xl font-bold text-brand-slate md:text-3xl">
            Local Landmarks and Areas We Commonly Serve in {city.name}
          </h2>
          <p class="mx-auto mt-3 max-w-3xl text-text-muted">
            Our electricians are familiar with homes, businesses, and HOA communities near these {city.name} landmarks and corridors.
          </p>
          <ul class="mt-6 flex flex-wrap justify-center gap-3">
            {cappedLocalCues.map((cue) => (
              <li class="rounded-full border border-brand-teal/30 bg-white px-4 py-2 text-sm font-medium text-brand-slate">
                {cue}
              </li>
            ))}
          </ul>
        </div>
      )}

      {featuredServiceLinks.length > 0 && (
        <div class="mt-10">
          <h3 class="text-center font-heading text-xl font-bold text-brand-slate">Popular Electrical Services in {city.name}</h3>
          <div class="mt-4 flex flex-wrap justify-center gap-x-4 gap-y-2 text-sm">
            {featuredServiceLinks.map((serviceLink) => (
              <a href={serviceLink.href} class="font-semibold text-brand-teal transition-colors hover:text-brand-slate">
                {serviceLink.label}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </Section>

  {/* 9. HOA Block — bg-warm */}
  <Section bg="warm">
    <HOAOfferBlock cityName={city.name} />
  </Section>

  {/* 10. Testimonials — dark navy (self-contained) */}
  <TestimonialBlock heading="What Our Customers Say" />

  {/* 11. FAQs — bg-white */}
  {cappedFaqs.length > 0 && (
    <Section bg="white">
      <div class="mx-auto max-w-3xl">
        <FAQAccordion faqs={cappedFaqs} heading={`${city.name} Electrician FAQs`} />
      </div>
    </Section>
  )}

  {/* 12. Nearby Cities — bg-surface-subtle */}
  {nearbyCities.length > 0 && (
    <Section bg="subtle">
      <div class="mx-auto max-w-4xl text-center">
        <h2 class="text-xl font-heading font-bold text-brand-slate mb-2">Nearby Service Areas</h2>
        <p class="text-text-muted text-sm mb-6">We also serve these North County San Diego communities</p>
        <div class="flex flex-wrap justify-center gap-3">
          {nearbyCities.map((c) => (
            
              href={`/${c.slug}/`}
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-white rounded-full border border-brand-teal/30 text-sm font-semibold text-brand-slate hover:border-brand-teal hover:text-brand-teal transition-colors shadow-sm"
            >
              <svg class="w-3.5 h-3.5 text-brand-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              {c.name}, CA
            </a>
          ))}
          
            href="/service-areas/"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-teal rounded-full text-sm font-semibold text-white hover:bg-brand-teal-light transition-colors shadow-sm"
          >
            All Service Areas &rarr;
          </a>
        </div>
      </div>
    </Section>
  )}

  {/* 12. CTA Section — dark navy (self-contained) */}
  <CTASection cityName={city.name} />

  {/* 13. GBP Embed — bg-white */}
  <Section bg="white">
    <div class="mx-auto max-w-4xl">
      <GBPEmbed heading={`Find Wheyland Electric Near ${city.name}`} />
    </div>
  </Section>
</PageLayout>
