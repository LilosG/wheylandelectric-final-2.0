---
import PageLayout from '../layouts/PageLayout.astro';
import TestimonialBlock from '../components/sections/TestimonialBlock.astro';
import CTASection from '../components/sections/CTASection.astro';
import Section from '../components/ui/Section.astro';
import { generateMeta } from '../lib/seo';
import { site } from '../data/site';

const meta = generateMeta({
  title: 'Customer Reviews | Wheyland Electric',
  description: 'Read what customers say about Wheyland Electric. 5-star rated electrician serving San Diego County since 2008.',
  path: '/reviews/',
});
---
<PageLayout meta={meta} breadcrumbs={[{ label: 'Reviews', href: '/reviews/' }]}>
  <Section bg="white">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-brand-slate mb-6">Customer Reviews</h1>
      <p class="text-lg text-text-muted mb-8">
        We are proud of the relationships we build with every customer. Our reputation is built on honest work, fair pricing, and standing behind every project.
      </p>
      <a
        href={site.gbp.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-brand-gold hover:bg-brand-gold-hover text-white font-semibold px-6 py-3 rounded-lg transition-colors"
      >
        Read Our Reviews on Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </Section>

  <TestimonialBlock heading="What Our Customers Say" />

  <CTASection />
</PageLayout>
