---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import CityGrid from '../../components/sections/CityGrid.astro';
import CTASection from '../../components/sections/CTASection.astro';
import MapSection from '../../components/sections/MapSection.astro';
import Section from '../../components/ui/Section.astro';
import { generateMeta } from '../../lib/seo';
import { getPublishedCities } from '../../data/cities';
import { site } from '../../data/site';
import { getPageHeroImage } from '../../data/heroImages';

const meta = generateMeta({
  title: 'Service Areas | Electrician in San Diego County',
  description: 'Wheyland Electric serves Carlsbad, Encinitas, Oceanside, San Marcos, Vista, Del Mar, Solana Beach, Rancho Santa Fe and all of San Diego County.',
  path: '/service-areas/',
});

const cities = getPublishedCities();
const serviceAreasHero = getPageHeroImage('service-areas');
---
<PageLayout meta={meta} breadcrumbs={[{ label: 'Service Areas', href: '/service-areas/' }]}>
  <Hero
    title="Areas We Serve"
    subtitle="Carlsbad-based, serving all of San Diego County with professional electrical services since 2008."
    showCTAs={false}
    variant="compact"
    showTrustCard={false}
    showStatChips={false}
    backgroundImage={serviceAreasHero.src}
  />

  <TrustBar />

  <CityGrid cities={cities} title="North County San Diego Service Areas" />

  <Section bg="subtle">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-slate mb-6">Serving San Diego County & Beyond</h2>
      <p class="text-text-muted leading-relaxed mb-4">
        While we focus on North County San Diego, Wheyland Electric serves customers throughout{' '}
        {site.serviceRadiusCounties.join(', ')}. Whether you are in Carlsbad or anywhere in the greater San Diego area, our licensed team is ready to help.
      </p>
      <p class="text-text-muted leading-relaxed">
        Do not see your city listed? Call us at{' '}
        <a href={`tel:${site.nap.phoneTel}`} class="text-brand-teal font-semibold hover:text-brand-slate transition-colors">
          {site.nap.phone}
        </a>{' '}
        — we likely serve your area.
      </p>
    </div>
  </Section>

  <MapSection />

  <CTASection />
</PageLayout>
