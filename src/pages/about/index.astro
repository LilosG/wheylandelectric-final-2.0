---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Section from '../../components/ui/Section.astro';
import { aboutPageMeta } from '../../lib/seo';
import { breadcrumbSchemaNode } from '../../lib/schema/breadcrumb';
import { graphSchema, webPageSchemaNode } from '../../lib/schema/graph';
import { site } from '../../data/site';
import { getPageHeroImage } from '../../data/heroImages';

const aboutHero = getPageHeroImage('about');

const meta = aboutPageMeta();
---
<PageLayout
  meta={meta}
  schemas={[
    graphSchema([
      webPageSchemaNode({
        type: 'AboutPage',
        path: '/about/',
        name: meta.title,
        description: meta.description,
      }),
      breadcrumbSchemaNode([{ label: 'About', href: '/about/' }], '/about/'),
    ]),
  ]}
  breadcrumbs={[{ label: 'About', href: '/about/' }]}
>
  <Hero
    title="About Wheyland Electric"
    subtitle="Family-owned. Carlsbad-based. Serving San Diego County since 2008."
    showCTAs={false}
    variant="compact"
    showTrustCard={false}
    showStatChips={false}
    backgroundImage={aboutHero.src}
  />

  <TrustBar />

  <!-- Owner Bio -->
  <Section bg="white">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-slate mb-6">Meet {site.owner.name}</h2>
        <p class="text-lg text-brand-teal font-semibold mb-4 italic">{site.owner.generation}</p>
        {site.owner.bio.map((paragraph) => (
          <p class="text-text-muted leading-relaxed mb-4">{paragraph}</p>
        ))}
      </div>
      <div class="rounded-xl overflow-hidden shadow-lg">
        <img
          src="/images/about/wheyland-electric-family-portrait-carlsbad.webp"
          alt="Tim Wheyland and the Wheyland Electric family in Carlsbad CA"
          width="800"
          height="628"
          class="w-full h-auto object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </Section>

  <!-- Business Philosophy -->
  <Section bg="subtle">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-slate mb-6">Our Philosophy</h2>
      <blockquote class="text-xl md:text-2xl text-brand-slate font-heading italic mb-8">
        "{site.businessModelLine}"
      </blockquote>
      <p class="text-text-muted leading-relaxed mb-6">
        Wheyland Electric was founded on a simple principle: do the job right, treat customers with respect, and stand behind every project. As a family-owned business based in Carlsbad, we are big enough to handle any project yet small enough to care about every detail.
      </p>
    </div>
  </Section>

  <!-- Customer Pledge -->
  <Section bg="white">
    <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-slate mb-8 text-center">Our Pledge to You</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {site.pledge.map((pledgeItem) => (
        <div class="flex items-start gap-4 bg-surface-subtle rounded-xl p-6">
          <svg class="w-6 h-6 text-brand-teal shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <p class="text-text-muted leading-relaxed">{pledgeItem}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Warranty -->
  <Section bg="subtle">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-slate mb-6">1-Year Labor Warranty</h2>
      <p class="text-text-muted leading-relaxed mb-6">{site.warranty}</p>
      <a href="/about/licenses/" class="text-brand-teal hover:text-brand-slate font-semibold transition-colors underline">
        View our licenses and credentials
      </a>
    </div>
  </Section>

  <CTASection />
</PageLayout>
