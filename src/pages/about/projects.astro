---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import ProjectGallery from '../../components/sections/ProjectGallery.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Section from '../../components/ui/Section.astro';
import { generateMeta } from '../../lib/seo';
import { getPageHeroImage } from '../../data/heroImages';

const projectsHero = getPageHeroImage('projects');

const meta = generateMeta({
  title: 'Our Projects | Wheyland Electric',
  description: 'View completed electrical projects by Wheyland Electric across San Diego County. Residential, commercial, and HOA work.',
  path: '/about/projects/',
});
---
<PageLayout
  meta={meta}
  breadcrumbs={[
    { label: 'About', href: '/about/' },
    { label: 'Projects', href: '/about/projects/' },
  ]}
>
  <Hero
    title="Our Projects"
    subtitle="A look at the electrical work we have completed for homeowners, businesses, and HOA communities across San Diego County."
    compact
    showTrustCard={false}
    showStatChips={false}
    showCTAs={false}
    backgroundImage={projectsHero.src}
    imagePosition="center"
  />

  <Section bg="white" size="tight">
    <ProjectGallery heading="" />
  </Section>

  <TrustBar />

  <CTASection />
</PageLayout>
