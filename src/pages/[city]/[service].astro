---
import ServiceMoneyPageTemplate from '../../components/templates/ServiceMoneyPageTemplate.astro';
import { moneyPageMeta } from '../../lib/seo';
import { serviceSchema } from '../../lib/schema/service';
import { faqPageSchema } from '../../lib/schema/faq';
import { breadcrumbSchema } from '../../lib/schema/breadcrumb';
import { getPublishedCities, getCityBySlug } from '../../data/cities';
import { getPublishedPillars, getPillarBySlug } from '../../data/services';
import { getCityServiceContent } from '../../data/cityServiceContent';
import type { City, ServicePillar, FAQ } from '../../types';

import { getServiceHeroImage } from '../../data/serviceHeroImages';
import { getServiceHeroImage as getHeroServiceImage } from '../../data/heroImages';

export function getStaticPaths() {
  const cities = getPublishedCities();
  const pillars = getPublishedPillars();
  const paths: {
    params: { city: string; service: string };
    props: { city: City; pillar: ServicePillar };
  }[] = [];

  for (const city of cities) {
    for (const pillar of pillars) {
      paths.push({
        params: { city: city.slug, service: pillar.slug },
        props: { city, pillar },
      });
    }
  }
  return paths;
}

interface Props {
  city: City;
  pillar: ServicePillar;
}

const { city, pillar } = Astro.props;
const heroImage = getHeroServiceImage(pillar.slug);
const serviceImg = getServiceHeroImage({
  serviceSlug: pillar.slug,
  citySlug: city.slug,
  variant: 'money',
});
const meta = moneyPageMeta(pillar.name, city.name, city.slug, pillar.slug);
const breadcrumbs = [
  { label: city.name, href: `/${city.slug}/` },
  { label: pillar.name, href: `/${city.slug}/${pillar.slug}/` },
];

const cityService = getCityServiceContent(city.slug, pillar.slug);

const h1Tagline = pillar.h1TaglineByCity?.[city.slug] ?? `${pillar.name} in ${city.name}, CA`;

const relatedPillars = (pillar.relatedServiceSlugs || pillar.relatedServices)
  .map((slug) => getPillarBySlug(slug))
  .filter((p): p is ServicePillar => p !== undefined && p.publish);

const nearbyCities = city.nearbyCities
  .map((slug) => getCityBySlug(slug))
  .filter((c): c is City => c !== undefined && c.publish);

const defaultOverviewBullets = [
  `Code-compliant ${pillar.name.toLowerCase()} planning in ${city.name}.`,
  'Scope-first recommendations before installation begins.',
  'Clean execution with final testing and handoff notes.',
  'Permit coordination support when required by scope.',
  'Focused troubleshooting to avoid unnecessary replacements.',
  'Options tailored to current needs and likely future loads.',
];

const overviewBullets = (cityService?.introBullets?.length ? cityService.introBullets : pillar.overviewBullets || []).slice(0, 6);
const includedItems = (cityService?.includedItems?.length ? cityService.includedItems : pillar.includedItems || pillar.includedBullets).slice(0, 8);
const processSteps = (cityService?.processSteps?.length ? cityService.processSteps : pillar.processSteps).slice(0, 6);
const pricingFactors = (cityService?.pricingFactors?.length ? cityService.pricingFactors : pillar.pricingFactors).slice(0, 8);

const moneyPageFaqs: FAQ[] = (cityService?.faqs?.length ? cityService.faqs : pillar.faqs).slice(0, 10);

const heroSubtitle = (overviewBullets.length > 0 ? overviewBullets : defaultOverviewBullets).slice(0, 2).join(' ');
---

<ServiceMoneyPageTemplate
  meta={meta}
  schemas={[
    serviceSchema(
      pillar.name,
      pillar.shortDesc,
      `/${city.slug}/${pillar.slug}/`,
      `${city.name}, CA`
    ),
    faqPageSchema(moneyPageFaqs),
    breadcrumbSchema(breadcrumbs),
  ]}
  breadcrumbs={breadcrumbs}
  heroTitle={h1Tagline}
  heroSubtitle={heroSubtitle}
  backgroundImage={heroImage.src}
  backgroundImageAlt={heroImage.alt}
  cityName={city.name}
  pillarName={pillar.name}
  citySlug={city.slug}
  pillarSlug={pillar.slug}
  overviewBullets={overviewBullets.length > 0 ? overviewBullets : defaultOverviewBullets}
  includedBullets={includedItems}
  serviceImg={serviceImg}
  processSteps={processSteps}
  pricingFactors={pricingFactors}
  faqs={moneyPageFaqs}
  relatedPillars={relatedPillars}
  nearbyCities={nearbyCities}
/>
