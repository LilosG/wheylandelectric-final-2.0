---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import CTABlock from '../../components/sections/CTABlock.astro';
import FAQAccordion from '../../components/sections/FAQAccordion.astro';
import CTASection from '../../components/sections/CTASection.astro';
import ServiceDetailSplit from '../../components/sections/ServiceDetailSplit.astro';
import Section from '../../components/ui/Section.astro';
import Button from '../../components/ui/Button.astro';
import { moneyPageMeta } from '../../lib/seo';
import { serviceSchema } from '../../lib/schema/service';
import { faqPageSchema } from '../../lib/schema/faq';
import { breadcrumbSchema } from '../../lib/schema/breadcrumb';
import { getPublishedCities, getCityBySlug } from '../../data/cities';
import { getPublishedPillars, getPillarBySlug } from '../../data/services';
import { site } from '../../data/site';
import type { City, ServicePillar, FAQ } from '../../types';

// Map service slugs to their primary hero images
const serviceImages: Record<string, { src: string; alt: string; width: number; height: number }> = {
  'ev-charger-installation': {
