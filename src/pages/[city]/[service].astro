---
import ServiceMoneyPageTemplate from '../../components/templates/ServiceMoneyPageTemplate.astro';
import CTABlock from '../../components/sections/CTABlock.astro';
import CTASection from '../../components/sections/CTASection.astro';
import LeadCaptureSection from '../../components/sections/LeadCaptureSection.astro';
import Section from '../../components/ui/Section.astro';
import Button from '../../components/ui/Button.astro';
import QuickEstimateForm from '../../components/forms/QuickEstimateForm.astro';
import { moneyPageMeta } from '../../lib/seo';
import { serviceSchema } from '../../lib/schema/service';
import { faqPageSchema } from '../../lib/schema/faq';
import { breadcrumbSchema } from '../../lib/schema/breadcrumb';
import { getPublishedCities, getCityBySlug } from '../../data/cities';
import { getPublishedPillars, getPillarBySlug } from '../../data/services';
import { site } from '../../data/site';
import type { City, ServicePillar, FAQ } from '../../types';

import { getServiceHeroImage } from '../../data/serviceHeroImages';

export function getStaticPaths() {
  const cities = getPublishedCities();
  const pillars = getPublishedPillars();
  const paths: {
    params: { city: string; service: string };
    props: { city: City; pillar: ServicePillar };
  }[] = [];

  for (const city of cities) {
    for (const pillar of pillars) {
      paths.push({
        params: { city: city.slug, service: pillar.slug },
        props: { city, pillar },
      });
    }
  }
  return paths;
}

interface Props {
  city: City;
  pillar: ServicePillar;
}

function trimHeroSubtitleCopy(
  copy: string,
  {
    minChars = 140,
    maxChars = 190,
    maxSentences = 2,
  }: { minChars?: number; maxChars?: number; maxSentences?: number } = {}
) {
  const normalized = copy.replace(/\s+/g, ' ').trim();
  if (!normalized) return '';

  const sentences = normalized.split(/(?<=[.!?])\s+/).filter(Boolean);
  if (sentences.length === 0) return normalized;

  let selected = '';
  for (const sentence of sentences) {
    const candidate = selected ? `${selected} ${sentence}` : sentence;
    const selectedCount = selected ? selected.split(/(?<=[.!?])\s+/).length : 0;

    if (selectedCount + 1 > maxSentences) break;

    if (candidate.length <= maxChars || selected.length < minChars) {
      selected = candidate;
      if (selected.length >= minChars && selectedCount + 1 >= maxSentences) break;
      continue;
    }
    break;
  }

  const candidate = selected || sentences[0] || normalized;
  if (candidate.length <= maxChars) return candidate;

  const truncated = candidate.slice(0, maxChars + 1);
  const softCut = truncated.lastIndexOf(' ');
  const cutoff = softCut > Math.floor(maxChars * 0.75) ? softCut : maxChars;

  return `${candidate.slice(0, cutoff).trimEnd()}…`;
}

const { city, pillar } = Astro.props;
const serviceImg = getServiceHeroImage({
  serviceSlug: pillar.slug,
  citySlug: city.slug,
  variant: 'money',
});
const meta = moneyPageMeta(pillar.name, city.name, city.slug, pillar.slug);
const breadcrumbs = [
  { label: city.name, href: `/${city.slug}/` },
  { label: pillar.name, href: `/${city.slug}/${pillar.slug}/` },
];

const fullLocalizedIntro =
  pillar.localizedIntroSeedByCity[city.slug] ??
  `Wheyland Electric provides professional ${pillar.name.toLowerCase()} in ${city.name}, CA. Our licensed team delivers reliable, code-compliant electrical work backed by our 1-year labor warranty.`;
const localizedIntro = trimHeroSubtitleCopy(fullLocalizedIntro);

const h1Tagline = pillar.h1TaglineByCity?.[city.slug] ?? `${pillar.name} in ${city.name}, CA`;

const relatedPillars = pillar.relatedServices
  .map((slug) => getPillarBySlug(slug))
  .filter((p): p is ServicePillar => p !== undefined && p.publish);

const nearbyCities = city.nearbyCities
  .map((slug) => getCityBySlug(slug))
  .filter((c): c is City => c !== undefined && c.publish);

// Generate city-specific FAQs — city-scoped questions + pillar FAQs
const citySpecificFaqs: FAQ[] = [
  {
    question: `What is the cost of ${pillar.name.toLowerCase()} in ${city.name}?`,
    answer: `The cost of ${pillar.name.toLowerCase()} in ${city.name} depends on several factors including ${pillar.pricingFactors.slice(0, 3).join(', ').toLowerCase()}. Contact us at (858) 663-5564 for a free, no-obligation estimate tailored to your project.`,
  },
  {
    question: `Is Wheyland Electric licensed to perform ${pillar.name.toLowerCase()} in ${city.name}?`,
    answer: `Yes. Wheyland Electric holds California Contractor License #940291 and is fully licensed, bonded, and insured to perform ${pillar.name.toLowerCase()} in ${city.name} and throughout San Diego County. All work is backed by our 1-year labor warranty on workmanship.`,
  },
  {
    question: `Does Wheyland Electric handle permits for ${pillar.name.toLowerCase()} in ${city.name}?`,
    answer: `Yes. We handle the complete permit process with the City of ${city.name} building department including application, plan submission where required, and inspection scheduling. You do not need to manage any paperwork.`,
  },
  {
    question: `How long does ${pillar.name.toLowerCase()} take in ${city.name}?`,
    answer: `Timeline varies by project scope. Most residential ${pillar.name.toLowerCase()} projects in ${city.name} are completed in one visit. More complex work involving panel upgrades or permit inspections may span 1–2 weeks from approval to final sign-off. We provide a clear timeline during your free estimate.`,
  },
];
// Combine with pillar-level FAQs, deduplicate, ensure 6+ total
const moneyPageFaqs: FAQ[] = [
  ...citySpecificFaqs,
  ...pillar.faqs.slice(0, Math.max(2, 6 - citySpecificFaqs.length)),
];
---

<ServiceMoneyPageTemplate
  meta={meta}
  schemas={[
    serviceSchema(
      pillar.name,
      pillar.shortDesc,
      `/${city.slug}/${pillar.slug}/`,
      `${city.name}, CA`
    ),
    faqPageSchema(moneyPageFaqs),
    breadcrumbSchema(breadcrumbs),
  ]}
  breadcrumbs={breadcrumbs}
  heroTitle={h1Tagline}
  heroSubtitle={localizedIntro}
  heroShowCTAs={false}
  imageSource="service"
  imageKey={pillar.slug}
  showTopTrustBar={false}
  inlineCtaSectionClass="pt-8 md:pt-12"
  detailHeading={`Professional ${pillar.name} in ${city.name}`}
  detailBody={`When you choose Wheyland Electric for ${pillar.name.toLowerCase()} in ${city.name}, you get a team that knows this community and delivers work you can trust. We handle every aspect of the job — from initial assessment through permitting, installation, and final inspection.`}
  includedBullets={pillar.includedBullets}
  serviceImg={serviceImg}
  fallbackImageLabel={`${pillar.name} in ${city.name}`}
  processHeading={`How ${pillar.name} Works in ${city.name}`}
  processSteps={pillar.processSteps}
  processStepCardClass="flex items-start gap-4 bg-white rounded-xl shadow-sm p-6"
  processDescriptionClass="text-text-muted text-sm"
  pricingHeading={`What Affects the Cost of ${pillar.name} in ${city.name}`}
  pricingIntro={`Every ${pillar.name.toLowerCase()} project in ${city.name} is unique. Here are the factors that typically influence pricing:`}
  pricingFactors={pillar.pricingFactors}
  showTrustBarAfterPricing
  relatedSectionBg="subtle"
  faqSectionBg="white"
  faqHeading={`${pillar.name} in ${city.name} — FAQs`}
  faqs={moneyPageFaqs}
>
  <!-- 1. Breadcrumbs rendered by PageLayout above -->
  <!-- 2. H1 + 3. Localized Intro + 4. Inline CTA (above the fold) -->

  <Section bg="white" class="pt-8 md:pt-12">
    <div class="flex flex-col justify-center gap-4 sm:flex-row">
      <Button href="/free-estimates/" variant="primary" size="lg">Get a Free Estimate</Button>
      <Button href={`tel:${site.nap.phoneTel}`} variant="secondary" size="lg"
        >Call {site.nap.phone}</Button
      >
    </div>
  </Section>

  <Section bg="subtle" class="pt-0 md:pt-0">
    <div class="mx-auto max-w-2xl">
      <div class="space-y-4 rounded-xl bg-white p-6 shadow-md md:p-8">
        <div>
          <h2 class="font-heading text-2xl font-bold text-brand-slate">Quick Estimate Request</h2>
          <p class="mt-2 text-text-muted">Send your details and we will follow up promptly.</p>
        </div>

        <QuickEstimateForm serviceNeed={pillar.name} />

        <p class="text-sm text-text-muted">
          Need to share more project details? Use our
          <a
            href="/free-estimates/"
            class="font-semibold text-brand-teal transition-colors hover:text-brand-slate"
          >
            full estimate form</a
          >
          .
        </p>
      </div>
    </div>
  </Section>

  <!-- 5. Scoped Service Detail -->
  <Section bg="white">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
      <div>
        <h2 class="mb-6 font-heading text-2xl font-bold text-brand-slate md:text-3xl">
          Professional {pillar.name} in {city.name}
        </h2>
        <p class="mb-6 leading-relaxed text-text-muted">
          {fullLocalizedIntro}
        </p>
        <p class="mb-6 leading-relaxed text-text-muted">
          We handle every aspect of the job — from initial assessment through permitting,
          installation, and final inspection.
        </p>
        <h3 class="mb-3 text-lg font-semibold text-brand-slate">What's Included</h3>
        <ul class="space-y-2">
          {
            pillar.includedBullets.map((bullet) => (
              <li class="flex items-start gap-2 text-text-muted">
                <svg
                  class="mt-1 h-4 w-4 shrink-0 text-brand-teal"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
                {bullet}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="overflow-hidden rounded-xl bg-surface-subtle shadow-lg">
        {
          serviceImg ? (
            <img
              src={serviceImg.src}
              alt={serviceImg.alt}
              width={serviceImg.width}
              height={serviceImg.height}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          ) : (
            <div class="flex min-h-[250px] items-center justify-center">
              <p class="text-sm text-text-muted">
                {pillar.name} in {city.name}
              </p>
            </div>
          )
        }
      </div>
    </div>
  </Section>

  <Fragment slot="pricingCta">
    <CTABlock
      heading={`Get a precise estimate for your ${city.name} project.`}
      description=""
      primaryText="Request Free Estimate"
      secondaryText={`Call ${site.nap.phone}`}
      secondaryHref={`tel:${site.nap.phoneTel}`}
    />
  </Fragment>

  <Fragment slot="relatedContent">
    <div class="space-y-12">
      <LeadCaptureSection
        heading={`Get a Free ${pillar.name} Estimate in ${city.name}`}
        description={`Tell us about your ${pillar.name.toLowerCase()} project in ${city.name} and we will send a clear estimate with next steps.`}
      />

      {
        relatedPillars.length > 0 && (
          <>
            <h2 class="mb-6 font-heading text-2xl font-bold text-brand-slate">You May Also Need</h2>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {relatedPillars.map((related) => (
                <a
                  href={`/${city.slug}/${related.slug}/`}
                  class="block rounded-xl bg-white p-6 shadow-md transition-shadow hover:shadow-lg"
                >
                  <h3 class="mb-2 font-semibold text-brand-slate">
                    {related.name} in {city.name}
                  </h3>
                  <p class="text-sm text-text-muted">{related.shortDesc}</p>
                </a>
              ))}
            </div>
          </>
        )
      }
    </div>
  </Fragment>

  <Fragment slot="fullCta">
    <CTASection
      title={`Need ${pillar.name} in ${city.name}?`}
      subtitle={`Contact Wheyland Electric today for a free estimate. Licensed, bonded & insured with a 1-year labor warranty.`}
      cityName={city.name}
    />
  </Fragment>

  <Fragment slot="afterFullCta">
    {
      nearbyCities.length > 0 && (
        <Section bg="subtle">
          <h2 class="mb-4 text-center font-heading text-xl font-bold text-brand-slate">
            Also Serving
          </h2>
          <div class="flex flex-wrap justify-center gap-3">
            {nearbyCities.map((nearby) => (
              <a
                href={`/${nearby.slug}/${pillar.slug}/`}
                class="rounded-lg bg-white px-4 py-2 text-sm font-medium text-brand-slate shadow-sm transition-shadow hover:text-brand-teal hover:shadow-md"
              >
                {pillar.name} in {nearby.name}
              </a>
            ))}
          </div>
        </Section>
      )
    }

    <Section bg="white">
      <div class="flex flex-wrap justify-center gap-4 text-sm">
        <a href={`/${city.slug}/`} class="text-brand-teal transition-colors hover:text-brand-slate">
          ← All services in {city.name}
        </a>
        <span class="text-surface-warm">|</span>
        <a
          href={`/services/${pillar.slug}/`}
          class="text-brand-teal transition-colors hover:text-brand-slate"
        >
          {pillar.name} across all areas →
        </a>
      </div>
    </Section>
  </Fragment>
</ServiceMoneyPageTemplate>
