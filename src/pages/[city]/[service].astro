    alt: 'Level 2 EV charger installed by Wheyland Electric in San Diego County',
    width: 533,
    height: 711,
  },
  'electrical-panel-upgrades': {
    src: '/images/services/panel/wheyland-electric-commercial-meter-stack-panel.webp',
    alt: 'Commercial electrical meter stack and panel upgrade by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'recessed-lighting-installation': {
    src: '/images/services/lighting/wheyland-electric-kitchen-lighting-skylights.webp',
    alt: 'Recessed lighting and kitchen pendant lights installed by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'light-fixture-installation': {
    src: '/images/services/lighting/wheyland-electric-crystal-chandelier-foyer.webp',
    alt: 'Crystal chandelier installed in a two-story foyer by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'ceiling-fan-installation': {
    src: '/images/services/lighting/wheyland-electric-home-office-ceiling-fan-lighting.webp',
    alt: 'Ceiling fan and recessed lighting installation by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'spa-jacuzzi-sauna-electrical': {
    src: '/images/services/spa-sauna/wheyland-electric-barrel-sauna-exterior.webp',
    alt: 'Outdoor barrel sauna electrical installation by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'service-calls-troubleshooting': {
    src: '/images/services/panel/wheyland-electric-service-entrance-wiring.webp',
    alt: 'Electrical service wiring and troubleshooting by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'outlet-switch-dimmer-gfci-repairs': {
    src: '/images/services/lighting/wheyland-electric-wet-bar-sconce-lighting.webp',
    alt: 'Sconce lighting and outlet installation by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'dedicated-circuits': {
    src: '/images/services/ev-charger/wheyland-electric-ev-charger-installation.webp',
    alt: 'Dedicated 240V circuit for EV charging by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'commercial-tenant-improvement': {
    src: '/images/services/commercial/wheyland-electric-commercial-control-panel-vfd.webp',
    alt: 'Commercial electrical control panel by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'commercial-electrical-maintenance': {
    src: '/images/services/commercial/wheyland-electric-commercial-food-processing-electrical.webp',
    alt: 'Commercial electrical maintenance by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'light-industrial-electrical': {
    src: '/images/services/commercial/wheyland-electric-commercial-control-panel-vfd.webp',
    alt: 'Industrial electrical panel and VFD installation by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'remodel-rewiring-adu': {
    src: '/images/services/lighting/wheyland-electric-cove-lighting-tray-ceiling.webp',
    alt: 'Residential remodel with cove lighting by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'electrical-safety-inspections': {
    src: '/images/services/panel/wheyland-electric-outdoor-service-disconnect.webp',
    alt: 'Electrical safety inspection by Wheyland Electric',
    width: 533,
    height: 711,
  },
};

// City-specific image overrides (city slug + service slug → image)
const cityServiceImages: Record<
  string,
  { src: string; alt: string; width: number; height: number }
> = {
  'rancho-santa-fe:ev-charger-installation': {
    src: '/images/services/ev-charger/wheyland-electric-bmw-ev-charger-rancho-santa-fe.webp',
    alt: 'BMW i Level 2 EV charger installed by Wheyland Electric in Rancho Santa Fe, CA',
    width: 533,
    height: 711,
  },
};

export function getStaticPaths() {
  const cities = getPublishedCities();
  const pillars = getPublishedPillars();
  const paths: {
    params: { city: string; service: string };
    props: { city: City; pillar: ServicePillar };
  }[] = [];

  for (const city of cities) {
    for (const pillar of pillars) {
      paths.push({
        params: { city: city.slug, service: pillar.slug },
        props: { city, pillar },
      });
    }
  }
  return paths;
}

interface Props {
  city: City;
  pillar: ServicePillar;
}

const { city, pillar } = Astro.props;
const cityKey = `${city.slug}:${pillar.slug}`;
const serviceImg = cityServiceImages[cityKey] ?? serviceImages[pillar.slug];
const meta = moneyPageMeta(pillar.name, city.name, city.slug, pillar.slug);
const breadcrumbs = [
  { label: city.name, href: `/${city.slug}/` },
  { label: pillar.name, href: `/${city.slug}/${pillar.slug}/` },
];

const localizedIntro =
  pillar.localizedIntroSeedByCity[city.slug] ??
  `Wheyland Electric provides professional ${pillar.name.toLowerCase()} in ${city.name}, CA. Our licensed team delivers reliable, code-compliant electrical work backed by our 1-year labor warranty.`;

const h1Tagline = pillar.h1TaglineByCity?.[city.slug] ?? `${pillar.name} in ${city.name}, CA`;

const relatedPillars = pillar.relatedServices
  .map((slug) => getPillarBySlug(slug))
  .filter((p): p is ServicePillar => p !== undefined && p.publish);

const nearbyCities = city.nearbyCities
  .map((slug) => getCityBySlug(slug))
  .filter((c): c is City => c !== undefined && c.publish);

// Generate city-specific FAQs — city-scoped questions + pillar FAQs
const citySpecificFaqs: FAQ[] = [
  {
    question: `What is the cost of ${pillar.name.toLowerCase()} in ${city.name}?`,
    answer: `The cost of ${pillar.name.toLowerCase()} in ${city.name} depends on several factors including ${pillar.pricingFactors.slice(0, 3).join(', ').toLowerCase()}. Contact us at (858) 663-5564 for a free, no-obligation estimate tailored to your project.`,
  },
  {
    question: `Is Wheyland Electric licensed to perform ${pillar.name.toLowerCase()} in ${city.name}?`,
    answer: `Yes. Wheyland Electric holds California Contractor License #940291 and is fully licensed, bonded, and insured to perform ${pillar.name.toLowerCase()} in ${city.name} and throughout San Diego County. All work is backed by our 1-year labor warranty on workmanship.`,
  },
  {
    question: `Does Wheyland Electric handle permits for ${pillar.name.toLowerCase()} in ${city.name}?`,
    answer: `Yes. We handle the complete permit process with the City of ${city.name} building department including application, plan submission where required, and inspection scheduling. You do not need to manage any paperwork.`,
  },
  {
    question: `How long does ${pillar.name.toLowerCase()} take in ${city.name}?`,
    answer: `Timeline varies by project scope. Most residential ${pillar.name.toLowerCase()} projects in ${city.name} are completed in one visit. More complex work involving panel upgrades or permit inspections may span 1–2 weeks from approval to final sign-off. We provide a clear timeline during your free estimate.`,
  },
];
// Combine with pillar-level FAQs, deduplicate, ensure 6+ total
const moneyPageFaqs: FAQ[] = [
  ...citySpecificFaqs,
  ...pillar.faqs.slice(0, Math.max(2, 6 - citySpecificFaqs.length)),
];
---

<PageLayout
  meta={meta}
  schemas={[
    serviceSchema(
      pillar.name,
      pillar.shortDesc,
      `/${city.slug}/${pillar.slug}/`,
      `${city.name}, CA`
    ),
    faqPageSchema(moneyPageFaqs),
    breadcrumbSchema(breadcrumbs),
  ]}
  breadcrumbs={breadcrumbs}
>
  <!-- 1. Breadcrumbs rendered by PageLayout above -->
  <!-- 2. H1 + 3. Localized Intro + 4. Inline CTA (above the fold) -->
  <Hero
    title={h1Tagline}
    subtitle={localizedIntro}
    compact
    showTrustCard={false}
    showStatChips={false}
    showCTAs={false}
    imageSource="service"
    imageKey={pillar.slug}
  />

  <Section bg="white" class="pt-8 md:pt-12">
    <div class="flex flex-col justify-center gap-4 sm:flex-row">
      <Button href="/free-estimates/" variant="primary" size="lg">Get a Free Estimate</Button>
      <Button href={`tel:${site.nap.phoneTel}`} variant="secondary" size="lg"
        >Call {site.nap.phone}</Button
      >
    </div>
  </Section>

  <!-- 5. Scoped Service Detail -->
  <ServiceDetailSplit
    heading={`Professional ${pillar.name} in ${city.name}`}
    intro={`When you choose Wheyland Electric for ${pillar.name.toLowerCase()} in ${city.name}, you get a team that knows this community and delivers work you can trust. We handle every aspect of the job — from initial assessment through permitting, installation, and final inspection.`}
    listHeading="What's Included"
    bullets={pillar.includedBullets}
    imageSrc={serviceImg?.src}
    imageAlt={serviceImg?.alt}
    imageWidth={serviceImg?.width}
    imageHeight={serviceImg?.height}
    layoutVariant="textWide"
    imagePosition="right"
    imageAspect="auto"
  />

  <!-- 6. Process Steps -->
  {
    pillar.processSteps.length > 0 && (
      <Section bg="subtle">
        <h2 class="mb-8 text-center font-heading text-2xl font-bold text-brand-slate md:text-3xl">
          How {pillar.name} Works in {city.name}
        </h2>
        <div class="mx-auto max-w-3xl space-y-6">
          {pillar.processSteps.map((step) => (
            <div class="flex items-start gap-4 rounded-xl bg-white p-6 shadow-sm">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-teal text-lg font-bold text-white">
                {step.step}
              </div>
              <div>
                <h3 class="mb-1 font-semibold text-brand-slate">{step.title}</h3>
                <p class="text-sm text-text-muted">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </Section>
    )
  }

  <!-- 7. Pricing Factors -->
  <Section bg="white">
    <h2 class="mb-6 font-heading text-2xl font-bold text-brand-slate md:text-3xl">
      What Affects the Cost of {pillar.name} in {city.name}
    </h2>
    <p class="mb-6 text-text-muted">
      Every {pillar.name.toLowerCase()} project in {city.name} is unique. Here are the factors that typically
      influence pricing:
    </p>
    <ul class="mb-8 grid grid-cols-1 gap-3 sm:grid-cols-2">
      {
        pillar.pricingFactors.map((factor) => (
          <li class="flex items-start gap-2 text-text-muted">
            <svg
              class="mt-1 h-4 w-4 shrink-0 text-brand-teal-light"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            {factor}
          </li>
        ))
      }
    </ul>
    <CTABlock
      heading={`Get a precise estimate for your ${city.name} project.`}
      description=""
      primaryText="Request Free Estimate"
      secondaryText={`Call ${site.nap.phone}`}
      secondaryHref={`tel:${site.nap.phoneTel}`}
    />
  </Section>

  <!-- 8. TrustBar -->
  <TrustBar />

  <!-- 9. Related Services -->
  {
    relatedPillars.length > 0 && (
      <Section bg="subtle">
        <h2 class="mb-6 font-heading text-2xl font-bold text-brand-slate">You May Also Need</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {relatedPillars.map((related) => (
            <a
              href={`/${city.slug}/${related.slug}/`}
              class="block rounded-xl bg-white p-6 shadow-md transition-shadow hover:shadow-lg"
            >
              <h3 class="mb-2 font-semibold text-brand-slate">
                {related.name} in {city.name}
              </h3>
              <p class="text-sm text-text-muted">{related.shortDesc}</p>
            </a>
          ))}
        </div>
      </Section>
    )
  }

  <!-- 10. FAQs -->
  <Section bg="white">
    <div class="mx-auto max-w-3xl">
      <FAQAccordion faqs={moneyPageFaqs} heading={`${pillar.name} in ${city.name} — FAQs`} />
    </div>
  </Section>

  <!-- 11. Full CTA Section -->
  <CTASection
    title={`Need ${pillar.name} in ${city.name}?`}
    subtitle={`Contact Wheyland Electric today for a free estimate. Licensed, bonded & insured with a 1-year labor warranty.`}
    cityName={city.name}
  />

  <!-- 12. Nearby city links for same service -->
  {
    nearbyCities.length > 0 && (
      <Section bg="subtle">
        <h2 class="mb-4 text-center font-heading text-xl font-bold text-brand-slate">
          Also Serving
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          {nearbyCities.map((nearby) => (
            <a
              href={`/${nearby.slug}/${pillar.slug}/`}
              class="rounded-lg bg-white px-4 py-2 text-sm font-medium text-brand-slate shadow-sm transition-shadow hover:text-brand-teal hover:shadow-md"
            >
              {pillar.name} in {nearby.name}
            </a>
          ))}
        </div>
      </Section>
    )
  }

  <!-- 13. Breadcrumb links back -->
  <Section bg="white">
    <div class="flex flex-wrap justify-center gap-4 text-sm">
      <a href={`/${city.slug}/`} class="text-brand-teal transition-colors hover:text-brand-slate">
        ← All services in {city.name}
      </a>
      <span class="text-surface-warm">|</span>
      <a
        href={`/services/${pillar.slug}/`}
        class="text-brand-teal transition-colors hover:text-brand-slate"
      >
        {pillar.name} across all areas →
      </a>
    </div>
  </Section>
</PageLayout>
