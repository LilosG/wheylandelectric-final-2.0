---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServiceGrid from '../../components/sections/ServiceGrid.astro';
import HOAOfferBlock from '../../components/sections/HOAOfferBlock.astro';
import FAQAccordion from '../../components/sections/FAQAccordion.astro';
import TestimonialBlock from '../../components/sections/TestimonialBlock.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Section from '../../components/ui/Section.astro';
import { cityPageMeta } from '../../lib/seo';
import { localBusinessSchema } from '../../lib/schema/localBusiness';
import { faqPageSchema } from '../../lib/schema/faq';
import { breadcrumbSchema } from '../../lib/schema/breadcrumb';
import { getPublishedCities, getCityBySlug } from '../../data/cities';
import { getPublishedPillars } from '../../data/services';
import type { City, FAQ } from '../../types';

export function getStaticPaths() {
  const cities = getPublishedCities();
  return cities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

interface Props {
  city: City;
}

const { city } = Astro.props;
const services = getPublishedPillars();
const meta = cityPageMeta(city.name, city.slug);
const breadcrumbs = [{ label: city.name, href: `/${city.slug}/` }];
const nearbyCities = city.nearbyCities
  .map((slug) => getCityBySlug(slug))
  .filter((c): c is City => c !== undefined && c.publish);

const categoryLabels: Record<string, string> = {
  residential: 'Residential',
  commercial: 'Commercial',
  hoa: 'HOA Communities',
  ev: 'EV Charging',
};

const cityFaqs: FAQ[] = [
  { question: `What electrical services does Wheyland Electric offer in ${city.name}?`, answer: `We provide comprehensive electrical services in ${city.name} including EV charger installation, electrical panel upgrades, recessed lighting, light fixture installation, ceiling fan installation, spa and hot tub wiring, outlet and switch repairs, and troubleshooting. All work is performed by licensed electricians and backed by our 1-year labor warranty.` },
  { question: `Is Wheyland Electric licensed to work in ${city.name}?`, answer: `Yes. Wheyland Electric holds California Contractor License #940291 and is fully licensed, bonded, and insured to perform electrical work throughout ${city.name} and all of San Diego County.` },
  { question: `How do I get a free estimate for electrical work in ${city.name}?`, answer: `Call us at (858) 663-5564 or fill out our online estimate request form at wheylandelectric.com/free-estimates. We will discuss your project and provide a no-obligation estimate.` },
  { question: `Does Wheyland Electric serve HOA communities in ${city.name}?`, answer: `Yes. We offer flat-rate monthly lighting and electrical maintenance services for HOA communities in ${city.name}. This includes scheduled inspections, documentation, and transparent pricing.` },
  { question: `Can you install an EV charger at my ${city.name} home?`, answer: `Yes. We install Level 2 EV chargers for all makes including Tesla, Rivian, and Ford at homes throughout ${city.name}. We handle the complete process from panel assessment to permitting, installation, and inspection.` },
  { question: `What areas near ${city.name} does Wheyland Electric serve?`, answer: `In addition to ${city.name}, we serve ${nearbyCities.map((c) => c.name).join(', ')} and all of San Diego County. Our main office is in Carlsbad.` },
];
---
<PageLayout
  meta={meta}
  schemas={[
    localBusinessSchema(),
    faqPageSchema(cityFaqs),
    breadcrumbSchema(breadcrumbs),
  ]}
  breadcrumbs={breadcrumbs}
>
  <Hero
    title={`Electrician in ${city.name}, CA`}
    subtitle={`Licensed, bonded & insured electrical services for homes and businesses in ${city.name}.`}
    compact
    showTrustCard={false}
    showStatChips={false}
  />

  <TrustBar />

  <!-- City-specific intro -->
  <Section bg="white">
    <div class="max-w-3xl mx-auto">
      <p class="text-lg text-text-muted leading-relaxed mb-6">{city.localIntroSeed}</p>

      <!-- Service categories -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8">
        {city.serviceCategories.map((cat) => (
            <div class="bg-surface-subtle rounded-lg p-4 text-center">
              <p class="font-semibold text-brand-indigo text-sm">{categoryLabels[cat] ?? cat}</p>
            </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Services in this city -->
  <Section bg="subtle">
    <ServiceGrid
      services={services}
      citySlug={city.slug}
      heading={`Electrical Services in ${city.name}`}
    />
  </Section>

  <!-- HOA Offer -->
  <Section bg="white">
    <HOAOfferBlock cityName={city.name} />
  </Section>

  <!-- City details -->
  <Section bg="subtle">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {city.neighborhoods.length > 0 && (
        <div>
          <h3 class="text-lg font-semibold text-brand-indigo mb-3">Neighborhoods We Serve</h3>
          <ul class="space-y-1">
            {city.neighborhoods.map((n) => (
              <li class="text-text-muted text-sm flex items-center gap-2">
                <svg class="w-3 h-3 text-brand-moonstone" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3"/></svg>
                {n}
              </li>
            ))}
          </ul>
        </div>
      )}
      {city.zips.length > 0 && (
        <div>
          <h3 class="text-lg font-semibold text-brand-indigo mb-3">ZIP Codes Served</h3>
          <div class="flex flex-wrap gap-2">
            {city.zips.map((zip) => (
              <span class="inline-block bg-white rounded-lg px-3 py-1.5 text-sm text-text-muted border border-brand-mint/50">{zip}</span>
            ))}
          </div>
          {city.localCues.length > 0 && (
            <div class="mt-6">
              <h3 class="text-lg font-semibold text-brand-indigo mb-3">Local Landmarks</h3>
              <ul class="space-y-1">
                {city.localCues.map((cue) => (
                  <li class="text-text-muted text-sm">{cue}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}
    </div>
  </Section>

  <!-- Testimonials -->
  <TestimonialBlock cityTag={city.slug} heading={`Reviews from ${city.name} Customers`} />

  <!-- FAQs -->
  <Section bg="subtle">
    <div class="max-w-3xl mx-auto">
      <FAQAccordion faqs={cityFaqs} heading={`${city.name} Electrician FAQs`} />
    </div>
  </Section>

  <!-- Nearby cities -->
  {nearbyCities.length > 0 && (
    <Section bg="white">
      <h2 class="text-2xl font-heading font-bold text-brand-indigo mb-6 text-center">Nearby Service Areas</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {nearbyCities.map((nearby) => (
          <a
            href={`/${nearby.slug}/`}
            class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow px-6 py-3 text-brand-indigo hover:text-brand-moonstone font-medium"
          >
            {nearby.name}, CA
          </a>
        ))}
      </div>
    </Section>
  )}

  <CTASection cityName={city.name} />

</PageLayout>
