---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServiceGrid from '../../components/sections/ServiceGrid.astro';
import HOAOfferBlock from '../../components/sections/HOAOfferBlock.astro';
import FAQAccordion from '../../components/sections/FAQAccordion.astro';
import TestimonialBlock from '../../components/sections/TestimonialBlock.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Section from '../../components/ui/Section.astro';
import { cityPageMeta } from '../../lib/seo';
import { localBusinessSchema } from '../../lib/schema/localBusiness';
import { faqPageSchema } from '../../lib/schema/faq';
import { breadcrumbSchema } from '../../lib/schema/breadcrumb';
import { getPublishedCities, getCityBySlug } from '../../data/cities';
import { getPublishedPillars } from '../../data/services';
import type { City, FAQ } from '../../types';

export function getStaticPaths() {
  const cities = getPublishedCities();
  return cities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

interface Props {
  city: City;
}

const { city } = Astro.props;
const services = getPublishedPillars();
const meta = cityPageMeta(city.name, city.slug);
const breadcrumbs = [{ label: city.name, href: `/${city.slug}/` }];
const nearbyCities = city.nearbyCities
  .map((slug) => getCityBySlug(slug))
  .filter((c): c is City => c !== undefined && c.publish);


const cityFaqs: FAQ[] = [
  {
    question: `What electrical services does Wheyland Electric offer in ${city.name}?`,
    answer: `We provide comprehensive electrical services in ${city.name} including EV charger installation, electrical panel upgrades, recessed lighting installation, light fixture installation, ceiling fan installation, spa and hot tub wiring, outlet and switch repairs, and electrical troubleshooting. All work is performed by licensed electricians, permitted through the City of ${city.name}, and backed by our 1-year labor warranty on workmanship.`,
  },
  {
    question: `Is Wheyland Electric licensed to work in ${city.name}, CA?`,
    answer: `Yes. Wheyland Electric holds California Contractor License #940291 and is fully licensed, bonded, and insured to perform electrical work throughout ${city.name} and all of San Diego County. We pull permits directly with the City of ${city.name} building department on every job that requires one.`,
  },
  {
    question: `How do I get a free estimate for electrical work in ${city.name}?`,
    answer: `Call us at (858) 663-5564 or fill out the estimate request form at wheylandelectric.com/free-estimates. We will discuss your project, answer questions, and schedule an on-site assessment at no cost or obligation.`,
  },
  {
    question: `Does Wheyland Electric handle building permits for work in ${city.name}?`,
    answer: `Yes. We manage the entire permit process — application, plan submission where required, and inspection scheduling — with the City of ${city.name} building department. You do not need to visit the permit office or manage any paperwork.`,
  },
  {
    question: `Does Wheyland Electric serve HOA communities in ${city.name}?`,
    answer: `Yes. We offer flat-rate monthly lighting and electrical maintenance services for HOA communities in ${city.name}. This includes scheduled common-area inspections, written documentation for board records, and transparent predictable pricing — no surprise invoices.`,
  },
  {
    question: `Can you install an EV charger at my ${city.name} home?`,
    answer: `Yes. We install Level 2 EV chargers for all makes and models — Tesla, Rivian, Ford, Chevy, BMW, and others — at homes throughout ${city.name}. We handle the complete process from panel capacity assessment and permit filing to installation and final city inspection.`,
  },
  {
    question: `What areas near ${city.name} does Wheyland Electric serve?`,
    answer: `In addition to ${city.name}, we serve ${nearbyCities.map((c) => c.name).join(', ')}, and all of North County San Diego. Our main office is at 3536 Woodland Way in Carlsbad. Call (858) 663-5564 to discuss your project.`,
  },
];
---
<PageLayout
  meta={meta}
  schemas={[
    localBusinessSchema(),
    faqPageSchema(cityFaqs),
    breadcrumbSchema(breadcrumbs),
  ]}
  breadcrumbs={breadcrumbs}
>
  <Hero
    title={`Electrician in ${city.name}, CA`}
    subtitle={`Licensed, bonded & insured electrical services for homes and businesses in ${city.name}.`}
    compact
    showTrustCard={false}
    showStatChips={false}
    imageSource="city"
    imageKey={city.slug}
    imagePosition="bottom"
  />

  <TrustBar />

  <!-- City-specific intro -->
  <Section bg="white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-slate mb-4">Local Electrical Expertise in {city.name}</h2>
      <p class="text-text-muted leading-relaxed mb-3">{city.localIntroSeed}</p>
      {city.localIntroExtended && <p class="text-text-muted leading-relaxed">{city.localIntroExtended}</p>}
    </div>
  </Section>

  <!-- Services in this city -->
  <Section bg="subtle">
    <ServiceGrid
      services={services}
      citySlug={city.slug}
      heading={`Electrical Services in ${city.name}`}
    />
  </Section>

  <!-- HOA Offer -->
  <Section bg="white">
    <HOAOfferBlock cityName={city.name} />
  </Section>

  <!-- City details -->
  <Section bg="subtle">
    <div class="max-w-4xl mx-auto space-y-4">
      <details class="rounded-xl bg-white p-5 shadow-sm" open>
        <summary class="cursor-pointer font-semibold text-brand-slate">Neighborhoods We Serve in {city.name}</summary>
        {city.neighborhoods.length > 0 ? (
          <ul class="mt-4 space-y-3">
            {city.neighborhoods.map((n) => (
              <li class="flex items-start gap-2">
                <svg class="w-3 h-3 text-brand-teal shrink-0 mt-1.5" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3"/></svg>
                <span>
                  <span class="text-brand-slate font-medium text-sm">{n}</span>
                  {city.neighborhoodDescriptions?.[n] && (
                    <span class="text-text-muted text-sm"> — {city.neighborhoodDescriptions[n]}</span>
                  )}
                </span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="mt-4 text-sm text-text-muted">Call us for service availability in your neighborhood.</p>
        )}
      </details>

      <details class="rounded-xl bg-white p-5 shadow-sm">
        <summary class="cursor-pointer font-semibold text-brand-slate">ZIP Codes and Local Coverage</summary>
        <div class="mt-4 space-y-4">
          {city.zips.length > 0 && (
            <div>
              <p class="text-sm font-medium text-brand-slate mb-2">ZIP Codes Served</p>
              <div class="flex flex-wrap gap-2">
                {city.zips.map((zip) => (
                  <span class="inline-block bg-surface-subtle rounded-lg px-3 py-1.5 text-sm text-text-muted border border-surface-warm/50">{zip}</span>
                ))}
              </div>
            </div>
          )}
          <p class="text-sm text-text-muted">Nearby Coverage: {nearbyCities.length} surrounding cities.</p>
        </div>
      </details>

      {city.localCues.length > 0 && (
        <details class="rounded-xl bg-white p-5 shadow-sm">
          <summary class="cursor-pointer font-semibold text-brand-slate">Local Landmarks and Cues</summary>
          <ul class="mt-4 space-y-1">
            {city.localCues.map((cue) => (
              <li class="text-text-muted text-sm">{cue}</li>
            ))}
          </ul>
        </details>
      )}
    </div>
  </Section>


  <!-- Testimonials -->
  <TestimonialBlock cityTag={city.slug} heading={`Reviews from ${city.name} Customers`} />

  <!-- FAQs -->
  <Section bg="subtle">
    <div class="max-w-3xl mx-auto">
      <FAQAccordion faqs={cityFaqs} heading={`${city.name} Electrician FAQs`} />
    </div>
  </Section>

  <!-- Nearby cities -->
  {nearbyCities.length > 0 && (
    <Section bg="white">
      <h2 class="text-2xl font-heading font-bold text-brand-slate mb-6 text-center">Nearby Service Areas</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {nearbyCities.map((nearby) => (
          <a
            href={`/${nearby.slug}/`}
            class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow px-6 py-3 text-brand-slate hover:text-brand-teal font-medium"
          >
            {nearby.name}, CA
          </a>
        ))}
      </div>
    </Section>
  )}

  <CTASection cityName={city.name} />

</PageLayout>
