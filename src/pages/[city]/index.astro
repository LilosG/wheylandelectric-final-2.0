---
import CityLandingTemplate from '../../components/templates/CityLandingTemplate.astro';
import { cityPageMeta } from '../../lib/seo';
import { faqPageSchemaNode } from '../../lib/schema/faq';
import { breadcrumbSchemaNode } from '../../lib/schema/breadcrumb';
import { shouldEmitFaqSchema } from '../../lib/schema/faqPolicy';
import { graphSchema, webPageSchemaNode } from '../../lib/schema/graph';
import { getPublishedCities, getCityBySlug } from '../../data/cities';
import { getPublishedPillars, getNeighborhoodPillars } from '../../data/services';
import { getCityHeroImage } from '../../data/heroImages';
import type { City, FAQ } from '../../types';

export function getStaticPaths() {
  const cities = getPublishedCities();
  return cities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

interface Props {
  city: City;
}

const { city } = Astro.props;
const services = city.isSubNeighborhood ? getNeighborhoodPillars() : getPublishedPillars();
const meta = cityPageMeta(city.name, city.slug);
const breadcrumbs = [{ label: city.name, href: `/${city.slug}/` }];
const cityHero = getCityHeroImage(city.slug);
const nearbyCities = city.nearbyCities
  .map((slug) => getCityBySlug(slug))
  .filter((c): c is City => c !== undefined && c.publish);

const cityFaqs: FAQ[] = city.cityFAQs || [];


const schemas = [
  (() => {
    const nodes: Record<string, unknown>[] = [
      webPageSchemaNode({
        type: 'WebPage',
        path: `/${city.slug}/`,
        name: meta.title,
        description: meta.description,
      }),
      breadcrumbSchemaNode(breadcrumbs, `/${city.slug}/`),
    ];

    if (shouldEmitFaqSchema({
      faqs: cityFaqs,
      pageTokens: [city.name],
      visible: cityFaqs.length > 0,
      usesSharedFallback: false,
    })) {
      nodes.push(faqPageSchemaNode(cityFaqs, `/${city.slug}/`));
    }

    return graphSchema(nodes);
  })(),
];
---

<CityLandingTemplate
  city={city}
  services={services}
  nearbyCities={nearbyCities}
  cityFaqs={cityFaqs}
  meta={meta}
  breadcrumbs={breadcrumbs}
  cityHero={cityHero}
  schemas={schemas}
/>
