---
import ServicePillarTemplate from '../../components/templates/ServicePillarTemplate.astro';
import { servicePageMeta } from '../../lib/seo';
import { serviceSchemaNode } from '../../lib/schema/service';
import { faqPageSchemaNode } from '../../lib/schema/faq';
import { shouldEmitFaqSchema } from '../../lib/schema/faqPolicy';
import { graphSchema, webPageSchemaNode } from '../../lib/schema/graph';
import { breadcrumbSchemaNode } from '../../lib/schema/breadcrumb';
import { getPublishedPillars, getPillarBySlug } from '../../data/services';
import { getPublishedCities } from '../../data/cities';
import type { ServicePillar } from '../../types';
import { getServiceHeroImage } from '../../data/serviceHeroImages';
import { getServiceHeroImage as getHeroServiceImage } from '../../data/heroImages';

export function getStaticPaths() {
  const pillars = getPublishedPillars();
  return pillars.map((pillar) => ({
    params: { service: pillar.slug },
    props: { pillar },
  }));
}

interface Props {
  pillar: ServicePillar;
}

const { pillar } = Astro.props;
const serviceImg = getServiceHeroImage({ serviceSlug: pillar.slug });
const heroImage = getHeroServiceImage(pillar.slug);
const meta = servicePageMeta(pillar.name, pillar.slug);
const breadcrumbs = [
  { label: 'Services', href: '/services/' },
  { label: pillar.name, href: `/services/${pillar.slug}/` },
];
const relatedPillars = (pillar.relatedServiceSlugs || pillar.relatedServices)
  .map((slug) => getPillarBySlug(slug))
  .filter((p): p is ServicePillar => p !== undefined && p.publish);
const serviceAreaCities = getPublishedCities().map((city) => ({ slug: city.slug, name: city.name }));
---

<ServicePillarTemplate
  meta={meta}
  schemas={[
    ...(() => {
      const nodes: Record<string, unknown>[] = [
        webPageSchemaNode({
          type: 'WebPage',
          path: `/services/${pillar.slug}/`,
          name: meta.title,
          description: meta.description,
          mainEntityId: `https://wheylandelectric.com/services/${pillar.slug}/#service`,
        }),
        serviceSchemaNode(pillar.name, pillar.shortDesc, `/services/${pillar.slug}/`),
        breadcrumbSchemaNode(breadcrumbs, `/services/${pillar.slug}/`),
      ];

      if (shouldEmitFaqSchema({
        faqs: pillar.faqs,
        pageTokens: [pillar.name],
        visible: pillar.faqs.length > 0,
        usesSharedFallback: false,
      })) {
        nodes.push(faqPageSchemaNode(pillar.faqs, `/services/${pillar.slug}/`));
      }

      return [graphSchema(nodes)];
    })(),
  ]}
  breadcrumbs={breadcrumbs}
  pillar={pillar}
  heroImage={heroImage}
  serviceImg={serviceImg}
  serviceAreaCities={serviceAreaCities}
  relatedPillars={relatedPillars}
/>
