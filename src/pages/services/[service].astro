---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import FAQAccordion from '../../components/sections/FAQAccordion.astro';
import TestimonialBlock from '../../components/sections/TestimonialBlock.astro';
import CTASection from '../../components/sections/CTASection.astro';
import ServiceDetailSplit from '../../components/sections/ServiceDetailSplit.astro';
import Section from '../../components/ui/Section.astro';
import Button from '../../components/ui/Button.astro';
import { servicePageMeta } from '../../lib/seo';
import { serviceSchema } from '../../lib/schema/service';
import { faqPageSchema } from '../../lib/schema/faq';
import { breadcrumbSchema } from '../../lib/schema/breadcrumb';
import { getPublishedPillars, getPillarBySlug } from '../../data/services';
import { getPublishedCities } from '../../data/cities';
import type { ServicePillar } from '../../types';

// Map service slugs to their primary hero images
const serviceImages: Record<string, { src: string; alt: string; width: number; height: number }> = {
  'ev-charger-installation': {
    src: '/images/services/ev-charger/wheyland-electric-bmw-ev-charger-rancho-santa-fe.webp',
    alt: 'Level 2 EV charger installed by Wheyland Electric in San Diego County',
    width: 533,
    height: 711,
  },
  'electrical-panel-upgrades': {
    src: '/images/services/panel/wheyland-electric-commercial-meter-stack-panel.webp',
    alt: 'Commercial electrical meter stack and panel upgrade by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'recessed-lighting-installation': {
    src: '/images/services/lighting/wheyland-electric-kitchen-lighting-skylights.webp',
    alt: 'Recessed lighting and kitchen pendant lights installed by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'light-fixture-installation': {
    src: '/images/services/lighting/wheyland-electric-crystal-chandelier-foyer.webp',
    alt: 'Crystal chandelier installed in a two-story foyer by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'ceiling-fan-installation': {
    src: '/images/services/lighting/wheyland-electric-home-office-ceiling-fan-lighting.webp',
    alt: 'Ceiling fan and recessed lighting installation by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'spa-jacuzzi-sauna-electrical': {
    src: '/images/services/spa-sauna/wheyland-electric-barrel-sauna-exterior.webp',
    alt: 'Outdoor barrel sauna electrical installation by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'service-calls-troubleshooting': {
    src: '/images/services/panel/wheyland-electric-service-entrance-wiring.webp',
    alt: 'Electrical service wiring and troubleshooting by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'outlet-switch-dimmer-gfci-repairs': {
    src: '/images/services/lighting/wheyland-electric-wet-bar-sconce-lighting.webp',
    alt: 'Sconce lighting and outlet installation in a residential home by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'dedicated-circuits': {
    src: '/images/services/ev-charger/wheyland-electric-ev-charger-installation.webp',
    alt: 'Dedicated 240V circuit for EV charging installed by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'commercial-tenant-improvement': {
    src: '/images/services/commercial/wheyland-electric-commercial-control-panel-vfd.webp',
    alt: 'Commercial electrical control panel installed by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'commercial-electrical-maintenance': {
    src: '/images/services/commercial/wheyland-electric-commercial-food-processing-electrical.webp',
    alt: 'Commercial food processing electrical maintenance by Wheyland Electric',
    width: 533,
    height: 711,
  },
  'light-industrial-electrical': {
    src: '/images/services/commercial/wheyland-electric-commercial-control-panel-vfd.webp',
    alt: 'Industrial electrical panel and VFD installation by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'remodel-rewiring-adu': {
    src: '/images/services/lighting/wheyland-electric-cove-lighting-tray-ceiling.webp',
    alt: 'Residential remodel with cove lighting and chandelier by Wheyland Electric',
    width: 711,
    height: 533,
  },
  'electrical-safety-inspections': {
    src: '/images/services/panel/wheyland-electric-outdoor-service-disconnect.webp',
    alt: 'Electrical safety inspection of outdoor service entrance by Wheyland Electric',
    width: 533,
    height: 711,
  },
};

export function getStaticPaths() {
  const pillars = getPublishedPillars();
  return pillars.map((pillar) => ({
    params: { service: pillar.slug },
    props: { pillar },
  }));
}

interface Props {
  pillar: ServicePillar;
}

const { pillar } = Astro.props;
const serviceImg = serviceImages[pillar.slug];
const cities = getPublishedCities();
const meta = servicePageMeta(pillar.name, pillar.slug);
const breadcrumbs = [
  { label: 'Services', href: '/services/' },
  { label: pillar.name, href: `/services/${pillar.slug}/` },
];
const relatedPillars = pillar.relatedServices
  .map((slug) => getPillarBySlug(slug))
  .filter((p): p is ServicePillar => p !== undefined && p.publish);
---

<PageLayout
  meta={meta}
  schemas={[
    serviceSchema(pillar.name, pillar.shortDesc, `/services/${pillar.slug}/`),
    faqPageSchema(pillar.faqs),
    breadcrumbSchema(breadcrumbs),
  ]}
  breadcrumbs={breadcrumbs}
>
  <Hero
    title={`${pillar.name} in San Diego County`}
    subtitle={pillar.shortDesc}
    compact
    showTrustCard={false}
    showStatChips={false}
    imageSource="service"
    imageKey={pillar.slug}
  />

  <TrustBar />

  <!-- When to Call -->
  {
    pillar.whenToCallSigns && pillar.whenToCallSigns.length > 0 && (
      <Section bg="white">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-4 font-heading text-2xl font-bold text-brand-slate md:text-3xl">
            Signs You Need {pillar.name}
          </h2>
          <p class="mb-6 text-text-muted">
            If any of the following situations apply to you, it is a good time to call Wheyland
            Electric for a free assessment.
          </p>
          <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            {pillar.whenToCallSigns.map((sign) => (
              <li class="flex items-start gap-3 rounded-lg bg-surface-subtle p-4">
                <svg
                  class="mt-0.5 h-5 w-5 shrink-0 text-brand-teal"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <span class="text-sm text-text-muted">{sign}</span>
              </li>
            ))}
          </ul>
        </div>
      </Section>
    )
  }

  <!-- What's Included -->
  <ServiceDetailSplit
    heading="What's Included"
    bullets={pillar.includedBullets}
    imageSrc={serviceImg?.src}
    imageAlt={serviceImg?.alt}
    imageWidth={serviceImg?.width}
    imageHeight={serviceImg?.height}
    layoutVariant="textWide"
    imagePosition="right"
    imageAspect="auto"
  />

  <!-- Process Steps -->
  {
    pillar.processSteps.length > 0 && (
      <Section bg="subtle">
        <h2 class="mb-8 text-center font-heading text-2xl font-bold text-brand-slate md:text-3xl">
          Our Process
        </h2>
        <div class="mx-auto max-w-3xl space-y-6">
          {pillar.processSteps.map((step) => (
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-teal text-lg font-bold text-white">
                {step.step}
              </div>
              <div>
                <h3 class="mb-1 font-semibold text-brand-slate">{step.title}</h3>
                <p class="text-text-muted">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </Section>
    )
  }

  <!-- Pricing Factors -->
  {
    pillar.pricingFactors.length > 0 && (
      <Section bg="white">
        <h2 class="mb-6 font-heading text-2xl font-bold text-brand-slate md:text-3xl">
          What Affects Pricing
        </h2>
        <p class="mb-6 text-text-muted">
          Every project is unique. These are the factors that typically influence the cost of{' '}
          {pillar.name.toLowerCase()}:
        </p>
        <ul class="mb-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
          {pillar.pricingFactors.map((factor) => (
            <li class="flex items-start gap-2 text-text-muted">
              <svg
                class="mt-1 h-4 w-4 shrink-0 text-brand-teal-light"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
              {factor}
            </li>
          ))}
        </ul>
        <p class="italic text-text-muted">
          Call{' '}
          <a
            href="tel:8586635564"
            class="font-semibold text-brand-teal transition-colors hover:text-brand-slate"
          >
            (858) 663-5564
          </a>{' '}
          for a free estimate tailored to your specific project.
        </p>
      </Section>
    )
  }

  <!-- City Links — North County San Diego Coverage -->
  <Section bg="subtle">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-4 text-center font-heading text-2xl font-bold text-brand-slate md:text-3xl">
        {pillar.name} Across North County San Diego
      </h2>
      <p class="mx-auto mb-8 max-w-2xl text-center text-text-muted">
        Wheyland Electric is based in Carlsbad and serves all of North County San Diego with the
        same commitment to quality, transparent pricing, and complete permit handling. Select your
        city below to learn about {pillar.name.toLowerCase()} specific to your area.
      </p>
      <div class="mb-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {
          cities.map((city) => (
            <a
              href={`/${city.slug}/${pillar.slug}/`}
              class="block rounded-lg bg-white p-4 text-center font-medium text-brand-slate shadow-sm transition-shadow hover:text-brand-teal hover:shadow-md"
            >
              {city.name}
            </a>
          ))
        }
      </div>
      <div class="text-center">
        <Button href="/service-areas/" variant="ghost">All Service Areas →</Button>
      </div>
    </div>
  </Section>

  <!-- Related Services -->
  {
    relatedPillars.length > 0 && (
      <Section bg="white">
        <h2 class="mb-6 font-heading text-2xl font-bold text-brand-slate md:text-3xl">
          Related Services
        </h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {relatedPillars.map((related) => (
            <a
              href={`/services/${related.slug}/`}
              class="block rounded-xl bg-white p-6 shadow-md transition-shadow hover:shadow-lg"
            >
              <h3 class="mb-2 font-semibold text-brand-slate">{related.name}</h3>
              <p class="text-sm text-text-muted">{related.shortDesc}</p>
            </a>
          ))}
        </div>
      </Section>
    )
  }

  <!-- FAQs -->
  <Section bg="subtle">
    <div class="mx-auto max-w-3xl">
      <FAQAccordion faqs={pillar.faqs} heading={`${pillar.name} FAQs`} />
    </div>
  </Section>

  <!-- Testimonials -->
  <TestimonialBlock serviceTag={pillar.slug} />

  <CTASection
    subtitle={`Contact Wheyland Electric today for a free estimate on ${pillar.name.toLowerCase()}.`}
  />
</PageLayout>
