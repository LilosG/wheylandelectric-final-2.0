---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/ui/Section.astro';
import Hero from '../../components/sections/Hero.astro';
import CTASection from '../../components/sections/CTASection.astro';
import { blogIndexMeta } from '../../lib/seo';
import { getCollection } from 'astro:content';
import { getPageHeroImage } from '../../data/heroImages';
import { collectionPageSchema } from '../../lib/schema/collection';
import { breadcrumbSchemaNode } from '../../lib/schema/breadcrumb';

const meta = blogIndexMeta();

const blogHero = getPageHeroImage('blog');

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<PageLayout
  meta={meta}
  schemas={[
    collectionPageSchema('/blog/', meta.title, meta.description, posts.map((post) => ({ name: post.data.title, url: `/blog/${post.slug}/` }))),
    {
      '@context': 'https://schema.org',
      ...breadcrumbSchemaNode([{ label: 'Blog', href: '/blog/' }], '/blog/'),
    },
  ]}
  breadcrumbs={[{ label: 'Blog', href: '/blog/' }]}
>
  <Hero
    title="Electrical Tips & Insights"
    subtitle="Practical guides and information from the Wheyland Electric team."
    variant="compact"
    showCTAs={false}
    showTrustCard={false}
    showStatChips={false}
    backgroundImage={blogHero.src}
  />

  <Section bg="white" spacing="hero-tight">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-slate text-center mb-10">Latest Electrical Tips and Project Guides</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
        <a href={`/blog/${post.slug}/`} class="block bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow overflow-hidden group">
          <div class="aspect-video bg-surface-subtle overflow-hidden">
            <img
              src={post.data.image || '/images/services/lighting/wheyland-electric-kitchen-pendant-lighting.webp'}
              alt={post.data.title}
              class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
              loading="lazy"
              width="1200"
              height="675"
            />
          </div>
          <div class="p-6">
            <time class="text-xs text-text-muted" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h3 class="text-lg font-semibold text-brand-slate mt-2 mb-2 group-hover:text-brand-teal transition-colors">
              {post.data.title}
            </h3>
            <p class="text-sm text-text-muted">{post.data.description}</p>
          </div>
        </a>
        ))}
      </div>
    </div>
  </Section>

  <CTASection />
</PageLayout>
