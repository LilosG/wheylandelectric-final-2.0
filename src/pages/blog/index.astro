---
import PageLayout from '../../layouts/PageLayout.astro';
import Section from '../../components/ui/Section.astro';
import CTASection from '../../components/sections/CTASection.astro';
import { generateMeta } from '../../lib/seo';
import { getCollection } from 'astro:content';

const meta = generateMeta({
  title: 'Electrical Tips & Insights | Wheyland Electric Blog',
  description: 'Practical electrical tips, guides, and insights from Wheyland Electric. Learn about EV chargers, panel upgrades, lighting, and more.',
  path: '/blog/',
});

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<PageLayout meta={meta} breadcrumbs={[{ label: 'Blog', href: '/blog/' }]}>
  <Section bg="white">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-brand-slate mb-6">Electrical Tips & Insights</h1>
      <p class="text-lg text-text-muted">
        Practical guides and information from the Wheyland Electric team.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}/`} class="block bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow overflow-hidden group">
          <div class="aspect-video bg-surface-subtle flex items-center justify-center">
            <svg class="w-12 h-12 text-surface-warm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
          <div class="p-6">
            <time class="text-xs text-text-muted" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="text-lg font-semibold text-brand-slate mt-2 mb-2 group-hover:text-brand-teal transition-colors">
              {post.data.title}
            </h2>
            <p class="text-sm text-text-muted">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </Section>

  <CTASection />
</PageLayout>
