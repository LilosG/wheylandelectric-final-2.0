---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Section from '../../components/ui/Section.astro';
import { blogPostMeta } from '../../lib/seo';
import { articleSchema } from '../../lib/schema/article';
import { getCollection } from 'astro:content';
import { getPageHeroImage } from '../../data/heroImages';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const meta = blogPostMeta(post.data.title, post.data.description, post.slug);
const blogPostHero = getPageHeroImage('blog-post');
const blogHeroImage = post.data.image || blogPostHero.src;

const schema = articleSchema(
  post.data.title,
  post.data.description,
  post.data.date.toISOString(),
  post.data.author,
  post.slug,
);
---
<PageLayout
  meta={meta}
  schemas={[schema]}
  breadcrumbs={[
    { label: 'Blog', href: '/blog/' },
    { label: post.data.title, href: `/blog/${post.slug}/` },
  ]}
>
  <Hero
    title={post.data.title}
    subtitle={post.data.description}
    compact
    showCTAs={false}
    showTrustCard={false}
    showStatChips={false}
    backgroundImage={blogHeroImage}
  />

  <Section bg="white" size="tight">
    <article class="max-w-3xl mx-auto">
      <header class="mb-8">
        <time class="text-sm text-text-muted" datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <div class="mt-4 text-sm text-text-muted">
          By <span class="font-medium text-brand-slate">{post.data.author}</span>
        </div>
      </header>

      <div class="rich-content">
        <Content />
      </div>
    </article>
  </Section>

  <CTASection title="Need Electrical Service?" subtitle="Contact Wheyland Electric for a free estimate on your next project." />
</PageLayout>
