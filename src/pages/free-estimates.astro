---
import PageLayout from '../layouts/PageLayout.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import PhotoEstimateForm from '../components/forms/PhotoEstimateForm.astro';
import FormShell from '../components/forms/FormShell.astro';
import Hero from '../components/sections/Hero.astro';
import Section from '../components/ui/Section.astro';
import { breadcrumbSchemaNode } from '../lib/schema/breadcrumb';
import { graphSchema, webPageSchemaNode } from '../lib/schema/graph';
import { generateMeta } from '../lib/seo';
import { getPageHeroImage } from '../data/heroImages';

const estimateHero = getPageHeroImage('free-estimates');

const meta = generateMeta({
  title: 'Free Estimate | Wheyland Electric',
  description: 'Request a free estimate from Wheyland Electric. Licensed electrician serving San Diego County. Call (858) 663-5564 or fill out our form.',
  path: '/free-estimates/',
});
---
<PageLayout
  meta={meta}
  schemas={[
    graphSchema([
      webPageSchemaNode({ type: 'WebPage', path: '/free-estimates/', name: meta.title, description: meta.description }),
      breadcrumbSchemaNode([{ label: 'Free Estimate', href: '/free-estimates/' }], '/free-estimates/'),
    ]),
  ]}
  breadcrumbs={[{ label: 'Free Estimate', href: '/free-estimates/' }]}
>
  <Hero
    title="Request Your Free Estimate"
    subtitle="Tell us about your project and we will get back to you promptly with a free estimate. No obligation, no pressure."
    variant="compact"
    showTrustCard={false}
    showStatChips={false}
    showCTAs={false}
    backgroundImage={estimateHero.src}
    imagePosition="center"
  />


  <TrustBar />

  <Section bg="subtle">
    <FormShell
      heading="Request a Free Estimate"
      subheading="Tell us about your project and we’ll follow up with next steps and scheduling options."
    >
      <PhotoEstimateForm />
    </FormShell>
  </Section>

</PageLayout>
