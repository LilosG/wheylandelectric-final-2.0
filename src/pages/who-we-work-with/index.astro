---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import HOAOfferBlock from '../../components/sections/HOAOfferBlock.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Section from '../../components/ui/Section.astro';
import Button from '../../components/ui/Button.astro';
import ResponsiveImage from '../../components/ResponsiveImage.astro';
import { breadcrumbSchemaNode } from '../../lib/schema/breadcrumb';
import { graphSchema, webPageSchemaNode } from '../../lib/schema/graph';
import { generateMeta } from '../../lib/seo';
import { getWhoWeServeImage, getPageHeroImage } from '../../data/heroImages';
import { segments } from '../../data/whoWeWorkWith';

const meta = generateMeta({
  title: 'Who We Work With | Wheyland Electric — Carlsbad Electrician',
  description: 'Wheyland Electric serves homeowners, property managers, HOA communities, commercial businesses, and general contractors across Carlsbad and North County San Diego. Licensed, bonded, and insured with a 1-year labor warranty.',
  path: '/who-we-work-with/',
});

const whoWeServeHero = getPageHeroImage('who-we-work-with');
---
<PageLayout
  meta={meta}
  schemas={[
    graphSchema([
      webPageSchemaNode({
        type: 'WebPage',
        path: '/who-we-work-with/',
        name: meta.title,
        description: meta.description,
      }),
      breadcrumbSchemaNode(
        [{ label: 'Who We Work With', href: '/who-we-work-with/' }],
        '/who-we-work-with/'
      ),
    ]),
  ]}
  breadcrumbs={[{ label: 'Who We Work With', href: '/who-we-work-with/' }]}
>
  <Hero
    title="Who We Work With"
    subtitle="Licensed electrical services for homeowners, property managers, HOA communities, commercial businesses, and general contractors across North County San Diego."
    showCTAs={false}
    variant="compact"
    showTrustCard={false}
    showStatChips={false}
    backgroundImage={whoWeServeHero.src}
  />

  <TrustBar />

  {segments.map((segment: import('../../data/whoWeWorkWith').WhoWeWorkWithSegment, index: number) => {
    const heroImage = getWhoWeServeImage(segment.key);
    const hasImage = heroImage && !heroImage.src.includes('placeholder');

    return (
      <Section bg={index % 2 === 0 ? 'white' : 'subtle'}>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="flex flex-col justify-center">
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-slate mb-4">{segment.title}</h2>
            <p class="text-text-muted leading-relaxed mb-6">{segment.description}</p>
            <ul class="space-y-2 mb-8">
              {segment.services.map((svc: { label: string; href: string }) => (
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-brand-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <a href={svc.href} class="text-sm text-text-muted hover:text-brand-teal transition-colors">
                    {svc.label}
                  </a>
                </li>
              ))}
            </ul>
            <div>
              <Button href={segment.cta.href} variant="secondary">{segment.cta.label}</Button>
            </div>
          </div>

          <div class="flex flex-col justify-center">
            {hasImage ? (
              <ResponsiveImage
                src={heroImage.src}
                alt={heroImage.alt}
                rounded="lg"
                containerClass="h-80 md:h-96 overflow-hidden"
                fillContainer
              />
            ) : (
              <div class="bg-gradient-to-br from-slate-100 to-slate-200 rounded-lg p-8 flex items-center justify-center h-80 md:h-96 shadow-md">
                <p class="text-slate-600 font-medium text-center">{segment.title}</p>
              </div>
            )}
          </div>
        </div>
      </Section>
    );
  })}

  <Section bg="subtle">
    <HOAOfferBlock />
  </Section>

  <CTASection
    title="Ready to get started?"
    subtitle="Contact Wheyland Electric for a free estimate. Licensed, bonded and insured with a 1-year labor warranty on all workmanship."
  />
</PageLayout>
