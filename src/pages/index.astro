---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import ServiceGrid from '../components/sections/ServiceGrid.astro';
import CityGrid from '../components/sections/CityGrid.astro';
import CustomerTypeCard from '../components/sections/CustomerTypeCard.astro';
import HOAOfferBlock from '../components/sections/HOAOfferBlock.astro';
import TestimonialBlock from '../components/sections/TestimonialBlock.astro';
import AboutPreview from '../components/sections/AboutPreview.astro';
import CTASection from '../components/sections/CTASection.astro';
import MapSection from '../components/sections/MapSection.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import { homePageMeta } from '../lib/seo';
import { graphSchema, webPageSchemaNode, websiteSchemaNode } from '../lib/schema/graph';
import { getPublishedPillars } from '../data/services';
import { getPublishedCities } from '../data/cities';

const meta = homePageMeta();
const services = getPublishedPillars();
const cities = getPublishedCities();
---
<PageLayout
  meta={meta}
  schemas={[
    graphSchema([
      websiteSchemaNode(),
      webPageSchemaNode({
        type: 'HomePage',
        path: '/',
        name: meta.title,
        description: meta.description,
      }),
    ]),
  ]}
  preloadHero
>
  {/* 1. Hero — dark indigo, full viewport, split layout */}
  <Hero
    eyebrow="Satisfaction Guaranteed"
    title="Trusted Carlsbad Electrician for Homes & Businesses"
    subtitle="Wheyland Electric provides residential and commercial electrical services across San Diego County, including panel upgrades, EV chargers, lighting, and troubleshooting."
  />

  {/* 2. TrustBar — columbia blue strip */}
  <TrustBar />

  {/* 3. CTA Band — drives qualified visitors to /free-estimates/ */}
  <CTASection
    title="Get a Free Estimate From Wheyland Electric"
    subtitle="Licensed, bonded & insured. We’ll follow up within one business day — no obligation, no pressure."
    tone="dark"
  />

  {/* 4. Services — surface-subtle bg */}
  <Section bg="subtle">
    <ServiceGrid services={services} heading="Residential & Commercial Electrical Services in San Diego County" />
    <div class="text-center mt-8">
      <Button href="/services/" variant="secondary">Explore all electrical services</Button>
    </div>
  </Section>

  {/* 5. Service Areas — dark indigo bg (self-contained) */}
  <CityGrid cities={cities} />

  {/* 6. Who We Work With — white bg */}
  <Section bg="white">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-heading font-bold text-brand-slate">
        Electrical Services for Homeowners, Property Managers, HOAs, and Contractors
      </h2>
      <span class="block w-16 h-0.5 bg-brand-teal mx-auto mt-3"></span>
      <p class="text-text-muted max-w-2xl mx-auto mt-4">
        From homeowners to HOA communities, Wheyland Electric serves a wide range of customers with the same dedication to quality and integrity.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <CustomerTypeCard
        title="Homeowners"
        description="Residential electrical services from panel upgrades to recessed lighting."
        icon="house"
      />
      <CustomerTypeCard
        title="Property Managers"
        description="Reliable electrical maintenance and prompt service calls for managed properties."
        icon="building"
      />
      <CustomerTypeCard
        title="HOA Communities"
        description="Monthly maintenance programs with flat-rate pricing and scheduled inspections."
        icon="landmark"
      />
      <CustomerTypeCard
        title="General Contractors"
        description="Licensed contractors trust Wheyland Electric for reliable subcontract electrical work on remodel and new construction projects."
        icon="briefcase"
      />
    </div>
  </Section>

  {/* 7. HOA Maintenance — warm gold-tinted bg */}
  <Section bg="warm">
    <HOAOfferBlock />
  </Section>

  {/* 8. Testimonials — dark indigo bg (self-contained) */}
  <TestimonialBlock />

  {/* 9. About Preview — white bg (self-contained) */}
  <AboutPreview />

  {/* 10. CTA — dark indigo with radial gradient (self-contained) */}
  <CTASection />

  {/* 11. Map / Local Service — white bg (self-contained) */}
  <MapSection />
</PageLayout>
