---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import ServiceGrid from '../components/sections/ServiceGrid.astro';
import CityGrid from '../components/sections/CityGrid.astro';
import CustomerTypeCard from '../components/sections/CustomerTypeCard.astro';
import HOAOfferBlock from '../components/sections/HOAOfferBlock.astro';
import TestimonialBlock from '../components/sections/TestimonialBlock.astro';
import AboutPreview from '../components/sections/AboutPreview.astro';
import CTASection from '../components/sections/CTASection.astro';
import MapSection from '../components/sections/MapSection.astro';
import InlineLeadCapture from '../components/forms/InlineLeadCapture.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import { homePageMeta } from '../lib/seo';
import { localBusinessSchema } from '../lib/schema/localBusiness';
import { getPublishedPillars } from '../data/services';
import { getPublishedCities } from '../data/cities';

const meta = homePageMeta();
const services = getPublishedPillars();
const cities = getPublishedCities();
---
<PageLayout meta={meta} schemas={[localBusinessSchema()]} preloadHero>
  {/* 1. Hero — dark indigo, full viewport, split layout */}
  <Hero
    eyebrow="Satisfaction Guaranteed"
    title="An Innovative Electrician"
    titleAccent="You Can Trust."
    subtitle="Licensed electricians for safe, code-compliant residential and commercial projects across San Diego County."
  />

  {/* 2. TrustBar — columbia blue strip */}
  <TrustBar />

  <Section bg="white" spacing="hero-tight">
    <div class="mx-auto max-w-4xl">
      <InlineLeadCapture
        formId="inline-lead-home"
        heading="Get a Fast Electrical Estimate"
        subheading="Share a few details and we’ll follow up with options, timeline, and next steps."
        variant="card"
      />
    </div>
  </Section>

  {/* 3. Services — white bg */}
  <Section bg="white">
    <ServiceGrid services={services} heading="Electrical Services You Can Count On" />
    <div class="text-center mt-8">
      <Button href="/services/" variant="secondary">View All Services</Button>
    </div>
  </Section>

  <Section bg="white" spacing="hero-adjacent">
    <div class="max-w-4xl mx-auto">
      <p class="text-text-muted text-lg leading-relaxed mb-5">
        Wheyland Electric delivers full-service installation, repairs, and maintenance with transparent communication from estimate through final walkthrough.
      </p>
      <ul class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <li class="rounded-lg bg-surface-subtle px-4 py-3 text-sm text-text-muted">Residential service upgrades, rewiring, and lighting improvements.</li>
        <li class="rounded-lg bg-surface-subtle px-4 py-3 text-sm text-text-muted">Commercial tenant improvements and dependable troubleshooting support.</li>
        <li class="rounded-lg bg-surface-subtle px-4 py-3 text-sm text-text-muted">Permit-ready workmanship backed by licensing, insurance, and warranty coverage.</li>
      </ul>
    </div>
  </Section>

  {/* 4. Service Areas — dark indigo bg (self-contained) */}
  <CityGrid cities={cities} />

  {/* 5. Who We Work With — surface-subtle bg */}
  <Section bg="subtle">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-heading font-bold text-brand-slate">
        Who We Work With
      </h2>
      <span class="block w-16 h-0.5 bg-brand-teal mx-auto mt-3"></span>
      <p class="text-text-muted max-w-2xl mx-auto mt-4">
        From homeowners to HOA communities, Wheyland Electric serves a wide range of customers with the same dedication to quality and integrity.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <CustomerTypeCard
        title="Homeowners"
        description="Residential electrical services from panel upgrades to recessed lighting."
        icon="house"
      />
      <CustomerTypeCard
        title="Property Managers"
        description="Reliable electrical maintenance and prompt service calls for managed properties."
        icon="building"
      />
      <CustomerTypeCard
        title="HOA Communities"
        description="Monthly maintenance programs with flat-rate pricing and scheduled inspections."
        icon="landmark"
      />
      <CustomerTypeCard
        title="EV Owners"
        description="Level 2 charger installation for Tesla, Rivian, Ford, and all EV makes."
        icon="zap"
      />
    </div>
  </Section>

  {/* 6. HOA Maintenance — warm gold-tinted bg */}
  <Section bg="warm">
    <HOAOfferBlock />
  </Section>

  {/* 7. Testimonials — dark indigo bg (self-contained) */}
  <TestimonialBlock />

  {/* 8. About Preview — white bg (self-contained) */}
  <AboutPreview />

  {/* 9. CTA — dark indigo with radial gradient (self-contained) */}
  <CTASection />

  {/* 10. Map / Local Service — white bg (self-contained) */}
  <MapSection />
</PageLayout>
