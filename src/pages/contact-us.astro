---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import GBPEmbed from '../components/sections/GBPEmbed.astro';
import Hero from '../components/sections/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import Section from '../components/ui/Section.astro';
import { generateMeta } from '../lib/seo';
import { localBusinessSchema } from '../lib/schema/localBusiness';
import { site } from '../data/site';
import { getPageHeroImage } from '../data/heroImages';

const contactHero = getPageHeroImage('contact');

const meta = generateMeta({
  title: 'Contact Us | Wheyland Electric',
  description: 'Contact Wheyland Electric in Carlsbad, CA. Call (858) 663-5564 or send us a message. Licensed electrician serving San Diego County.',
  path: '/contact-us/',
});
---
<PageLayout meta={meta} schemas={[localBusinessSchema()]} breadcrumbs={[{ label: 'Contact', href: '/contact-us/' }]}>
  <Hero
    title="Contact Us"
    subtitle="Have a question or need electrical service? We are here to help."
    compact
    showTrustCard={false}
    showStatChips={false}
    showCTAs={false}
    backgroundImage={contactHero.src}
    imagePosition="center"
  />

  <TrustBar />

  <Section bg="subtle">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div>
        <h2 class="text-2xl font-heading font-bold text-brand-slate mb-6">Get in Touch</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-surface/30 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand-slate" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-brand-slate">Phone</h3>
              <a href={`tel:${site.nap.phoneTel}`} class="text-brand-teal hover:text-brand-slate transition-colors font-medium">{site.nap.phone}</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-surface/30 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand-slate" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-brand-slate">Email</h3>
              <a href={`mailto:${site.nap.email}`} class="text-brand-teal hover:text-brand-slate transition-colors">{site.nap.email}</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-surface/30 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand-slate" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-brand-slate">Address</h3>
              <p class="text-text-muted">{site.nap.address.full}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-surface/30 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand-slate" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-brand-slate">Hours</h3>
              <p class="text-text-muted">{site.hours.weekday}</p>
              <p class="text-text-muted">{site.hours.weekend}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <ContactForm />
    </div>
  </Section>

  <Section bg="white">
    <GBPEmbed heading="Find Us" />
  </Section>
</PageLayout>
