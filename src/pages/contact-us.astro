---
import PageLayout from '../layouts/PageLayout.astro';
import PhotoEstimateForm from '../components/forms/PhotoEstimateForm.astro';
import GBPEmbed from '../components/sections/GBPEmbed.astro';
import Hero from '../components/sections/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import { contactPageMeta } from '../lib/seo';
import { breadcrumbSchemaNode } from '../lib/schema/breadcrumb';
import { graphSchema, webPageSchemaNode } from '../lib/schema/graph';
import { site } from '../data/site';
import { getPageHeroImage } from '../data/heroImages';

const contactHero = getPageHeroImage('contact');
const meta = contactPageMeta();
---
<PageLayout
  meta={meta}
  schemas={[
    graphSchema([
      webPageSchemaNode({
        type: 'ContactPage',
        path: '/contact-us/',
        name: meta.title,
        description: meta.description,
      }),
      breadcrumbSchemaNode([{ label: 'Contact', href: '/contact-us/' }], '/contact-us/'),
    ]),
  ]}
  breadcrumbs={[{ label: 'Contact', href: '/contact-us/' }]}
>
  <Hero
    title="Contact Us"
    subtitle="Have a question or need electrical service? We are here to help."
    variant="compact"
    showTrustCard={false}
    showStatChips={false}
    showCTAs={false}
    backgroundImage={contactHero.src}
    imagePosition="center"
  />

  <TrustBar />

  <Section bg="subtle">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

        <!-- LEFT: Contact info card -->
        <aside class="lg:col-span-4 flex flex-col gap-4">

          <!-- Contact details -->
          <div class="rounded-2xl border border-surface-subtle bg-white p-6 shadow-sm flex-1">
            <h2 class="text-xl font-heading font-bold text-brand-slate mb-6">Get in Touch</h2>
            <ul class="space-y-5">
              <li class="flex items-start gap-4">
                <div class="w-9 h-9 rounded-lg bg-brand-teal/10 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-0.5">Phone</p>
                  <a href={`tel:${site.nap.phoneTel}`} class="text-base font-semibold text-brand-slate hover:text-brand-teal transition-colors">{site.nap.phone}</a>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-9 h-9 rounded-lg bg-brand-teal/10 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-0.5">Email</p>
                  <a href={`mailto:${site.nap.email}`} class="text-sm font-medium text-brand-slate hover:text-brand-teal transition-colors break-all">{site.nap.email}</a>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-9 h-9 rounded-lg bg-brand-teal/10 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-0.5">Address</p>
                  <p class="text-sm text-brand-slate">{site.nap.address.full}</p>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-9 h-9 rounded-lg bg-brand-teal/10 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-0.5">Hours</p>
                  <p class="text-sm text-brand-slate">{site.hours.weekday}</p>
                  <p class="text-sm text-text-muted">{site.hours.weekend}</p>
                </div>
              </li>
            </ul>
          </div>

          <!-- Estimate nudge -->
          <div class="rounded-2xl border border-brand-teal/20 bg-brand-teal/5 p-5">
            <p class="text-sm font-semibold text-brand-slate mb-1">Need a project estimate?</p>
            <p class="text-xs text-text-muted mb-4">Use our dedicated estimate form for faster turnaround on project quotes.</p>
            <Button href="/free-estimates/" variant="primary" size="sm">Request Free Estimate</Button>
          </div>

        </aside>

        <!-- RIGHT: Contact form card -->
        <div class="lg:col-span-8 rounded-2xl border border-surface-subtle border-t-4 border-t-brand-gold bg-white p-6 shadow-sm md:p-8">
          <header class="mb-6 space-y-1">
            <h2 class="text-2xl font-heading font-bold text-brand-slate">Send Us a Message</h2>
            <p class="text-sm text-text-muted">Questions about a repair or upcoming project? We’re here to help.</p>
          </header>
          <PhotoEstimateForm />
        </div>

      </div>
    </div>
  </Section>

  <Section bg="white">
    <GBPEmbed heading="Find Us" />
  </Section>

</PageLayout>
