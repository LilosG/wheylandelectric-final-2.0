---
import PageLayout from '../layouts/PageLayout.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import { generateMeta } from '../lib/seo';
import { site } from '../data/site';

const meta = generateMeta({
  title: 'Thank You | Wheyland Electric',
  description: 'Thank you for contacting Wheyland Electric. We will be in touch soon.',
  path: '/thank-you/',
});
---
<PageLayout meta={meta}>
  <Section bg="white">
    <div class="max-w-2xl mx-auto text-center py-12">
      <div class="w-20 h-20 bg-brand-mint/30 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-brand-moonstone" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-brand-indigo mb-6">Thank You!</h1>
      <p class="text-lg text-text-muted mb-4">
        Your message has been received. We will get back to you as soon as possible.
      </p>
      <p class="text-text-muted mb-8">
        Need immediate assistance? Call us at{' '}
        <a href={`tel:${site.nap.phoneTel}`} class="text-brand-moonstone font-semibold hover:text-brand-indigo transition-colors">
          {site.nap.phone}
        </a>
      </p>
      <Button href="/" variant="secondary">Back to Homepage</Button>
    </div>
  </Section>
</PageLayout>
