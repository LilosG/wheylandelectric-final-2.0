---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import { generateMeta } from '../lib/seo';
import { site } from '../data/site';
import { getPageHeroImage } from '../data/heroImages';

const thankYouHero = getPageHeroImage('thank-you');

const meta = generateMeta({
  title: 'Thank You | Wheyland Electric',
  description: 'Thank you for contacting Wheyland Electric. We will be in touch soon.',
  path: '/thank-you/',
});
---
<PageLayout meta={meta}>
  <Hero
    title="Thank You!"
    subtitle="Your message has been received. We will get back to you as soon as possible."
    compact
    showCTAs={false}
    showTrustCard={false}
    showStatChips={false}
    backgroundImage={thankYouHero.src}
  />

  <Section bg="white" class="pt-8 md:pt-12">
    <div class="max-w-2xl mx-auto text-center py-8">
      <div class="w-20 h-20 bg-surface-warm/30 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-slate mb-6">We Appreciate Your Request</h2>
      <p class="text-lg text-text-muted mb-4">
        Your message has been received. We will get back to you as soon as possible.
      </p>
      <p class="text-text-muted mb-8">
        Need immediate assistance? Call us at{' '}
        <a href={`tel:${site.nap.phoneTel}`} class="text-brand-teal font-semibold hover:text-brand-slate transition-colors">
          {site.nap.phone}
        </a>
      </p>
      <Button href="/" variant="secondary">Back to Homepage</Button>
    </div>
  </Section>
</PageLayout>
