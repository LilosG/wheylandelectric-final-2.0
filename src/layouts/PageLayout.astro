---
import '../styles/global.css';
import type { PageMeta, BreadcrumbItem } from '../types';
import Header from '../components/navigation/Header.astro';
import Footer from '../components/navigation/Footer.astro';
import MobileCTA from '../components/navigation/MobileCTA.astro';
import Breadcrumbs from '../components/navigation/Breadcrumbs.astro';
import SEOHead from '../components/seo/SEOHead.astro';
import { electricianSchemaNode } from '../lib/schema/localBusiness';
import { graphSchema } from '../lib/schema/graph';
import { getGoogleRating } from '../lib/googlePlaces';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';

interface Props {
  meta: PageMeta;
  schemas?: Record<string, unknown>[];
  breadcrumbs?: BreadcrumbItem[];
  preloadHero?: boolean;
}

const { meta, schemas = [], breadcrumbs, preloadHero = false } = Astro.props;

// Always prepend the Electrician LocalBusiness entity to every page schema.
// This ensures Google can find the business entity from any page entry point.
const liveRating = await getGoogleRating();
const baseSchema = graphSchema([electricianSchemaNode(liveRating)]);
const allSchemas = [baseSchema, ...schemas];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />
    {preloadHero && (
      <link
        rel="preload"
        as="image"
        href="/images/hero/wheyland-electric-edison-bulb-lighting-carlsbad.webp"
        type="image/webp"
      />
    )}
    <SEOHead meta={meta} schemas={allSchemas} />
    <GoogleAnalytics />
    <script is:inline async src="https://analytics.ahrefs.com/analytics.js" data-key="TbbKwC7nVeT39LSOKMNAiA"></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 pb-20 lg:pb-0">
      {breadcrumbs && breadcrumbs.length > 0 && (
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <Breadcrumbs items={breadcrumbs} />
        </div>
      )}
      <slot />
    </main>
    <Footer />
    <MobileCTA />
  </body>
</html>
